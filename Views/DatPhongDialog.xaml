<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.DatPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đặt Phòng" Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: thông tin phòng -->
        <Border Grid.Row="0" CornerRadius="10" Padding="14,10" Background="#EBF5FB">
            <TextBlock x:Name="TxtPhong" FontSize="14" FontWeight="SemiBold" Foreground="#0F3460"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Tìm khách hàng -->
                <TextBlock Text="Khách hàng" FontSize="12" FontWeight="SemiBold"
                           Foreground="#555" Margin="0,0,0,4"/>
                <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="36" Margin="0,0,0,4">
                    <TextBox x:Name="TxtTimKhach" BorderThickness="0" Padding="10,0"
                             VerticalAlignment="Center" FontSize="13"
                             TextChanged="TxtTimKhach_TextChanged"
                             PlaceholderText="Tìm theo tên / SĐT / CCCD..."/>
                </Border>

                <!-- Dropdown kết quả tìm kiếm -->
                <ListBox x:Name="ListKhach" MaxHeight="120" Visibility="Collapsed"
                         SelectionChanged="ListKhach_SelectionChanged"
                         DisplayMemberPath="TenKhachHang"
                         BorderBrush="#DDE" BorderThickness="1" Margin="0,0,0,4"/>

                <!-- Info hạng KH -->
                <TextBlock x:Name="TxtKhachInfo" FontSize="11" Foreground="#0078D4"
                           Visibility="Collapsed" Margin="0,0,0,8"/>

                <!-- Nếu khách mới: nhập thêm -->
                <Expander Header="Khách mới — nhập thông tin" Margin="0,0,0,12">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Số điện thoại" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="34" Margin="0,0,0,8">
                            <TextBox x:Name="TxtDienThoai" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>
                        <TextBlock Text="CCCD" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="34">
                            <TextBox x:Name="TxtCCCD" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- Ngày nhận / trả -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ngày nhận phòng" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpNgayNhan" SelectedDateChanged="DatePicker_Changed"
                                    FontSize="13" Height="34"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ngày trả phòng" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpNgayTra" SelectedDateChanged="DatePicker_Changed"
                                    FontSize="13" Height="34"/>
                    </StackPanel>
                </Grid>

                <!-- Khuyến mãi -->
                <TextBlock Text="Khuyến mãi" FontSize="12" FontWeight="SemiBold"
                           Foreground="#555" Margin="0,0,0,4"/>
                <ComboBox x:Name="CboKhuyenMai" Height="34" FontSize="13" Margin="0,0,0,12"
                          SelectionChanged="CboKhuyenMai_Changed"/>

                <!-- Tính giá -->
                <Border CornerRadius="8" Padding="12,8" Background="#F0F7FF">
                    <TextBlock x:Name="TxtTinhGia" FontSize="13" Foreground="#0F3460"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="BtnHuy" Content="Hủy" Height="38"
                    FontSize="13" Click="BtnHuy_Click"
                    Background="#F5F5F5" BorderThickness="0"/>
            <Button Grid.Column="2" x:Name="BtnXacNhan" Content="Xác nhận đặt phòng" Height="38"
                    FontSize="13" FontWeight="SemiBold" Foreground="White"
                    Click="BtnXacNhan_Click">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#00BCF2" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>
