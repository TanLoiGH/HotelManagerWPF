<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.ThanhToanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh Toán" Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Mã hóa đơn -->
            <Border CornerRadius="10" Padding="14,10" Background="#EBF5FB" Margin="0,0,0,16">
                <Grid>
                    <TextBlock Text="Hóa đơn:" FontSize="12" Foreground="#555"/>
                    <TextBlock x:Name="TxtMaHD" HorizontalAlignment="Right"
                               FontSize="14" FontWeight="Bold" Foreground="#0F3460"/>
                </Grid>
            </Border>

            <!-- Chi tiết tiền -->
            <TextBlock Text="Chi tiết hóa đơn" FontSize="13" FontWeight="SemiBold"
                       Foreground="#0F3460" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,6">
                <TextBlock Text="Tiền phòng:" FontSize="13" Foreground="#555"/>
                <TextBlock x:Name="TxtTienPhong" HorizontalAlignment="Right"
                           FontSize="13" FontWeight="SemiBold" Foreground="#1A3A5C"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <TextBlock Text="Tiền dịch vụ:" FontSize="13" Foreground="#555"/>
                <TextBlock x:Name="TxtTienDV" HorizontalAlignment="Right"
                           FontSize="13" FontWeight="SemiBold" Foreground="#1A3A5C"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <TextBlock Text="VAT:" FontSize="13" Foreground="#555"/>
                <TextBlock x:Name="TxtVAT" HorizontalAlignment="Right"
                           FontSize="13" Foreground="#888"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <TextBlock Text="Khuyến mãi:" FontSize="13" Foreground="#555"/>
                <TextBlock x:Name="TxtKhuyenMai" HorizontalAlignment="Right"
                           FontSize="13" Foreground="#00B894"/>
            </Grid>

            <Separator Margin="0,6,0,6"/>

            <Grid Margin="0,0,0,4">
                <TextBlock Text="TỔNG THANH TOÁN:" FontSize="14" FontWeight="Bold" Foreground="#0F3460"/>
                <TextBlock x:Name="TxtTong" HorizontalAlignment="Right"
                           FontSize="16" FontWeight="Bold" Foreground="#0078D4"/>
            </Grid>
            <TextBlock x:Name="TxtConLai" FontSize="13" Foreground="#E74C3C"
                       HorizontalAlignment="Right" Margin="0,0,0,16"/>

            <!-- Lịch sử giao dịch -->
            <StackPanel x:Name="PanelLichSu" Visibility="Collapsed" Margin="0,0,0,16">
                <TextBlock Text="Giao dịch trước" FontSize="12" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,6"/>
                <ListBox x:Name="ListThanhToan" MaxHeight="100"
                         BorderBrush="#DDE" BorderThickness="1" FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding LoaiGiaoDich}" FontSize="12"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="12"
                                           FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <Binding Path="SoTien" StringFormat="{}{0:N0} ₫"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Form thanh toán -->
            <TextBlock Text="Giao dịch mới" FontSize="13" FontWeight="SemiBold"
                       Foreground="#0F3460" Margin="0,0,0,8"/>

            <TextBlock Text="Số tiền thanh toán" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="36" Margin="0,0,0,10">
                <TextBox x:Name="TxtSoTien" BorderThickness="0" Padding="10,0"
                         VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                         TextAlignment="Right"/>
            </Border>

            <TextBlock Text="Phương thức thanh toán" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CboPTTT" Height="34" FontSize="13" Margin="0,0,0,10"/>

            <TextBlock Text="Loại giao dịch" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <ComboBox x:Name="CboLoaiGD" Height="34" FontSize="13" Margin="0,0,0,10">
                <ComboBoxItem Content="Thanh toán cuối" IsSelected="True"/>
                <ComboBoxItem Content="Đặt cọc"/>
                <ComboBoxItem Content="Hoàn tiền"/>
            </ComboBox>

            <TextBlock Text="Ghi chú" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Margin="0,0,0,16">
                <TextBox x:Name="TxtNoiDung" BorderThickness="0" Padding="10,6"
                         FontSize="13" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Hủy" Height="38" FontSize="13"
                        Click="BtnHuy_Click" Background="#F5F5F5" BorderThickness="0"/>
                <Button Grid.Column="2" x:Name="BtnThanhToan"
                        Content="Xác nhận thanh toán" Height="38"
                        FontSize="13" FontWeight="SemiBold" Foreground="White"
                        Background="#00B894" BorderThickness="0"
                        Click="BtnThanhToan_Click"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
