<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.PhongPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
      Background="Transparent"
      Title="Quản lý Phòng">

    <Page.DataContext>
        <vm:PhongDiagramViewModel/>
    </Page.DataContext>

    <!-- Button style resources -->
    <Page.Resources>
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#DDE8F4"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#4A6B8A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEF5FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterBtnActive" TargetType="Button" BasedOn="{StaticResource FilterBtn}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>


    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar: Filter + Search ─────────────────────── -->
        <Border Grid.Row="0" CornerRadius="14" Background="White" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07" Color="#0078D4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filter buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAll" Content="Tất cả" Tag="all"
                            Click="Filter_Click" Height="34" Padding="16,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtnActive}"/>
                    <Button Content="🟢 Trống" Tag="PTT01"
                            Click="Filter_Click" Height="34" Padding="14,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtn}"/>
                    <Button Content="🔴 Đang ở" Tag="PTT02"
                            Click="Filter_Click" Height="34" Padding="14,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtn}"/>
                    <Button Content="🟡 Dọn dẹp" Tag="PTT03"
                            Click="Filter_Click" Height="34" Padding="14,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtn}"/>
                    <Button Content="🟣 Đã đặt" Tag="PTT05"
                            Click="Filter_Click" Height="34" Padding="14,0"
                            Style="{StaticResource FilterBtn}"/>
                </StackPanel>

                <!-- Search box -->
                <Border Grid.Column="2" CornerRadius="10" BorderBrush="#E0EAF4"
                        BorderThickness="1.5" Padding="10,0" Height="34" Width="200">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtSearch" BorderThickness="0"
                                 Background="Transparent" VerticalAlignment="Center"
                                 FontSize="13" Foreground="#333"
                                 TextChanged="TxtSearch_TextChanged"
                                 Width="150"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>


        <!-- ── Main: Room Grid + Detail Panel ───────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="300" x:Name="DetailCol"/>
            </Grid.ColumnDefinitions>

            <!-- Room cards grid -->
            <Border Grid.Column="0" CornerRadius="16" Background="White" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07" Color="#0078D4"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtRoomCount" Grid.Row="0"
                               Text="Đang tải..." FontSize="13" Foreground="#888"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PhongList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="140" Height="120" Margin="8" CornerRadius="14"
                                            Background="{Binding CardBackground}"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="PhongCard_Click"
                                            Tag="{Binding}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                              Color="{Binding ShadowColor}" Opacity="0.30"/>
                                        </Border.Effect>
                                        <Grid Margin="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MaPhong}"
                                                           FontSize="22" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding TenLoaiPhong}"
                                                           FontSize="11" Foreground="#DDF"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border Grid.Row="1" CornerRadius="6" Padding="6,3"
                                                    Background="#22FFFFFF" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TenTrangThai}"
                                                           FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Detail Panel -->
            <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07" Color="#0078D4"/>
                </Border.Effect>
                <StackPanel>

                    <TextBlock Text="Chi Tiết Phòng" FontSize="16" FontWeight="Bold"
                               Foreground="#0F3460" Margin="0,0,0,20"/>

                    <!-- Empty state -->
                    <StackPanel x:Name="PanelEmpty" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="48" HorizontalAlignment="Center" Margin="0,40,0,12"/>
                        <TextBlock Text="Chọn một phòng để xem chi tiết"
                                   FontSize="13" Foreground="#AAA" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Detail info -->
                    <StackPanel x:Name="PanelDetail" Visibility="Collapsed">

                        <!-- Room header -->
                        <Border CornerRadius="12" Padding="16" Margin="0,0,0,16"
                                Background="{Binding SelectedCardBg}">
                            <Grid>
                                <StackPanel>
                                    <TextBlock x:Name="DetailMaPhong" FontSize="28"
                                               FontWeight="Bold" Foreground="White"/>
                                    <TextBlock x:Name="DetailLoaiPhong" FontSize="13"
                                               Foreground="#DDEEFF"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                        CornerRadius="8" Padding="8,4" Background="#22FFFFFF">
                                    <TextBlock x:Name="DetailTrangThai" FontSize="11"
                                               Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Info rows -->
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Loại phòng" FontSize="12" Foreground="#888"/>
                                <TextBlock x:Name="InfoLoaiPhong" HorizontalAlignment="Right"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                            </Grid>
                            <Separator Background="#EEE" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Sức chứa" FontSize="12" Foreground="#888"/>
                                <TextBlock x:Name="InfoSoNguoi" HorizontalAlignment="Right"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                            </Grid>
                            <Separator Background="#EEE" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Giá/đêm" FontSize="12" Foreground="#888"/>
                                <TextBlock x:Name="InfoGia" HorizontalAlignment="Right"
                                           FontSize="14" FontWeight="Bold" Foreground="#0078D4"/>
                            </Grid>
                        </StackPanel>

                        <!-- Tiện nghi -->
                        <TextBlock Text="Tiện nghi" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#0F3460" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="TienNghiList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="8,5" Margin="0,0,0,6"
                                            Background="#F0F7FF">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✓ " Foreground="#0078D4" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding TenTienNghi}"
                                                       FontSize="12" Foreground="#2C4A6E"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNoTienNghi" Text="Chưa có tiện nghi"
                                   FontSize="12" Foreground="#BBB" Margin="0,4,0,16"/>

                        <!-- Action button -->
                        <Button x:Name="BtnDatPhong" Content="📅  Đặt Phòng"
                                Height="42" Margin="0,12,0,0"
                                FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                Click="BtnDatPhong_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="10" Padding="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#0078D4" Offset="0"/>
                                                <GradientStop Color="#00BCF2" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ContentPresenter.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </ContentPresenter.Resources>
                                        </ContentPresenter>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Page>
