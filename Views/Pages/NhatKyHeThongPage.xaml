<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Pages.NhatKyHeThongPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Nhật ký hệ thống"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppSecondaryBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Margin="0,0,0,1"
            Padding="20"
            Background="{StaticResource AppPrimaryBackground}">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource AppPrimaryBlue}"
                    Text="LỊCH SỬ HOẠT ĐỘNG" />

                <TextBox
                    x:Name="txtSearch"
                    Width="300"
                    Style="{StaticResource SearchTextBoxStyle}"
                    Tag="Tìm kiếm theo nhân viên, thao tác..."
                    TextChanged="TxtSearch_TextChanged" />
            </StackPanel>
        </Border>

        <DataGrid
            x:Name="dgNhatKy"
            Grid.Row="1"
            Margin="10"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            ItemsSource="{Binding FilteredLogs}"
            Style="{StaticResource ModernDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="160"
                    Binding="{Binding ThoiGian, StringFormat='dd/MM/yyyy HH:mm:ss'}"
                    Header="Thời gian" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding MaNhanVien}"
                    Header="Nhân viên" />
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding ThaoTac}"
                    Header="Thao tác">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding ChiTiet}"
                    Header="Chi tiết nội dung" />
                <DataGridTextColumn
                    Width="130"
                    Binding="{Binding IpAddress}"
                    Header="Địa chỉ IP" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
