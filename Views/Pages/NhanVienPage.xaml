<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.NhanVienPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    Title="Nhân Viên"
    Background="Transparent">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!--  Danh sách  -->
        <ContentControl
            Grid.Column="0"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16,12"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="TxtTongNV"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{DynamicResource Brush.Heading}" />
                            <Border
                                Width="180"
                                Height="34"
                                Margin="16,0,0,0"
                                Padding="10,0"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1.5"
                                CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="🔍" />
                                    <TextBox
                                        x:Name="TxtSearch"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="15"
                                        TextChanged="TxtSearch_TextChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Height="36"
                            Padding="16,0"
                            Click="BtnThem_Click"
                            Content="➕  Thêm"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                    </Grid>
                </Border>

                <DataGrid
                    x:Name="NVGrid"
                    Grid.Row="1"
                    Padding="8"
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="44"
                    SelectionChanged="NVGrid_SelectionChanged"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding MaNhanVien}"
                            Header="Mã NV" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenNhanVien}"
                            Header="Tên nhân viên" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding ChucVu}"
                            Header="Chức vụ" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding DienThoai}"
                            Header="Điện thoại" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding TenTrangThai}"
                            Header="Trạng thái" />
                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding QuyenText}"
                            Header="Quyền" />
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!--  Form  -->
        <ContentControl
            Grid.Column="2"
            Padding="20"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <TextBlock
                        x:Name="TxtFormTitle"
                        Margin="0,0,0,20"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.Heading}"
                        Text="Chi tiết nhân viên" />

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,30,0,12"
                            HorizontalAlignment="Center"
                            FontSize="50"
                            Text="🪪" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="15"
                            Foreground="{DynamicResource Brush.TextMuted}"
                            Text="Chọn nhân viên hoặc bấm Thêm mới"
                            TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Họ tên *" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtTen"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Chức vụ" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtChucVu"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Điện thoại" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtDienThoai"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Email" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtEmail"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="CCCD" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtCCCD"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Trạng thái" />
                        <ComboBox
                            x:Name="CboTrangThai"
                            Height="34"
                            Margin="0,0,0,16"
                            FontSize="15" />

                        <Separator Margin="0,0,0,16" Background="{DynamicResource Brush.Border}" />

                        <!--  Tài khoản  -->
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="🔐 Tài khoản đăng nhập" />

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Tên đăng nhập" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtTenDangNhap"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Mật khẩu" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <PasswordBox
                                x:Name="PbMatKhau"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Quyền" />
                        <ComboBox
                            x:Name="CboQuyen"
                            Height="34"
                            Margin="0,0,0,20"
                            FontSize="15" />

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Trạng thái tài khoản" />
                        <ComboBox
                            x:Name="CboTaiKhoanActive"
                            Height="34"
                            Margin="0,0,0,20"
                            FontSize="15" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="BtnXoa"
                                Grid.Column="0"
                                Click="BtnXoa_Click"
                                Content="🗑 Xóa"
                                Cursor="Hand"
                                FontSize="15"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
                            <Button
                                x:Name="BtnLuu"
                                Grid.Column="2"
                                Click="BtnLuu_Click"
                                Content="💾 Lưu"
                                Cursor="Hand"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Style="{DynamicResource MacFluent.ButtonPrimary}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>
    </Grid>
</Page>




