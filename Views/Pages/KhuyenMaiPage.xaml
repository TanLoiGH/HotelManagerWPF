<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.KhuyenMaiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    Title="Khuyến Mãi"
    Background="Transparent">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <ContentControl
            Grid.Column="0"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16,12"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="TxtTong"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{DynamicResource Brush.Heading}" />
                            <Border
                                Width="200"
                                Height="34"
                                Margin="16,0,0,0"
                                Padding="10,0"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1.5"
                                CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="🔍" />
                                    <TextBox
                                        x:Name="TxtSearch"
                                        Width="190"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="15"
                                        TextChanged="TxtSearch_TextChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Height="36"
                            Padding="16,0"
                            Click="BtnThem_Click"
                            Content="➕  Thêm"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                    </Grid>
                </Border>

                <DataGrid
                    x:Name="KmGrid"
                    Grid.Row="1"
                    Padding="8"
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="44"
                    SelectionChanged="KmGrid_SelectionChanged"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding MaKhuyenMai}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Mã" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenKhuyenMai}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Tên khuyến mãi" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding LoaiKhuyenMai}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Loại" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding GiaTriText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Giá trị" />
                        <DataGridTextColumn
                            Width="95"
                            Binding="{Binding TuNgayText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Từ ngày" />
                        <DataGridTextColumn
                            Width="95"
                            Binding="{Binding DenNgayText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Đến ngày" />
                        <DataGridTemplateColumn Width="110" Header="Trạng thái">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="4"
                                        Padding="8,3"
                                        HorizontalAlignment="Center"
                                        Background="{Binding StatusColor}"
                                        CornerRadius="6">
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="White"
                                            Text="{Binding StatusText}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.RoomReservedSoft}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!--  Form  -->
        <ContentControl
            Grid.Column="2"
            Padding="20"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        x:Name="TxtFormTitle"
                        Margin="0,0,0,20"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.Heading}"
                        Text="Chi tiết" />

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,30,0,12"
                            HorizontalAlignment="Center"
                            FontSize="50"
                            Text="🎁" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="15"
                            Foreground="{DynamicResource Brush.TextMuted}"
                            Text="Chọn hoặc thêm khuyến mãi" />
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Tên khuyến mãi *" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtTen"
                                Margin="10,5"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Loại *" />
                        <ComboBox
                            x:Name="CboLoai"
                            Height="34"
                            Margin="0,0,0,12"
                            FontSize="15"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            SelectionChanged="CboLoai_Changed">
                            <ComboBoxItem Content="Phần trăm" IsSelected="True" />
                            <ComboBoxItem Content="Số tiền" />
                        </ComboBox>

                        <TextBlock
                            x:Name="TxtLabelGiaTri"
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Giá trị (%) *" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtGiaTri"
                                Margin="10,5"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15"
                                TextAlignment="Right" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Giá trị tối thiểu đơn (₫)" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtToiThieu"
                                Margin="10,5"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15"
                                Text="0"
                                TextAlignment="Right" />
                        </Border>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Từ ngày *" />
                                <DatePicker
                                    x:Name="DpTuNgay"
                                    Height="34"
                                    FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Đến ngày *" />
                                <DatePicker
                                    x:Name="DpDenNgay"
                                    Height="34"
                                    FontSize="14" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Áp dụng cho hạng KH" />
                        <ComboBox
                            x:Name="CboLoaiKhach"
                            Height="34"
                            Margin="0,0,0,12"
                            FontSize="15" />

                        <CheckBox
                            x:Name="ChkActive"
                            Margin="0,0,0,20"
                            Content="Đang hoạt động"
                            FontSize="15"
                            IsChecked="True" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="BtnXoa"
                                Grid.Column="0"
                                Height="38"
                                Click="BtnXoa_Click"
                                Content="🗑 Xóa"
                                Cursor="Hand"
                                FontSize="15"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
                            <Button
                                Grid.Column="2"
                                Height="38"
                                Click="BtnLuu_Click"
                                Content="💾 Lưu"
                                Cursor="Hand"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Style="{DynamicResource MacFluent.ButtonPrimary}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>
    </Grid>
</Page>




