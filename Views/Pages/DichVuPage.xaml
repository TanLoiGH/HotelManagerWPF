<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DichVuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Dịch Vụ">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <ContentControl Grid.Column="0"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="16,12" BorderBrush="#F0F5FA"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTongDV" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                            <Border CornerRadius="8" Padding="10,0" Height="34"
                                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Margin="16,0,0,0" Width="180">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtSearch" BorderThickness="0"
                                             Background="Transparent" VerticalAlignment="Center"
                                             FontSize="15" TextChanged="TxtSearch_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1" Content="➕  Thêm dịch vụ"
                                Height="36" Padding="16,0" FontSize="15"
                                FontWeight="SemiBold" Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonAction.Add}"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="DvGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="15"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="DvGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã DV" Binding="{Binding MaDichVu}" Width="90"/>
                        <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding TenDichVu}" Width="*"/>
                        <DataGridTextColumn Header="Giá" Binding="{Binding GiaText}" Width="120"/>
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="90"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,3" Margin="4"
                                            Background="{Binding ActiveColor}" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ActiveText}"
                                                   FontSize="13" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!-- Form thêm/sửa -->
        <ContentControl Grid.Column="2"
                        Background="{DynamicResource Brush.Surface}" Padding="20"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Chi tiết dịch vụ"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,20"/>

                <!-- Empty state -->
                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock Text="🍽️" FontSize="50" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                    <TextBlock Text="Chọn dịch vụ hoặc bấm Thêm mới"
                               FontSize="15" Foreground="#AAA"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <!-- Form -->
                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock Text="Tên dịch vụ *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <TextBlock Text="Giá (₫) *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtGia" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15" TextAlignment="Right"/>
                    </Border>

                    <TextBlock Text="Đơn vị tính" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtDonVi" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <CheckBox x:Name="ChkActive" Content="Đang hoạt động"
                              IsChecked="True" FontSize="15" Margin="0,0,0,20"/>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                Height="38" FontSize="15" Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}"
                                Click="BtnXoa_Click"/>
                        <Button Grid.Column="2" x:Name="BtnLuu" Content="💾 Lưu"
                                Height="38" FontSize="15" FontWeight="SemiBold"
                                Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonPrimary}"
                                Click="BtnLuu_Click"/>
                    </Grid>

                </StackPanel>
            </StackPanel>
        </ContentControl>
    </Grid>
</Page>




