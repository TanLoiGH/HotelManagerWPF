<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.DanhMucTienNghiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    Title="Danh mục Tiện Nghi"
    Background="Transparent">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!--  Danh sách  -->
        <ContentControl
            Grid.Column="0"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16,12"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="TxtTong"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{DynamicResource Brush.Heading}" />
                            <Border
                                Width="220"
                                Height="34"
                                Margin="16,0,0,0"
                                Padding="10,0"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1.5"
                                CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="🔍" />
                                    <TextBox
                                        x:Name="TxtSearch"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="15"
                                        TextChanged="TxtSearch_TextChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button
                            x:Name="BtnThem"
                            Grid.Column="1"
                            Height="36"
                            Padding="16,0"
                            Click="BtnThem_Click"
                            Content="➕  Thêm"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                    </Grid>
                </Border>

                <DataGrid
                    x:Name="TnGrid"
                    Grid.Row="1"
                    Padding="8"
                    AutoGenerateColumns="False"
                    BorderThickness="1"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="44"
                    SelectionChanged="TnGrid_SelectionChanged"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding MaTienNghi}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Mã" />
                        <DataGridTextColumn
                            Width="180"
                            Binding="{Binding TenTienNghi}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Tên tiện nghi" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenNCC}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="NCC" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding HanBaoHanhText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Bảo hành" />
                        <DataGridTextColumn
                            Width="70"
                            Binding="{Binding TongSoLuong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="SL" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding DonViTinh}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Đơn vị" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding ActiveText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Active" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding SoPhong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Đã gán" />
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!--  Form  -->
        <ContentControl
            Grid.Column="2"
            Padding="20"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        x:Name="TxtFormTitle"
                        Margin="0,0,0,20"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.Heading}"
                        Text="Chi tiết tiện nghi" />

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,30,0,12"
                            HorizontalAlignment="Center"
                            FontSize="50"
                            Text="🧰" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="15"
                            Foreground="{DynamicResource Brush.TextMuted}"
                            Text="Chọn tiện nghi hoặc bấm Thêm mới"
                            TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Tên tiện nghi *" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtTen"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Nhà cung cấp" />
                        <ComboBox
                            x:Name="CboNCC"
                            Height="34"
                            Margin="0,0,0,12"
                            FontSize="15" />

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Hạn bảo hành" />
                        <DatePicker
                            x:Name="DpHanBaoHanh"
                            Height="34"
                            Margin="0,0,0,12"
                            FontSize="14" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Tổng số lượng" />
                                <Border
                                    Height="36"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1.5"
                                    CornerRadius="8">
                                    <TextBox
                                        x:Name="TxtSoLuong"
                                        Padding="10,0"
                                        VerticalAlignment="Center"
                                        BorderThickness="0"
                                        FontSize="15"
                                        Text="0"
                                        TextAlignment="Right" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Đơn vị tính" />
                                <Border
                                    Height="36"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1.5"
                                    CornerRadius="8">
                                    <TextBox
                                        x:Name="TxtDonVi"
                                        Padding="10,0"
                                        VerticalAlignment="Center"
                                        BorderThickness="0"
                                        FontSize="15" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <CheckBox
                            x:Name="ChkActive"
                            Margin="0,0,0,14"
                            Content="Hoạt động"
                            FontSize="14" />

                        <TextBlock
                            x:Name="TxtHint"
                            Margin="0,0,0,20"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            TextWrapping="Wrap" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="BtnXoa"
                                Grid.Column="0"
                                Height="38"
                                Click="BtnXoa_Click"
                                Content="🗑 Xóa"
                                Cursor="Hand"
                                FontSize="15"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
                            <Button
                                x:Name="BtnLuu"
                                Grid.Column="2"
                                Height="38"
                                Click="BtnLuu_Click"
                                Content="💾 Lưu"
                                Cursor="Hand"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Style="{DynamicResource MacFluent.ButtonPrimary}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>
    </Grid>
</Page>
