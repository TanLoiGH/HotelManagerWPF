<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DanhMucTienNghiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Danh mục Tiện Nghi">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <ContentControl Grid.Column="0"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTong" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                            <Border CornerRadius="8" Padding="10,0" Height="34"
                                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                    Margin="16,0,0,0" Width="220">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtSearch" BorderThickness="0"
                                             Background="Transparent" VerticalAlignment="Center"
                                             FontSize="15" TextChanged="TxtSearch_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="BtnThem" Content="➕  Thêm"
                                Height="36" Padding="16,0" FontSize="15"
                                FontWeight="SemiBold" Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonAction.Add}"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="TnGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="15"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="TnGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaTienNghi}" Width="90"/>
                        <DataGridTextColumn Header="Tên tiện nghi" Binding="{Binding TenTienNghi}" Width="*"/>
                        <DataGridTextColumn Header="NCC" Binding="{Binding TenNCC}" Width="140"/>
                        <DataGridTextColumn Header="Bảo hành" Binding="{Binding HanBaoHanhText}" Width="110"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding TongSoLuong}" Width="70"/>
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="90"/>
                        <DataGridTextColumn Header="Active" Binding="{Binding ActiveText}" Width="90"/>
                        <DataGridTextColumn Header="Đã gán" Binding="{Binding SoPhong}" Width="80"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!-- Form -->
        <ContentControl Grid.Column="2"
                        Background="{DynamicResource Brush.Surface}" Padding="20"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtFormTitle" Text="Chi tiết tiện nghi"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,20"/>

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock Text="🧰" FontSize="50" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                        <TextBlock Text="Chọn tiện nghi hoặc bấm Thêm mới"
                                   FontSize="15" Foreground="{DynamicResource Brush.TextMuted}"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">
                        <TextBlock Text="Tên tiện nghi *" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="15"/>
                        </Border>

                        <TextBlock Text="Nhà cung cấp" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CboNCC" Height="34" FontSize="15" Margin="0,0,0,12"/>

                        <TextBlock Text="Hạn bảo hành" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpHanBaoHanh" Height="34" FontSize="14" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tổng số lượng" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                        Height="36">
                                    <TextBox x:Name="TxtSoLuong" BorderThickness="0" Padding="10,0"
                                             VerticalAlignment="Center" FontSize="15"
                                             TextAlignment="Right" Text="0"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Đơn vị tính" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                        Height="36">
                                    <TextBox x:Name="TxtDonVi" BorderThickness="0" Padding="10,0"
                                             VerticalAlignment="Center" FontSize="15"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="ChkActive" Content="Hoạt động" FontSize="14"
                                  Margin="0,0,0,14"/>

                        <TextBlock x:Name="TxtHint" FontSize="14"
                                   Foreground="{DynamicResource Brush.TextPlaceholder}"
                                   Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                    Height="38" FontSize="15" Cursor="Hand"
                                    Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}"
                                    Click="BtnXoa_Click"/>
                            <Button Grid.Column="2" x:Name="BtnLuu" Content="💾 Lưu"
                                    Height="38" FontSize="15" FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Style="{DynamicResource MacFluent.ButtonPrimary}"
                                    Click="BtnLuu_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>
    </Grid>
</Page>
