<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Pages.CaiDatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Cài đặt hệ thống"
    d:DesignHeight="1500"
    d:DesignWidth="1200"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="Settings.FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextLabel}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="Settings.FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
        </Style>

        <Style
            x:Key="Settings.InputFrame"
            BasedOn="{StaticResource MacFluent.InputFrame}"
            TargetType="Border">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="Settings.TextBox" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>

        <Style x:Key="Settings.Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="Settings.CardHost" TargetType="ContentControl">
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="16"
                            SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="15"
                                    Opacity="0.05"
                                    ShadowDepth="1"
                                    Color="Black" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1000" Margin="40,30">

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="32"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.TextHeading}"
                    Text="Cài đặt" />
                <TextBlock
                    Margin="0,0,0,30"
                    FontSize="15"
                    Foreground="{DynamicResource Brush.TextMuted}"
                    Text="Cấu hình hệ thống, tài khoản và bảo mật" />

                <ContentControl Style="{StaticResource Settings.CardHost}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.TextHeading}"
                            Text="Giao diện" />
                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Chế độ tối (Dark Mode)" />
                            <CheckBox
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Content="Kích hoạt giao diện tối"
                                FontSize="14"
                                Foreground="{DynamicResource Brush.TextPrimary}"
                                IsChecked="{Binding IsDarkMode}" />
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <ContentControl Style="{StaticResource Settings.CardHost}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.TextHeading}"
                            Text="Thông tin khách sạn" />

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Tên khách sạn" />
                            <Border
                                Grid.Column="1"
                                MaxWidth="500"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding HotelName, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Địa chỉ" />
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding HotelAddress, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Số điện thoại" />
                            <Border
                                Grid.Column="1"
                                Width="300"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding HotelPhone, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Email liên hệ" />
                            <Border
                                Grid.Column="1"
                                Width="400"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding HotelEmail, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Separator Margin="0,10,0,20" Background="{DynamicResource Brush.Border}" />

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Quy ước giờ &amp; Thuế" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Style="{StaticResource Settings.FieldHint}"
                                    Text="Giờ nhận/trả và VAT (%)" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border
                                    Width="100"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource Settings.InputFrame}">
                                    <TextBox
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource Settings.TextBox}"
                                        Text="{Binding DefaultCheckIn}" />
                                </Border>
                                <Border
                                    Width="100"
                                    Margin="0,0,20,0"
                                    Style="{StaticResource Settings.InputFrame}">
                                    <TextBox
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource Settings.TextBox}"
                                        Text="{Binding DefaultCheckOut}" />
                                </Border>
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource Settings.FieldLabel}"
                                    Text="VAT:" />
                                <Border Width="80" Style="{StaticResource Settings.InputFrame}">
                                    <TextBox
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource Settings.TextBox}"
                                        Text="{Binding VatPercent}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                Width="120"
                                Height="40"
                                Margin="0,0,12,0"
                                Command="{Binding ReloadSystemCommand}"
                                Content="Tải lại"
                                Style="{DynamicResource MacFluent.ButtonGhost}" />
                            <Button
                                Width="160"
                                Height="40"
                                Command="{Binding SaveSystemCommand}"
                                Content="Lưu hệ thống"
                                Style="{DynamicResource MacFluent.ButtonPrimary}" />
                        </StackPanel>
                    </StackPanel>
                </ContentControl>

                <ContentControl Style="{StaticResource Settings.CardHost}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.TextHeading}"
                            Text="Thông tin nhân viên" />

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Settings.FieldHint}" Text="Mã nhân viên" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.BrandPrimary}"
                                    Text="{Binding MaNhanVien}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource Settings.FieldHint}" Text="Tên đăng nhập" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding TenDangNhap}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource Settings.FieldHint}" Text="Quyền hạn" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding Quyen}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Style="{StaticResource Settings.FieldHint}" Text="Chức vụ" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding ChucVu}" />
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,0,0,20" Background="{DynamicResource Brush.Border}" />

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Họ tên hiển thị" />
                            <Border
                                Grid.Column="1"
                                MaxWidth="450"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Số điện thoại" />
                            <Border
                                Grid.Column="1"
                                Width="250"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Email cá nhân" />
                            <Border
                                Grid.Column="1"
                                MaxWidth="450"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Địa chỉ thường trú" />
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}">
                                <TextBox Style="{StaticResource Settings.TextBox}" Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </Grid>

                        <StackPanel
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                Width="120"
                                Height="40"
                                Margin="0,0,12,0"
                                Command="{Binding CancelCommand}"
                                Content="Hoàn tác"
                                Style="{DynamicResource MacFluent.ButtonGhost}" />
                            <Button
                                Width="160"
                                Height="40"
                                Command="{Binding UpdateInfoCommand}"
                                Content="Cập nhật cá nhân"
                                Style="{DynamicResource MacFluent.ButtonPrimary}" />
                        </StackPanel>
                    </StackPanel>
                </ContentControl>

                <ContentControl Style="{StaticResource Settings.CardHost}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.TextHeading}"
                            Text="Bảo mật tài khoản" />

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Mật khẩu hiện tại" />
                            <Border
                                Grid.Column="1"
                                Width="300"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <PasswordBox
                                    VerticalAlignment="Center"
                                    helpers:PasswordBoxBinding.BindPassword="True"
                                    helpers:PasswordBoxBinding.BoundPassword="{Binding MatKhauCu, Mode=TwoWay}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="16" />
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Settings.FieldLabel}" Text="Mật khẩu mới" />
                            <Border
                                Grid.Column="1"
                                Width="300"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Settings.InputFrame}">
                                <PasswordBox
                                    VerticalAlignment="Center"
                                    helpers:PasswordBoxBinding.BindPassword="True"
                                    helpers:PasswordBoxBinding.BoundPassword="{Binding MatKhauMoi, Mode=TwoWay}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="16" />
                            </Border>
                        </Grid>

                        <Button
                            Width="160"
                            Height="40"
                            HorizontalAlignment="Right"
                            Command="{Binding ChangePasswordCommand}"
                            Content="Đổi mật khẩu"
                            Style="{DynamicResource MacFluent.ButtonPrimary}" />
                    </StackPanel>
                </ContentControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>