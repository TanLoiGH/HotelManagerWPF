<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.Pages.CaiDatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      mc:Ignorable="d"
      d:DesignHeight="1950" d:DesignWidth="1200"
      Title="CaiDatPage"
      Background="WhiteSmoke">

    <Page.Resources>
        <Style x:Key="Settings.FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextLabel}" />
        </Style>

        <Style x:Key="Settings.FieldHint" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
        </Style>

        <Style x:Key="Settings.InputFrame" TargetType="{x:Type Border}" BasedOn="{StaticResource MacFluent.InputFrame}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="Settings.TextBox" TargetType="{x:Type TextBox}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            
        </Style>

        <Style x:Key="Settings.PasswordBox" TargetType="{x:Type PasswordBox}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style x:Key="Settings.Row" TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>

        <!--
          IMPORTANT: Không đặt DropShadowEffect trực tiếp lên container có chữ.
          WPF sẽ render qua bitmap trung gian và ClearType bị tắt -> chữ nhìn "mờ".
          CardHost tách shadow sang lớp phía sau để chữ sắc nét.
        -->
        <Style x:Key="Settings.CardHost" TargetType="{x:Type ContentControl}">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContentControl}">
                        <Grid>
                            <Border CornerRadius="{StaticResource Radius.L}"
                                    Background="{DynamicResource Brush.SurfaceTranslucent}"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22" ShadowDepth="2" Opacity="0.10" Color="#000000" />
                                </Border.Effect>
                            </Border>

                            <Border CornerRadius="{StaticResource Radius.L}"
                                    Background="{DynamicResource Brush.SurfaceTranslucent}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30" Width="1000">

                <TextBlock Text="Cài đặt"
                           FontSize="{StaticResource Font.Size.Hero}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Cấu hình hệ thống, tài khoản và bảo mật"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Margin="0,0,0,20"/>

                <!-- ================= HỆ THỐNG ================= -->
                <ContentControl Style="{StaticResource Settings.CardHost}"
                                Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Hệ thống"
                                   FontSize="{StaticResource Font.Size.Subtitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Thông tin hiển thị chung và quy ước vận hành."
                                   Style="{StaticResource Settings.FieldHint}"
                                   Margin="0,0,0,14"/>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tên khách sạn" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="480">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding HotelName, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Địa chỉ" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="700">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding HotelAddress, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Số điện thoại" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="260">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding HotelPhone, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Email" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="420">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding HotelEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Separator Margin="0,0,0,16"/>

                        <TextBlock Text="Quy ước vận hành" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Giờ nhận phòng" Style="{StaticResource Settings.FieldLabel}"/>
                                <TextBlock Text="Định dạng HH:mm" Style="{StaticResource Settings.FieldHint}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="170">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding DefaultCheckIn, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Giờ trả phòng" Style="{StaticResource Settings.FieldLabel}"/>
                                <TextBlock Text="Định dạng HH:mm" Style="{StaticResource Settings.FieldHint}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="170">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding DefaultCheckOut, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="VAT" Style="{StaticResource Settings.FieldLabel}"/>
                                <TextBlock Text="0–30 (%)" Style="{StaticResource Settings.FieldHint}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="130">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding VatPercent, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Tải lại"
                                    Width="110"
                                    Margin="0,0,10,0"
                                    Command="{Binding ReloadSystemCommand}"
                                    Style="{DynamicResource MacFluent.ButtonGhost}"/>
                            <Button Content="Lưu hệ thống"
                                    Width="150"
                                    Command="{Binding SaveSystemCommand}"
                                    Style="{DynamicResource MacFluent.ButtonPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </ContentControl>

                <!-- ================= TÀI KHOẢN ================= -->
                <ContentControl Style="{StaticResource Settings.CardHost}"
                                Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Tài khoản"
                                   FontSize="{StaticResource Font.Size.Subtitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Thông tin người đang đăng nhập."
                                   Style="{StaticResource Settings.FieldHint}"
                                   Margin="0,0,0,14"/>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mã nhân viên" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding MaNhanVien}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tên đăng nhập" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TenDangNhap}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Quyền" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Quyen}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Chức vụ" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ChucVu}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Margin="0,0,0,16"/>

                        <TextBlock Text="Thông tin cá nhân" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Họ tên" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="420">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Số điện thoại" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="260">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding SoDienThoai, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Email" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="420">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Địa chỉ" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="700">
                                <TextBox Style="{StaticResource Settings.TextBox}"
                                         Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Hoàn tác"
                                    Width="110"
                                    Margin="0,0,10,0"
                                    Command="{Binding CancelCommand}"
                                    Style="{DynamicResource MacFluent.ButtonGhost}"/>
                            <Button Content="Lưu tài khoản"
                                    Width="140"
                                    Command="{Binding UpdateInfoCommand}"
                                    Style="{DynamicResource MacFluent.ButtonPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </ContentControl>

                <!-- ================= BẢO MẬT ================= -->
                <ContentControl Style="{StaticResource Settings.CardHost}">
                    <StackPanel>
                        <TextBlock Text="Bảo mật"
                                   FontSize="{StaticResource Font.Size.Subtitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Đổi mật khẩu đăng nhập."
                                   Style="{StaticResource Settings.FieldHint}"
                                   Margin="0,0,0,14"/>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mật khẩu cũ" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="260">
                                <PasswordBox Style="{StaticResource Settings.PasswordBox}"
                                             helpers:PasswordBoxBinding.BindPassword="True"
                                             helpers:PasswordBoxBinding.BoundPassword="{Binding MatKhauCu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource Settings.Row}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mật khẩu mới" Style="{StaticResource Settings.FieldLabel}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="260">
                                <PasswordBox Style="{StaticResource Settings.PasswordBox}"
                                             helpers:PasswordBoxBinding.BindPassword="True"
                                             helpers:PasswordBoxBinding.BoundPassword="{Binding MatKhauMoi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Xác nhận mật khẩu" Style="{StaticResource Settings.FieldLabel}"/>
                                <TextBlock Text="Tối thiểu 6 ký tự." Style="{StaticResource Settings.FieldHint}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource Settings.InputFrame}" Width="260">
                                <PasswordBox Style="{StaticResource Settings.PasswordBox}"
                                             helpers:PasswordBoxBinding.BindPassword="True"
                                             helpers:PasswordBoxBinding.BoundPassword="{Binding XacNhanMatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Xóa"
                                    Width="110"
                                    Margin="0,0,10,0"
                                    Command="{Binding CancelCommand}"
                                    Style="{DynamicResource MacFluent.ButtonGhost}"/>
                            <Button Content="Đổi mật khẩu"
                                    Width="140"
                                    Command="{Binding ChangePasswordCommand}"
                                    Style="{DynamicResource MacFluent.ButtonPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </ContentControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
