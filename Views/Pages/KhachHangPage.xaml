<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.KhachHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Khách Hàng">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <ContentControl Grid.Column="0"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTongKhach" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                            <Border CornerRadius="8" Padding="10,0" Height="34"
                                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                    Margin="16,0,0,0" Width="200">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtSearch" BorderThickness="0"
                                             Background="Transparent" VerticalAlignment="Center"
                                             FontSize="15" TextChanged="TxtSearch_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1" Content="➕  Thêm"
                                Height="36" Padding="16,0" FontSize="15"
                                FontWeight="SemiBold" Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonAction.Add}"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="KhachGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="15"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="KhachGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKhachHang}" Width="90"/>
                        <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding DienThoai}" Width="120"/>
                        <DataGridTextColumn Header="CCCD" Binding="{Binding Cccd}" Width="140"/>
                        <DataGridTextColumn Header="Hạng" Binding="{Binding TenLoaiKhach}" Width="100"/>
                        <DataGridTextColumn Header="Tích lũy" Binding="{Binding TichLuyText}" Width="120"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!-- Form -->
        <ContentControl Grid.Column="2"
                        Background="{DynamicResource Brush.Surface}" Padding="20"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Chi tiết khách hàng"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,20"/>

                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock Text="👥" FontSize="50" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                    <TextBlock Text="Chọn khách hàng hoặc bấm Thêm mới"
                               FontSize="15" Foreground="{DynamicResource Brush.TextMuted}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock Text="Họ tên *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <TextBlock Text="Điện thoại" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtDienThoai" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <TextBlock Text="CCCD" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtCCCD" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <TextBlock Text="Email" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtEmail" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <TextBlock Text="Địa chỉ" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Margin="0,0,0,12">
                        <TextBox x:Name="TxtDiaChi" BorderThickness="0" Padding="10,6"
                                 FontSize="15" Height="52" AcceptsReturn="True"
                                 TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Hạng khách" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboLoaiKhach" Height="34" FontSize="15"
                              Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                Height="38" FontSize="15" Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}"
                                Click="BtnXoa_Click"/>
                        <Button Grid.Column="2" Content="💾 Lưu"
                                Height="38" FontSize="15" FontWeight="SemiBold"
                                Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonPrimary}"
                                Click="BtnLuu_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ContentControl>
    </Grid>
</Page>




