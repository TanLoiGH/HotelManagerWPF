<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.LoaiChiPhiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    Title="Loại Chi Phí"
    Background="Transparent">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!--  Danh sách  -->
        <ContentControl
            Grid.Column="0"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16,12"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="TxtTong"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="{DynamicResource Brush.Heading}" />
                            <Border
                                Width="200"
                                Height="34"
                                Margin="16,0,0,0"
                                Padding="10,0"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1.5"
                                CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="🔍" />
                                    <TextBox
                                        x:Name="TxtSearch"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="15"
                                        TextChanged="TxtSearch_TextChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Height="36"
                            Padding="16,0"
                            Click="BtnThem_Click"
                            Content="➕  Thêm"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                    </Grid>
                </Border>

                <DataGrid
                    x:Name="LoaiCpGrid"
                    Grid.Row="1"
                    Padding="8"
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="44"
                    SelectionChanged="LoaiCpGrid_SelectionChanged"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding MaLoaiCp}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Mã" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenLoaiCp}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Tên loại chi phí" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding SoPhieu}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Số phiếu" />
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!--  Form  -->
        <ContentControl
            Grid.Column="2"
            Padding="20"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <StackPanel>
                <TextBlock
                    x:Name="TxtFormTitle"
                    Margin="0,0,0,20"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Heading}"
                    Text="Chi tiết loại chi phí" />

                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock
                        Margin="0,30,0,12"
                        HorizontalAlignment="Center"
                        FontSize="50"
                        Text="💸" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="Chọn loại chi phí hoặc bấm Thêm mới"
                        TextAlignment="Center" />
                </StackPanel>

                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Tên loại chi phí *" />
                    <Border
                        Height="36"
                        Margin="0,0,0,12"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1.5"
                        CornerRadius="8">
                        <TextBox
                            x:Name="TxtTen"
                            Margin="10,5"
                            Padding="10,0"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            FontSize="15" />
                    </Border>

                    <TextBlock
                        x:Name="TxtHint"
                        Margin="0,0,0,20"
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                        TextWrapping="Wrap" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="BtnXoa"
                            Grid.Column="0"
                            Height="38"
                            Click="BtnXoa_Click"
                            Content="🗑 Xóa"
                            Cursor="Hand"
                            FontSize="15"
                            Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
                        <Button
                            Grid.Column="2"
                            Height="38"
                            Click="BtnLuu_Click"
                            Content="💾 Lưu"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonPrimary}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ContentControl>
    </Grid>
</Page>
