<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.SoDoPhongPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
    Title="Quản lý Phòng"
    d:DataContext="{d:DesignInstance Type=vm:SoDoPhongViewModel}"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ContentControl
            Grid.Row="0"
            Padding="16,12"
            helpers:ThemeProperties.CornerRadius="20"
            helpers:ThemeProperties.ShadowBlurRadius="18"
            helpers:ThemeProperties.ShadowDepth="1"
            helpers:ThemeProperties.ShadowOpacity="0.08"
            Background="{DynamicResource Brush.SurfaceTranslucent}"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="FilterPanel" Orientation="Horizontal">
                    <Button
                        x:Name="BtnAll"
                        Margin="0,0,8,0"
                        BorderThickness="2"
                        Click="FilterButton_Click"
                        Command="{Binding FilterCommand}"
                        CommandParameter="all"
                        Content="Tất cả"
                        Opacity="1.0"
                        Style="{DynamicResource MacFluent.FilterButton}"
                        Tag="all" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{DynamicResource Brush.RoomAvailableSoft}"
                        BorderBrush="{DynamicResource Brush.RoomAvailable}"
                        BorderThickness="1"
                        Click="FilterButton_Click"
                        Command="{Binding FilterCommand}"
                        CommandParameter="PTT01"
                        Content="🟢 Trống"
                        Foreground="{DynamicResource Brush.RoomAvailable}"
                        Opacity="0.4"
                        Style="{DynamicResource MacFluent.FilterButton}"
                        Tag="PTT01" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{DynamicResource Brush.RoomOccupiedSoft}"
                        BorderBrush="{DynamicResource Brush.RoomOccupied}"
                        BorderThickness="1"
                        Click="FilterButton_Click"
                        Command="{Binding FilterCommand}"
                        CommandParameter="PTT02"
                        Content="🔴 Đang ở"
                        Foreground="{DynamicResource Brush.RoomOccupied}"
                        Opacity="0.4"
                        Style="{DynamicResource MacFluent.FilterButton}"
                        Tag="PTT02" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{DynamicResource Brush.RoomCleaningSoft}"
                        BorderBrush="{DynamicResource Brush.RoomCleaning}"
                        BorderThickness="1"
                        Click="FilterButton_Click"
                        Command="{Binding FilterCommand}"
                        CommandParameter="PTT03"
                        Content="🟡 Dọn dẹp"
                        Foreground="{DynamicResource Brush.RoomCleaning}"
                        Opacity="0.4"
                        Style="{DynamicResource MacFluent.FilterButton}"
                        Tag="PTT03" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{DynamicResource Brush.RoomMaintenanceSoft}"
                        BorderBrush="{DynamicResource Brush.RoomMaintenance}"
                        BorderThickness="1"
                        Click="FilterButton_Click"
                        Command="{Binding FilterCommand}"
                        CommandParameter="PTT04"
                        Content="⚪ Bảo trì"
                        Foreground="{DynamicResource Brush.RoomMaintenance}"
                        Opacity="0.4"
                        Style="{DynamicResource MacFluent.FilterButton}"
                        Tag="PTT04" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{DynamicResource Brush.RoomReservedSoft}"
                        BorderBrush="{DynamicResource Brush.RoomReserved}"
                        BorderThickness="1"
                        Click="FilterButton_Click"
                        Command="{Binding FilterCommand}"
                        CommandParameter="PTT05"
                        Content="🟣 Đã đặt"
                        Foreground="{DynamicResource Brush.RoomReserved}"
                        Opacity="0.4"
                        Style="{DynamicResource MacFluent.FilterButton}"
                        Tag="PTT05" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Width="200"
                        Height="34"
                        Padding="10,0"
                        Style="{DynamicResource MacFluent.InputFrame}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="🔍" />
                            <TextBox
                                x:Name="TxtSearch"
                                Width="150"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ContentControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <ContentControl
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,0,10,0"
                Padding="20"
                helpers:ThemeProperties.CornerRadius="16"
                Background="{DynamicResource Brush.Surface}"
                Style="{DynamicResource MacFluent.ShadowCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Name="TxtRoomCount"
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                        Text="{Binding RoomCountText}" />
                    <ScrollViewer
                        Grid.Row="1"
                        CanContentScroll="False"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Hidden">
                        <ItemsControl x:Name="PhongList" ItemsSource="{Binding FilteredRooms}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,0,12"
                                                Padding="12,8"
                                                Background="{DynamicResource Brush.SurfaceTranslucent}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock
                                                        DockPanel.Dock="Left"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource Brush.Heading}"><Run Text="Tầng " /><Run Text="{Binding Name, Mode=OneWay}" /></TextBlock>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        DockPanel.Dock="Right"
                                                        FontSize="13"
                                                        Foreground="{DynamicResource Brush.TextPlaceholder}"><Run Text="{Binding ItemCount, Mode=OneWay}" /><Run Text=" phòng" /></TextBlock>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="20,0" Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl
                                        Width="200"
                                        Height="180"
                                        helpers:ThemeProperties.ShadowBlurRadius="20"
                                        helpers:ThemeProperties.ShadowOpacity="0.3"
                                        MouseLeftButtonDown="PhongCard_Click"
                                        Tag="{Binding}">
                                        <ContentControl.Style>
                                            <Style BasedOn="{StaticResource MacFluent.RoomCard}" TargetType="ContentControl">
                                                <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
                                                <Setter Property="helpers:ThemeProperties.ShadowColor" Value="{DynamicResource Color.BrandPrimary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT01">
                                                        <Setter Property="helpers:ThemeProperties.ShadowColor" Value="{DynamicResource Color.RoomAvailable}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT02">
                                                        <Setter Property="helpers:ThemeProperties.ShadowColor" Value="{DynamicResource Color.RoomOccupied}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT03">
                                                        <Setter Property="helpers:ThemeProperties.ShadowColor" Value="{DynamicResource Color.RoomCleaning}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT04">
                                                        <Setter Property="helpers:ThemeProperties.ShadowColor" Value="{DynamicResource Color.RoomMaintenance}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT05">
                                                        <Setter Property="helpers:ThemeProperties.ShadowColor" Value="{DynamicResource Color.RoomReserved}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                        <Grid Margin="12">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem
                                                        Command="{Binding DataContext.HoanThanhDonDepCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Header="🧹 Đã dọn dẹp sạch"
                                                        Visibility="{Binding MaTrangThaiPhong, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='PTT03'}" />
                                                    <MenuItem
                                                        Command="{Binding DataContext.DoiPhongCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Header="🔀 Đổi phòng"
                                                        Visibility="{Binding MaTrangThaiPhong, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='PTT02'}" />
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    FontSize="28"
                                                    FontWeight="ExtraBold"
                                                    Foreground="{DynamicResource Brush.TextHeading}"
                                                    Text="{Binding MaPhong}" />
                                                <Border
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="0,3,0,2"
                                                    Padding="8,5"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Brush.RoomMaintenanceSoft}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT01">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.RoomAvailableSoft}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT02">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.RoomOccupiedSoft}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT03">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.RoomCleaningSoft}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT04">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.RoomMaintenanceSoft}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT05">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.RoomReservedSoft}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Text="{Binding TenTrangThai}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.RoomMaintenance}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT01">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.RoomAvailable}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT02">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.RoomOccupied}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT03">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.RoomCleaning}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT04">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.RoomMaintenance}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT05">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.RoomReserved}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <StackPanel
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,4,0,0"
                                                    Orientation="Horizontal">
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontStyle="Italic"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource Brush.TextSecondary}"
                                                        Text="{Binding CaptionText}" />
                                                </StackPanel>
                                            </Grid>
                                            <Separator
                                                Grid.Row="1"
                                                Height="1"
                                                Margin="0,5,0,70"
                                                Background="{DynamicResource Brush.Border}"
                                                Opacity="0.9" />
                                            <StackPanel
                                                Grid.Row="2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    Margin="0,20,0,2"
                                                    HorizontalAlignment="Center"
                                                    FontSize="32"
                                                    Opacity="0.4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="ℹ️" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT01">
                                                                    <Setter Property="Text" Value="✨" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT02">
                                                                    <Setter Property="Text" Value="👤" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT03">
                                                                    <Setter Property="Text" Value="🧹" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT04">
                                                                    <Setter Property="Text" Value="🛠️" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MaTrangThaiPhong}" Value="PTT05">
                                                                    <Setter Property="Text" Value="📅" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    MaxHeight="34"
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource Brush.TextMuted}"
                                                    Text="{Binding InfoText}"
                                                    TextAlignment="Center"
                                                    TextWrapping="WrapWithOverflow" />
                                            </StackPanel>
                                            <CheckBox
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Panel.ZIndex="10"
                                                IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                Visibility="{Binding MaTrangThaiPhong, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='PTT01'}" />
                                        </Grid>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </ContentControl>

            <ContentControl
                Grid.Column="2"
                helpers:ThemeProperties.CornerRadius="16"
                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}"
                Background="{DynamicResource Brush.Surface}"
                Style="{DynamicResource MacFluent.ShadowCard}">
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="20">
                        <StackPanel x:Name="PanelBooking" Visibility="{Binding IsRoomSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border
                                Margin="0,0,0,16"
                                Padding="16"
                                CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource Brush.BrandPrimary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedRoom.MaTrangThaiPhong}" Value="PTT01">
                                                <Setter Property="Background" Value="{DynamicResource Brush.RoomAvailable}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedRoom.MaTrangThaiPhong}" Value="PTT02">
                                                <Setter Property="Background" Value="{DynamicResource Brush.RoomOccupied}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedRoom.MaTrangThaiPhong}" Value="PTT03">
                                                <Setter Property="Background" Value="{DynamicResource Brush.RoomCleaning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedRoom.MaTrangThaiPhong}" Value="PTT04">
                                                <Setter Property="Background" Value="{DynamicResource Brush.RoomMaintenance}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedRoom.MaTrangThaiPhong}" Value="PTT05">
                                                <Setter Property="Background" Value="{DynamicResource Brush.RoomReserved}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Brush.BrandPrimary}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Opacity="0.8"
                                        Text="{Binding SelectionTitle}" />
                                    <TextBlock
                                        FontSize="30"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding SelectedRoom.MaPhong}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ItemsControl
                                        Margin="0,8,0,0"
                                        ItemsSource="{Binding SelectedRooms}"
                                        Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,4,4"
                                                    Padding="6,2"
                                                    Background="White"
                                                    CornerRadius="6">
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                                        Text="{Binding MaPhong}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <StackPanel Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                                        Text="Sức chứa" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Brush.TextHeading}"
                                        Text="{Binding SelectedRoom.SoNguoiToiDa, StringFormat='{}{0} người'}" />
                                </Grid>
                                <Separator Margin="0,0,0,8" Background="{DynamicResource Brush.Border}" />
                                <Grid Margin="0,0,0,12">
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                                        Text="Giá/đêm" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                        Text="{Binding SelectedRoom.GiaPhongText}" />
                                </Grid>

                                <TextBlock
                                    Margin="0,8,0,8"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextHeading}"
                                    Text="Tiện nghi" />
                                <ItemsControl ItemsSource="{Binding RoomAmenities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,0,4"
                                                Padding="8,4"
                                                Background="{DynamicResource Brush.SurfaceSoft}"
                                                CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                                        Text="✓ " />
                                                    <TextBlock
                                                        FontSize="14"
                                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                                        Text="{Binding TenTienNghi}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock
                                    Margin="0,0,0,12"
                                    FontSize="14"
                                    Foreground="{DynamicResource Brush.TextDisabled}"
                                    Text="Chưa có tiện nghi"
                                    Visibility="{Binding RoomAmenities.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=0}" />
                            </StackPanel>

                            <Border
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource Brush.SurfaceSoft}"
                                CornerRadius="10"
                                Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    FontSize="13"
                                    FontStyle="Italic"
                                    Foreground="{DynamicResource Brush.TextMuted}"
                                    Text="💡 Bạn đang thực hiện đặt phòng nhanh cho một nhóm. Các phòng này sẽ có chung thông tin khách hàng và thời gian lưu trú."
                                    TextWrapping="Wrap" />
                            </Border>

                            <Separator Margin="0,4,0,16" Background="{DynamicResource Brush.Border}" />

                            <StackPanel
                                x:Name="PanelDaDatTruoc"
                                Margin="0,0,0,12"
                                Visibility="{Binding IsRoomReserved, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    Margin="0,0,0,14"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.Heading}"
                                    Text="📋  Thông tin đặt trước" />
                                <Grid Margin="0,0,0,8">
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                                        Text="Khách hàng" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Brush.Heading}"
                                        Text="{Binding ReservedGuestName}" />
                                </Grid>
                                <Separator Margin="0,0,0,8" Background="{DynamicResource Brush.Border}" />
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngày nhận" />
                                    <TextBlock HorizontalAlignment="Right" Text="{Binding ReservedNgayNhan}" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngày trả" />
                                    <TextBlock HorizontalAlignment="Right" Text="{Binding ReservedNgayTra}" />
                                </Grid>
                                <Separator Margin="0,0,0,8" Background="{DynamicResource Brush.Border}" />
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Tiền đặt cọc" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                        Text="{Binding ReservedTienCoc}" />
                                </Grid>
                                <Button Command="{Binding CheckInRiengLeCommand}" Style="{DynamicResource MacFluent.ButtonPrimary}">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="#FFF"
                                        Text="✅  Khách đã nhận phòng" />
                                </Button>
                                <Button
                                    Margin="10,18,10,0"
                                    Command="{Binding HuyPhongRiengLeCommand}"
                                    Style="{DynamicResource MacFluent.ButtonSecondary}">
                                    <TextBlock
                                        Foreground="#FF8C00"
                                        Text="✂️ Hủy riêng phòng này"
                                        TextWrapping="Wrap" />
                                </Button>
                                <Button
                                    Margin="30,18,30,0"
                                    Command="{Binding HuyDatPhongCommand}"
                                    Style="{DynamicResource MacFluent.ButtonSecondary}">
                                    <TextBlock Foreground="{DynamicResource Brush.Error}" Text="❌ Hủy TOÀN BỘ đoàn" />
                                </Button>
                            </StackPanel>

                            <StackPanel x:Name="PanelDatPhong" Visibility="{Binding IsRoomAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    Margin="0,0,0,14"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.Heading}"
                                    Text="📅  Đặt phòng" />
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Search" />
                                <Border
                                    Height="36"
                                    Margin="0,0,0,4"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1.5"
                                    CornerRadius="8">
                                    <TextBox
                                        Padding="10,0"
                                        VerticalAlignment="Center"
                                        BorderThickness="0"
                                        FontSize="15"
                                        Text="{Binding KhachHangSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>
                                <ListBox
                                    MaxHeight="100"
                                    Margin="0,0,0,4"
                                    DisplayMemberPath="TenKhachHang"
                                    ItemsSource="{Binding KhachHangResults}"
                                    SelectedItem="{Binding SelectedKhach}"
                                    Visibility="{Binding IsSearchOpen, Converter={StaticResource StringToVisibilityConverter}}" />
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{DynamicResource Brush.BrandPrimary}"
                                    Text="{Binding SelectedKhach.TenKhachHang}"
                                    Visibility="{Binding SelectedKhach, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Border
                                    Margin="0,4,0,0"
                                    Padding="8,2"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource Brush.SurfaceSoft}"
                                    CornerRadius="4"
                                    Visibility="{Binding CoHangKhachHang, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⭐ Hạng: " />
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Foreground="#35AF13"
                                            Text="{Binding LoaiKhachHienThi}" />
                                    </StackPanel>
                                </Border>
                                <Expander
                                    Margin="0,0,0,10"
                                    Header="{Binding ThongTinKhachHeader}"
                                    IsExpanded="{Binding IsKhachExpanded}">
                                    <StackPanel Margin="0,8,0,0">
                                        <Border
                                            Margin="0,0,0,12"
                                            Padding="10"
                                            Background="{DynamicResource Brush.SurfaceTranslucent}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Visibility="{Binding IsKhachMoi, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock FontSize="13"><Run Foreground="{DynamicResource Brush.TextLabel}" Text="🏷️ Phân loại:" /><Run
                                                    FontWeight="Bold"
                                                    Foreground="Gray"
                                                    Text=" Khách mới (Hạng mặc định)" /></TextBlock>
                                        </Border>
                                        <TextBlock Text="Quốc tịch" />
                                        <Border Style="{DynamicResource MacFluent.InputFrame}">
                                            <TextBox Text="{Binding NewKhachQuocTich, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <TextBlock Text="Họ và tên" />
                                        <Border Style="{DynamicResource MacFluent.InputFrame}">
                                            <TextBox Text="{Binding NewKhachHoTen, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <TextBlock Text="Số điện thoại" />
                                        <Border Style="{DynamicResource MacFluent.InputFrame}">
                                            <TextBox Text="{Binding NewKhachSdt, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <TextBlock Text="Địa chỉ" />
                                        <Border Style="{DynamicResource MacFluent.InputFrame}">
                                            <TextBox Text="{Binding NewKhachDiaChi, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <StackPanel Visibility="{Binding IsKhachTrongNuoc, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="CCCD" />
                                            <Border Style="{DynamicResource MacFluent.InputFrame}">
                                                <TextBox Text="{Binding NewKhachCccd, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Visibility="{Binding IsKhachNuocNgoai, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Passport" />
                                            <Border Style="{DynamicResource MacFluent.InputFrame}">
                                                <TextBox Text="{Binding NewKhachPassport, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                            <TextBlock Text="Visa" />
                                            <Border Style="{DynamicResource MacFluent.InputFrame}">
                                                <TextBox Text="{Binding NewKhachVisa, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ngày nhận" />
                                        <DatePicker SelectedDate="{Binding NgayNhan}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ngày trả" />
                                        <DatePicker SelectedDate="{Binding NgayTra}" />
                                    </StackPanel>
                                </Grid>
                                <Border Background="{DynamicResource Brush.WarningSurface}" CornerRadius="8">
                                    <TextBlock
                                        Padding="12,8"
                                        Foreground="{DynamicResource Brush.WarningText}"
                                        Text="Khuyến mãi sẽ được chọn khi xuất hóa đơn." />
                                </Border>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Tiền cọc trước (VNĐ):" />
                                    <TextBox
                                        Height="35"
                                        FontSize="14"
                                        Text="{Binding TienCoc, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" />
                                </StackPanel>
                                <Border
                                    Margin="0,14"
                                    Background="{DynamicResource Brush.SurfaceSoft}"
                                    CornerRadius="8">

                                    <TextBlock
                                        Padding="12,8"
                                        Text="{Binding TotalPriceText, StringFormat='{}Tổng tiền tạm tính: {0}'}"
                                        TextWrapping="WrapWithOverflow" />
                                </Border>
                                <Button
                                    Command="{Binding DatPhongCommand}"
                                    Content="📅 Xác nhận đặt phòng"
                                    Style="{DynamicResource MacFluent.ButtonPrimary}" />
                            </StackPanel>

                            <StackPanel x:Name="PanelKhongTrong" Visibility="{Binding IsRoomOccupied, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="14,10"
                                    Background="{DynamicResource Brush.WarningSurface}"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="15"
                                        Foreground="{DynamicResource Brush.WarningText}"
                                        Text="{Binding SelectedRoom.TenTrangThai, StringFormat='Trạng thái: {0}'}"
                                        TextAlignment="Center" />
                                </Border>
                                <Button
                                    Height="44"
                                    Command="{Binding DoiPhongCommand}"
                                    Cursor="Hand"
                                    Visibility="{Binding SelectedRoom.MaTrangThaiPhong, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='PTT02'}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8" />
                                        </Style>
                                    </Button.Resources>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                        Text="🔀  Chuyển sang phòng khác" />
                                </Button>
                                <Button
                                    Margin="0,8,0,0"
                                    Command="{Binding HoanThanhDonDepCommand}"
                                    Style="{DynamicResource MacFluent.ButtonPrimary}"
                                    Visibility="{Binding SelectedRoom.MaTrangThaiPhong, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='PTT03'}">
                                    <TextBlock Foreground="White" Text="🧹  Đã dọn dẹp sạch" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </ContentControl>
        </Grid>
    </Grid>
</Page>
