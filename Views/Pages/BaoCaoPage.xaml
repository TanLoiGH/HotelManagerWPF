<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.BaoCaoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
    Title="Báo cáo hệ thống"
    d:DataContext="{d:DesignInstance Type=vm:BaoCaoPageViewModel}"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="20,16"
            Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="12"
                    Opacity="0.06"
                    ShadowDepth="1"
                    Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock
                        Margin="2,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Nguồn dữ liệu" />
                    <Border
                        Height="38"
                        Padding="1"
                        CornerRadius="0"
                        Style="{DynamicResource MacFluent.InputFrame}">
                        <ComboBox
                            x:Name="CboSource"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            SelectedIndex="{Binding SelectedSourceIndex}">
                            <ComboBoxItem Content="View (Dữ liệu tĩnh)" />
                            <ComboBoxItem Content="Stored Procedure (Lọc ngày)" />
                        </ComboBox>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock
                        Margin="2,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Tên báo cáo" />
                    <Border
                        Height="38"
                        Padding="1"
                        CornerRadius="0"
                        Style="{DynamicResource MacFluent.InputFrame}">
                        <ComboBox
                            x:Name="CboProcName"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            DisplayMemberPath="DisplayName"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            ItemsSource="{Binding AvailableReports}"
                            SelectedItem="{Binding SelectedReport}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock
                        Margin="2,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Từ ngày" />
                    <Border
                        Height="38"
                        CornerRadius="0"
                        Style="{DynamicResource MacFluent.InputFrame}">
                        <DatePicker
                            x:Name="DpFrom"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            BorderThickness="0"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            IsEnabled="{Binding IsDateFilterEnabled}"
                            SelectedDate="{Binding TuNgay}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,16,0">
                    <TextBlock
                        Margin="2,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Đến ngày" />
                    <Border
                        Height="38"
                        CornerRadius="0"
                        Style="{DynamicResource MacFluent.InputFrame}">
                        <DatePicker
                            x:Name="DpTo"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            BorderThickness="0"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            IsEnabled="{Binding IsDateFilterEnabled}"
                            SelectedDate="{Binding DenNgay}" />
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Height="38"
                        Margin="0,0,10,0"
                        Command="{Binding RunReportCommand}"
                        Content="Chạy"
                        IsDefault="True"
                        Style="{DynamicResource MacFluent.ButtonPrimary}" />
                    <Button
                        Width="150"
                        Height="38"
                        Command="{Binding ExportCsvCommand}"
                        Content="📊 Xuất Excel/CSV"
                        Style="{DynamicResource MacFluent.ButtonSecondary}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="16">
            <Grid>
                <DataGrid
                    x:Name="GridProc"
                    AutoGenerateColumns="True"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                    IsReadOnly="True"
                    ItemsSource="{Binding ReportData}"
                    RowHeight="42"
                    Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="45"
                        Text="⚙️">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="0" CenterX="22.5" CenterY="22.5" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                            From="0"
                                            To="360"
                                            Duration="0:0:2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock
                        Margin="0,15,0,0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="Đang tổng hợp dữ liệu báo cáo..." />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding NoData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="60"
                        Opacity="0.5"
                        Text="📊" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="Chưa có dữ liệu hiển thị" />
                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextSubtle}"
                        Text="Vui lòng chọn báo cáo và nhấn 'Chạy' để xem kết quả." />
                </StackPanel>

                <StackPanel
                    MaxWidth="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="50"
                        Text="❌" />
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.Error}"
                        Text="Lỗi trích xuất báo cáo" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextSecondary}"
                        Text="{Binding ErrorMessage}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>