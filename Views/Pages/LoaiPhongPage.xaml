<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.LoaiPhongPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    Title="Loại Phòng"
    Background="Transparent">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!--  Danh sách  -->
        <ContentControl
            Grid.Column="0"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16,12"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="TxtTong"
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}" />
                        <Button
                            Grid.Column="1"
                            Height="36"
                            Padding="16,0"
                            Click="BtnThem_Click"
                            Content="➕  Thêm"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                    </Grid>
                </Border>

                <DataGrid
                    x:Name="LpGrid"
                    Grid.Row="1"
                    Padding="8"
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="44"
                    SelectionChanged="LpGrid_SelectionChanged"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding MaLoaiPhong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Mã" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenLoaiPhong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Tên loại phòng" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding SoNguoiText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Sức chứa" />
                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding GiaPhongText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Giá/đêm" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding SoPhong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Số phòng" />
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </ContentControl>

        <!--  Form  -->
        <ContentControl
            Grid.Column="2"
            Padding="20"
            helpers:ThemeProperties.CornerRadius="16"
            Background="{DynamicResource Brush.Surface}"
            BorderThickness="0"
            Style="{DynamicResource MacFluent.ShadowCard}">
            <StackPanel>
                <TextBlock
                    x:Name="TxtFormTitle"
                    Margin="0,0,0,20"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Heading}"
                    Text="Chi tiết loại phòng" />

                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock
                        Margin="0,30,0,12"
                        HorizontalAlignment="Center"
                        FontSize="50"
                        Text="🏠" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="Chọn loại phòng hoặc bấm Thêm mới"
                        TextAlignment="Center" />
                </StackPanel>

                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Tên loại phòng *" />
                    <Border
                        Height="36"
                        Margin="0,0,0,12"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1.5"
                        CornerRadius="8">
                        <TextBox
                            x:Name="TxtTen"
                            Margin="10,0"
                            Padding="10,0"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            FontSize="15" />
                    </Border>

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Sức chứa (người)" />
                    <Border
                        Height="36"
                        Margin="0,0,0,12"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1.5"
                        CornerRadius="8">
                        <TextBox
                            x:Name="TxtSoNguoi"
                            Margin="10,0"
                            Padding="10,0"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            FontSize="15"
                            Text="2"
                            TextAlignment="Right" />
                    </Border>

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Giá/đêm (₫) *" />
                    <Border
                        Height="36"
                        Margin="0,0,0,20"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1.5"
                        CornerRadius="8">
                        <TextBox
                            x:Name="TxtGia"
                            Margin="10,0"
                            Padding="10,0"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            FontSize="15"
                            TextAlignment="Right" />
                    </Border>

                    <!--  Danh sách phòng thuộc loại này  -->
                    <TextBlock
                        x:Name="TxtPhongList"
                        Margin="0,0,0,20"
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                        TextWrapping="Wrap" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="BtnXoa"
                            Grid.Column="0"
                            Click="BtnXoa_Click"
                            Content="🗑 Xóa"
                            Cursor="Hand"
                            FontSize="15"
                            Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
                        <Button
                            Grid.Column="2"
                            Click="BtnLuu_Click"
                            Content="💾 Lưu"
                            Cursor="Hand"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{DynamicResource MacFluent.ButtonPrimary}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ContentControl>
    </Grid>
</Page>




