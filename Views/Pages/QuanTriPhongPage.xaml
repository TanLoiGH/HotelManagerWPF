<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.QuanTriPhongPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Pages"
    Title="Quản trị phòng"
    Background="Transparent">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>

        <!--  Danh sách phòng  -->
        <Border
            Grid.Column="0"
            Padding="14"
            Background="{DynamicResource Brush.Surface}"
            CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            x:Name="TxtTong"
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}" />
                        <Border
                            Width="220"
                            Height="34"
                            Margin="16,0,0,0"
                            Padding="10,0"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="🔍" />
                                <TextBox
                                    x:Name="TxtSearch"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="15"
                                    TextChanged="TxtSearch_TextChanged" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        Height="34"
                        Padding="16,0"
                        Click="BtnThem_Click"
                        Content="➕  Thêm"
                        Cursor="Hand"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                </Grid>

                <DataGrid
                    x:Name="PhongGrid"
                    Grid.Row="2"
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    FontSize="14"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="40"
                    SelectionChanged="PhongGrid_SelectionChanged"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding MaPhong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Mã phòng" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenLoaiPhong}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Loại phòng" />
                        <DataGridTextColumn
                            Width="160"
                            Binding="{Binding TenTrangThai}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Trạng thái" />
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding UsedText}"
                            ElementStyle="{StaticResource CenterCell}"
                            Header="Tiện nghi" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!--  Splitter kéo  -->
        <GridSplitter
            Grid.Column="1"
            Width="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource Brush.OverlayBlack13}"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Columns"
            ShowsPreview="True" />

        <!--  Form  -->
        <Border
            Grid.Column="2"
            Padding="16"
            Background="{DynamicResource Brush.Surface}"
            CornerRadius="12">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        x:Name="TxtFormTitle"
                        Margin="0,0,0,14"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.Heading}"
                        Text="Chi tiết phòng" />

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,24,0,10"
                            HorizontalAlignment="Center"
                            FontSize="54"
                            Text="🏠" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextMuted}"
                            Text="Chọn phòng hoặc bấm Thêm mới"
                            TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Mã phòng *" />
                        <Border
                            Height="36"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1.5"
                            CornerRadius="8">
                            <TextBox
                                x:Name="TxtMaPhong"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                FontSize="15" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Loại phòng *" />
                        <ComboBox
                            x:Name="CboLoaiPhong"
                            Height="34"
                            Margin="0,0,0,12"
                            FontSize="15" />

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Trạng thái *" />
                        <ComboBox
                            x:Name="CboTrangThai"
                            Height="34"
                            Margin="0,0,0,12"
                            FontSize="15" />

                        <TextBlock
                            x:Name="TxtHint"
                            Margin="0,0,0,16"
                            FontSize="13"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            TextWrapping="Wrap" />


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                x:Name="BtnXoa"
                                Grid.Column="0"
                                Click="BtnXoa_Click"
                                Content="🗑 Xóa"
                                Cursor="Hand"
                                FontSize="15"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
                            <Button
                                x:Name="BtnLuu"
                                Grid.Column="2"
                                Click="BtnLuu_Click"
                                Content="💾 Lưu"
                                Cursor="Hand"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Style="{DynamicResource MacFluent.ButtonPrimary}" />
                        </Grid>

                        <!--  Tiện nghi theo phòng  -->
                        <StackPanel x:Name="PanelTienNghi" Visibility="Collapsed">
                            <Separator Margin="0,4,0,12" Background="{DynamicResource Brush.Border}" />
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.Heading}"
                                Text="🧰  Tiện nghi theo phòng" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="BtnChonTienNghi"
                                    Grid.Column="0"
                                    Height="34"
                                    Padding="14,0"
                                    Click="BtnChonTienNghi_Click"
                                    Content="➕  Chọn/Gỡ tiện nghi"
                                    Cursor="Hand"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                            </Grid>

                            <DataGrid
                                x:Name="TienNghiGrid"
                                MaxHeight="220"
                                AutoGenerateColumns="False"
                                BorderThickness="0"
                                CanUserAddRows="False"
                                ColumnWidth="SizeToCells"
                                FontSize="14"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                MinColumnWidth="120"
                                RowHeight="40"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="180"
                                        Binding="{Binding TenTienNghi}"
                                        ElementStyle="{StaticResource LeftCell}"
                                        Header="Tiện nghi" />
                                    <DataGridComboBoxColumn
                                        Width="120"
                                        DisplayMemberPath="TenTrangThai"
                                        ElementStyle="{StaticResource CenterComboBoxCell}"
                                        Header="Trạng thái"
                                        SelectedValueBinding="{Binding MaTrangThai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="MaTrangThai" />
                                    <DataGridTemplateColumn Width="26" Header="Thao tác">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Width="60"
                                                    Height="30"
                                                    Margin="1"
                                                    Padding="0,0,5,0"
                                                    HorizontalAlignment="Center"
                                                    Click="BtnGoTienNghi_Click"
                                                    Cursor="Hand"
                                                    Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}">
                                                    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=ActualWidth}">
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Text="Gỡ" />
                                                    </Grid>
                                                </Button>



                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
