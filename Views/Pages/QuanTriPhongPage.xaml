<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.QuanTriPhongPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Pages"
        Title="Quản trị phòng"
         Background="Transparent">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách phòng -->
        <Border Grid.Column="0" CornerRadius="12" Padding="14"
                Background="{DynamicResource Brush.Surface}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtTong" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Padding="10,0" Height="34"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                Margin="16,0,0,0" Width="220">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="TxtSearch" BorderThickness="0"
                                         Background="Transparent" VerticalAlignment="Center"
                                         FontSize="15" TextChanged="TxtSearch_TextChanged"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1" Content="➕  Thêm"
                            Height="34" Padding="16,0" FontSize="14"
                            FontWeight="SemiBold" Cursor="Hand"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}"
                            Click="BtnThem_Click"/>
                </Grid>

                <DataGrid x:Name="PhongGrid" Grid.Row="2"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="14"
                          BorderThickness="0" RowHeight="40"
                          SelectionChanged="PhongGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã phòng" Binding="{Binding MaPhong}" Width="110"/>
                        <DataGridTextColumn Header="Loại phòng" Binding="{Binding TenLoaiPhong}" Width="*"/>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TenTrangThai}" Width="160"/>
                        <DataGridTextColumn Header="Tiện nghi" Binding="{Binding UsedText}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Splitter kéo -->
        <GridSplitter Grid.Column="1"
                  Width="6"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="{DynamicResource Brush.OverlayBlack13}"
                  ResizeBehavior="PreviousAndNext"
                  ResizeDirection="Columns"
                  ShowsPreview="True"/>

        <!-- Form -->
        <Border Grid.Column="2" CornerRadius="12" Padding="16"
                Background="{DynamicResource Brush.Surface}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="TxtFormTitle" Text="Chi tiết phòng"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,14"/>

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="54" HorizontalAlignment="Center" Margin="0,24,0,10"/>
                        <TextBlock Text="Chọn phòng hoặc bấm Thêm mới"
                               FontSize="14" Foreground="{DynamicResource Brush.TextMuted}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">
                        <TextBlock Text="Mã phòng *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtMaPhong" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                        </Border>

                        <TextBlock Text="Loại phòng *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CboLoaiPhong" Height="34" FontSize="15" Margin="0,0,0,12"/>

                        <TextBlock Text="Trạng thái *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CboTrangThai" Height="34" FontSize="15" Margin="0,0,0,12"/>

                        <TextBlock x:Name="TxtHint" FontSize="13"
                               Foreground="{DynamicResource Brush.TextPlaceholder}"
                               Margin="0,0,0,16" TextWrapping="Wrap"/>


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                Height="38" FontSize="15" Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}"
                                Click="BtnXoa_Click"/>
                            <Button Grid.Column="2" x:Name="BtnLuu" Content="💾 Lưu"
                                Height="38" FontSize="15" FontWeight="SemiBold"
                                Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonPrimary}"
                                Click="BtnLuu_Click"/>
                        </Grid>

                        <!-- Tiện nghi theo phòng -->
                        <StackPanel x:Name="PanelTienNghi" Visibility="Collapsed">
                            <Separator Background="{DynamicResource Brush.Border}" Margin="0,4,0,12"/>
                            <TextBlock Text="🧰  Tiện nghi theo phòng" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="BtnChonTienNghi" Content="➕  Chọn/Gỡ tiện nghi"
                                            Height="34" Padding="14,0" FontSize="14"
                                            FontWeight="SemiBold" Cursor="Hand"
                                            Style="{DynamicResource MacFluent.ButtonAction.Add}"
                                            Click="BtnChonTienNghi_Click"/>
                            </Grid>

                            <DataGrid x:Name="TienNghiGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  FontSize="14"
                  BorderThickness="0"
                  RowHeight="40"
                  MaxHeight="220"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ColumnWidth="SizeToCells"
                  MinColumnWidth="120">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tiện nghi" Binding="{Binding TenTienNghi}" Width="220"/>
                                    <DataGridComboBoxColumn Header="Trạng thái"
                                        SelectedValueBinding="{Binding MaTrangThai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="MaTrangThai"
                                        DisplayMemberPath="TenTrangThai"
                                        Width="160"/>
                                    <DataGridTemplateColumn Header="" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button HorizontalContentAlignment="Left"
                                                        Padding="3"
                                                        Cursor="Hand"
                                                        Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}"
                                                        Click="BtnGoTienNghi_Click">
                                                    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=ActualWidth}">
                                                        <TextBlock Text="Gỡ"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Button>



                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
