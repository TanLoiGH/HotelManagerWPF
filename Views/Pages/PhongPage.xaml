<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.PhongPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Quản lý Phòng">



    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ContentControl Grid.Row="0"
                        Background="{DynamicResource Brush.SurfaceTranslucent}"
                        Padding="16,12"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="20"
                        helpers:ThemeProperties.ShadowBlurRadius="18"
                        helpers:ThemeProperties.ShadowDepth="1"
                        helpers:ThemeProperties.ShadowOpacity="0.08">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAll" Content="Tất cả" Tag="all"
                            Command="{Binding FilterCommand}" CommandParameter="all" Margin="0,0,8,0"
                            Style="{DynamicResource MacFluent.FilterButton.Active}"/>
                    <Button Content="🟢 Trống" Tag="PTT01"
                            Command="{Binding FilterCommand}" CommandParameter="PTT01" Margin="0,0,8,0"
                            Background="{DynamicResource Brush.RoomAvailableSoft}"
                            Foreground="{DynamicResource Brush.RoomAvailable}"
                            BorderBrush="{DynamicResource Brush.RoomAvailable}"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="🔴 Đang ở" Tag="PTT02"
                            Command="{Binding FilterCommand}" CommandParameter="PTT02" Margin="0,0,8,0"
                            Background="{DynamicResource Brush.RoomOccupiedSoft}"
                            Foreground="{DynamicResource Brush.RoomOccupied}"
                            BorderBrush="{DynamicResource Brush.RoomOccupied}"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="🟡 Dọn dẹp" Tag="PTT03"
                            Command="{Binding FilterCommand}" CommandParameter="PTT03" Margin="0,0,8,0"
                            Background="{DynamicResource Brush.RoomCleaningSoft}"
                            Foreground="{DynamicResource Brush.RoomCleaning}"
                            BorderBrush="{DynamicResource Brush.RoomCleaning}"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="⚪ Bảo trì" Tag="PTT04"
                            Command="{Binding FilterCommand}" CommandParameter="PTT04" Margin="0,0,8,0"
                            Background="{DynamicResource Brush.RoomMaintenanceSoft}"
                            Foreground="{DynamicResource Brush.RoomMaintenance}"
                            BorderBrush="{DynamicResource Brush.RoomMaintenance}"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="🟣 Đã đặt" Tag="PTT05"
                            Command="{Binding FilterCommand}" CommandParameter="PTT05"
                            Background="{DynamicResource Brush.RoomReservedSoft}"
                            Foreground="{DynamicResource Brush.RoomReserved}"
                            BorderBrush="{DynamicResource Brush.RoomReserved}"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <Border Height="34" Width="200" Padding="10,0"
                            Style="{DynamicResource MacFluent.InputFrame}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="TxtSearch" BorderThickness="0"
                                     Background="Transparent" VerticalAlignment="Center"
                                     FontSize="15" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ContentControl>

        <!-- Main layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Room cards -->
            <ContentControl Grid.Column="0"
                            Background="{DynamicResource Brush.Surface}" Padding="20"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="16"
                            helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}" Grid.ColumnSpan="2" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtRoomCount" Grid.Row="0"
                               Text="{Binding RoomCountText}"
                               FontSize="15" Foreground="{DynamicResource Brush.TextPlaceholder}" Margin="0,0,0,12"/>
                    
                    <!-- List Room (grouped by floor) -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <ItemsControl x:Name="PhongList" ItemsSource="{Binding FilteredRooms}">
                            
                            <!-- Group Style: Header cho mỗi tầng -->
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <!-- Tầng + Tổng phòng-->
                                            <Border Background="{DynamicResource Brush.SurfaceTranslucent}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="12,8"
                                                    Margin="0,0,0,12">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource Brush.Heading}">
                                                <Run Text="Tầng "/>
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock DockPanel.Dock="Right"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                               VerticalAlignment="Center">
                                                        <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                        <Run Text=" phòng"/>
                                                    </TextBlock>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                    <GroupStyle.Panel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </GroupStyle.Panel>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>

                            <!-- Panel Layout: WrapPanel để tự động xuống hàng -->
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="20,0" Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <!--Phòng Card-->
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl 
                                        Background="{Binding CardBackground}"
                                        MouseLeftButtonDown="PhongCard_Click" Tag="{Binding}"
                                        Style="{DynamicResource MacFluent.RoomCard}"
                                        Width="200"
                                        Height="180"
                                        helpers:ThemeProperties.ShadowColor="{Binding ShadowColor}"
                                        helpers:ThemeProperties.ShadowOpacity="0.3"
                                        helpers:ThemeProperties.ShadowBlurRadius="20">
                                        <Grid Margin="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Mã phòng -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding MaPhong}"
                                                           FontSize="28"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{DynamicResource Brush.TextHeading}"/>

                                                <!-- Badge trạng thái -->
                                                <Border Grid.Row="0" Grid.Column="1"
                                                        CornerRadius="10"
                                                        Margin="0,3,0,2"
                                                        Padding="8,5"
                                                        Background="{Binding BadgeBackground}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TenTrangThai}"
                                                               FontSize="13"
                                                               FontWeight="Bold" 
                                                               Foreground="{Binding BadgeForeground}"/>
                                                </Border>

                                                <!-- Thông tin phòng -->
                                                <StackPanel Grid.Row="1"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="2"
                                                            Orientation="Horizontal"
                                                            Margin="0,4,0,0">

                                                    <TextBlock Text="{Binding CaptionText}"
                                                               FontSize="13" 
                                                               FontStyle="Italic"  FontWeight="Bold"
                                                               Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Separator Grid.Row="1" Background="{DynamicResource Brush.Border}" 
                                                       Margin="0,5,0,70" Height="1" Opacity="0.9"/>

                                            <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StatusIcon}" 
                                                           FontSize="32" HorizontalAlignment="Center" Margin="0,20,0,2"
                                                           Opacity="0.4"/>
                                                <TextBlock Text="{Binding InfoText}"
                                                           FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Brush.TextMuted}"
                                                           HorizontalAlignment="Center" TextAlignment="Center"
                                                           TextWrapping="WrapWithOverflow" MaxHeight="34"/>
                                            </StackPanel>
                                        </Grid>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                    </ScrollViewer>
                </Grid>
            </ContentControl>

            <!-- Right panel: Chi tiết + Form đặt phòng -->
            <ContentControl Grid.Column="2"
                            Background="{DynamicResource Brush.Surface}"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="16"
                            helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}">

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="20">

                        <!-- PanelDetail (Empty state - Hiển thị khi chưa chọn phòng) -->
                        <StackPanel x:Name="PanelDetail" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsRoomSelected, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                            <TextBlock Text="🏠" FontSize="50" HorizontalAlignment="Center" Margin="0,40,0,12"/>
                            <TextBlock Text="Chọn một phòng để xem chi tiết và đặt phòng"
                                       FontSize="15" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- PanelBooking (Form & Details - Hiển thị khi đã chọn phòng) -->
                        <StackPanel x:Name="PanelBooking" Visibility="{Binding IsRoomSelected, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <!-- DetailHeader -->
                            <Border x:Name="DetailHeader" CornerRadius="12" Padding="16" Margin="0,0,0,16"
                                    Background="{Binding SelectedRoom.BadgeForeground}">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedRoom.MaPhong}" FontSize="30"
                                                   FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding SelectedRoom.TenLoaiPhong}" FontSize="15" Foreground="White" Opacity="0.9"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="8" Padding="8,4" Background="{DynamicResource Brush.OverlayWhite20}">
                                        <TextBlock Text="{Binding SelectedRoom.TenTrangThai}" FontSize="13"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Thông tin phòng -->
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Sức chứa" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                <TextBlock Text="{Binding SelectedRoom.SoNguoiToiDa, StringFormat='{}{0} người'}" HorizontalAlignment="Right"
                                           FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextHeading}"/>
                            </Grid>
                            <Separator Background="{DynamicResource Brush.Border}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Giá/đêm" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                <TextBlock Text="{Binding SelectedRoom.GiaPhongText}" HorizontalAlignment="Right"
                                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.BrandPrimary}"/>
                            </Grid>

                            <!-- Tiện nghi -->
                            <TextBlock Text="Tiện nghi" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextHeading}" Margin="0,8,0,8"/>
                            <ItemsControl ItemsSource="{Binding RoomAmenities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,0,4"
                                                Background="{DynamicResource Brush.SurfaceSoft}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="{DynamicResource Brush.BrandPrimary}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding TenTienNghi}" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Chưa có tiện nghi"
                                       Visibility="{Binding RoomAmenities.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=0}"
                                       FontSize="14" Foreground="{DynamicResource Brush.TextDisabled}" Margin="0,0,0,12"/>

                            <!-- Divider -->
                            <Separator Background="{DynamicResource Brush.Border}" Margin="0,4,0,16"/>

                            <!-- ══ PANEL ĐÃ ĐẶT TRƯỚC (PTT05) ══ -->
                            <StackPanel x:Name="PanelDaDatTruoc" Visibility="{Binding IsRoomReserved, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">

                                <TextBlock Text="📋  Thông tin đặt trước"
               FontSize="16" FontWeight="Bold"
               Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,14"/>

                                <!-- Tên khách -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Khách hàng"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock Text="{Binding ReservedGuestName}"
                   HorizontalAlignment="Right"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Heading}"/>
                                </Grid>
                                <Separator Background="{DynamicResource Brush.Border}" Margin="0,0,0,8"/>

                                <!-- Ngày nhận / trả -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngày nhận"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock Text="{Binding ReservedNgayNhan}"
                   HorizontalAlignment="Right"
                   FontSize="14" Foreground="{DynamicResource Brush.Heading}"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngày trả"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock Text="{Binding ReservedNgayTra}"
                   HorizontalAlignment="Right"
                   FontSize="14" Foreground="{DynamicResource Brush.Heading}"/>
                                </Grid>
                                <Separator Background="{DynamicResource Brush.Border}" Margin="0,0,0,8"/>

                                <!-- Tiền cọc -->
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Tiền đặt cọc"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock Text="{Binding ReservedTienCoc}"
                   HorizontalAlignment="Right"
                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.BrandPrimary}"/>
                                </Grid>

                                <!-- Nút xác nhận nhận phòng -->
                                <Button Command="{Binding CheckInCommand}" Height="44"
            FontSize="16" FontWeight="SemiBold" Cursor="Hand"
            Style="{DynamicResource MacFluent.ButtonPrimary}">
                                    <TextBlock Text="✅  Khách đã nhận phòng"
                   FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                </Button>

                            </StackPanel>

<!-- ══ FORM ĐẶT PHÒNG ══ -->
                            <StackPanel x:Name="PanelDatPhong" Visibility="{Binding IsRoomAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <TextBlock Text="📅  Đặt phòng" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,14"/>

                                <!-- Tìm khách hàng -->
                                <TextBlock Text="Khách hàng" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                        Height="36" Margin="0,0,0,4">
                                    <TextBox BorderThickness="0" Padding="10,0"
                                             VerticalAlignment="Center" FontSize="15"
                                             Text="{Binding KhachHangSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <ListBox ItemsSource="{Binding KhachHangResults}" MaxHeight="100" 
                                         Visibility="{Binding KhachHangResults.Count, Converter={StaticResource StringToVisibilityConverter}}"
                                         SelectedItem="{Binding SelectedKhach}"
                                         DisplayMemberPath="TenKhachHang"
                                         BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" Margin="0,0,0,4"/>
                                
                                <TextBlock Text="{Binding SelectedKhach.TenKhachHang}" FontSize="13" Foreground="{DynamicResource Brush.BrandPrimary}"
                                           Visibility="{Binding SelectedKhach, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <!-- Khách mới -->
                                <Expander Header="➕ Khách mới" Margin="0,0,0,10">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Số điện thoại" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Height="34" Margin="0,0,0,8">
                                            <TextBox Text="{Binding NewKhachSdt, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="15"/>
                                        </Border>
                                        <TextBlock Text="CCCD" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"
                                                   Visibility="{Binding IsKhachTrongNuoc, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Height="34"
                                                Visibility="{Binding IsKhachTrongNuoc, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBox Text="{Binding NewKhachCccd, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="15"/>
                                        </Border>

                                        <TextBlock Text="Địa chỉ" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <Border CornerRadius="8" Style="{DynamicResource MacFluent.InputFrame}" Height="34">
                                            <TextBox Text="{Binding NewKhachDiaChi, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="10,0"
                                   VerticalAlignment="Center" FontSize="15"/>
                                        </Border>

                                        <TextBlock Text="Số Passport" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"
                                                   Visibility="{Binding IsKhachNuocNgoai, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Border CornerRadius="8" Style="{DynamicResource MacFluent.InputFrame}" Height="34"
                                                Visibility="{Binding IsKhachNuocNgoai, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBox Text="{Binding NewKhachPassport, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="15"/>
                                        </Border>

                                        <TextBlock Text="Số Visa" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"
                                                   Visibility="{Binding IsKhachNuocNgoai, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Border CornerRadius="8" Style="{DynamicResource MacFluent.InputFrame}" Height="34"
                                                Visibility="{Binding IsKhachNuocNgoai, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBox Text="{Binding NewKhachVisa, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="15"/>
                                        </Border>

                                        <TextBlock Text="Quốc tịch" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"  />
                                        <Border CornerRadius="8" Style="{DynamicResource MacFluent.InputFrame}" Height="34">
                                            <TextBox Text="{Binding NewKhachQuocTich, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="10,0"
                                   VerticalAlignment="Center" FontSize="15" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Ngày nhận / trả -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ngày nhận" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <DatePicker SelectedDate="{Binding NgayNhan}" Height="34" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ngày trả" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <DatePicker SelectedDate="{Binding NgayTra}" Height="34" FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                                <Border CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                                        Background="{DynamicResource Brush.WarningSurface}">
                                    <TextBlock Text="Khuyến mãi sẽ được chọn khi xuất hóa đơn."
                                               FontSize="13"
                                               Foreground="{DynamicResource Brush.WarningText}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Tính giá -->
                                <Border CornerRadius="8" Padding="12,8" Background="{DynamicResource Brush.SurfaceSoft}" Margin="0,0,0,14">
                                    <TextBlock Text="{Binding TotalPriceText, StringFormat='{}Tổng tiền tạm tính: {0}'}" FontSize="14" Foreground="{DynamicResource Brush.Heading}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Nút xác nhận -->
                                <Button Command="{Binding DatPhongCommand}" Height="44"
                                        FontSize="16" FontWeight="SemiBold" Cursor="Hand"
                                        Style="{DynamicResource MacFluent.ButtonPrimary}">
                                    <TextBlock Text="📅  Xác nhận đặt phòng"
                                               FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                </Button>

                            </StackPanel>

                            <!-- Thông báo phòng không trống -->
                            <Border x:Name="PanelKhongTrong" Visibility="{Binding IsRoomOccupied, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    CornerRadius="10" Padding="14,10" Background="{DynamicResource Brush.WarningSurface}">
                                <TextBlock Text="{Binding SelectedRoom.TenTrangThai, StringFormat='Trạng thái: {0}'}" FontSize="15" Foreground="{DynamicResource Brush.WarningText}"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </ContentControl>
        </Grid>
    </Grid>
</Page>




