<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.PhongPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Quản lý Phòng">



    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ContentControl Grid.Row="0"
                        Background="{DynamicResource Brush.SurfaceTranslucent}"
                        Padding="16,12"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="20"
                        helpers:ThemeProperties.ShadowBlurRadius="18"
                        helpers:ThemeProperties.ShadowDepth="1"
                        helpers:ThemeProperties.ShadowOpacity="0.08">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAll" Content="Tất cả" Tag="all"
                            Click="Filter_Click" Margin="0,0,8,0"
                            Style="{DynamicResource MacFluent.FilterButton.Active}"/>
                    <Button Content="🟢 Trống" Tag="PTT01"
                            Click="Filter_Click" Margin="0,0,8,0"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="🔴 Đang ở" Tag="PTT02"
                            Click="Filter_Click" Margin="0,0,8,0"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="🟡 Dọn dẹp" Tag="PTT03"
                            Click="Filter_Click" Margin="0,0,8,0"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                    <Button Content="🟣 Đã đặt" Tag="PTT05"
                            Click="Filter_Click"
                            Style="{DynamicResource MacFluent.FilterButton}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnQuanTriPhong" Content="⚙  Quản trị"
                            Height="34" Padding="14,0" Margin="0,0,10,0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Click="BtnQuanTriPhong_Click"
                            Style="{DynamicResource MacFluent.ButtonAction.Add}"/>

                    <Border Height="34" Width="200" Padding="10,0"
                            Style="{DynamicResource MacFluent.InputFrame}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="TxtSearch" BorderThickness="0"
                                     Background="Transparent" VerticalAlignment="Center"
                                     FontSize="15" TextChanged="TxtSearch_TextChanged" Width="150"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ContentControl>

        <!-- Main layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Room cards -->
            <ContentControl Grid.Column="0"
                            Background="{DynamicResource Brush.Surface}" Padding="20"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="16"
                            helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}" Grid.ColumnSpan="2" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtRoomCount" Grid.Row="0"
                               FontSize="15" Foreground="{DynamicResource Brush.TextPlaceholder}" Margin="0,0,0,12"/>
                    
                    <!-- List Room (grouped by floor) -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <ItemsControl x:Name="PhongList">
                            
                            <!-- Group Style: Header cho mỗi tầng -->
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <!-- Tầng + Tổng phòng-->
                                            <Border Background="{DynamicResource Brush.SurfaceTranslucent}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="12,8"
                                                    Margin="0,0,0,12">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource Brush.Heading}">
                                                <Run Text="Tầng "/>
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock DockPanel.Dock="Right"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                               VerticalAlignment="Center">
                                                        <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                        <Run Text=" phòng"/>
                                                    </TextBlock>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                    <GroupStyle.Panel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </GroupStyle.Panel>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>

                            <!-- Panel Layout: WrapPanel để tự động xuống hàng -->
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="20,0" Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <!-- Item Template: Card phòng (giữ nguyên như cũ) -->
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Width="140" Height="120" Margin="8"
                            Background="{Binding CardBackground}" Cursor="Hand"
                            MouseLeftButtonDown="PhongCard_Click" Tag="{Binding}"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="14"
                            helpers:ThemeProperties.ShadowColor="{Binding ShadowColor}"
                            helpers:ThemeProperties.ShadowBlurRadius="10"
                            helpers:ThemeProperties.ShadowDepth="0"
                            helpers:ThemeProperties.ShadowOpacity="0.30">
                                        <Grid Margin="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MaPhong}"
                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding TenLoaiPhong}"
                                   FontSize="13" Foreground="#DDF"
                                   TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border Grid.Row="1" CornerRadius="6" Padding="6,3"
                            Background="#22FFFFFF" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TenTrangThai}"
                                   FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                    </ScrollViewer>
                </Grid>
            </ContentControl>

            <!-- Right panel: Chi tiết + Form đặt phòng -->
            <ContentControl Grid.Column="2"
                            Background="{DynamicResource Brush.Surface}"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="16"
                            helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}">

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="20">

                        <!-- Empty state -->
                        <StackPanel x:Name="PanelEmpty" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🏠" FontSize="50" HorizontalAlignment="Center" Margin="0,40,0,12"/>
                            <TextBlock Text="Chọn một phòng để xem chi tiết và đặt phòng"
                                       FontSize="15" Foreground="#AAA" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- PanelDetail + Form -->
                        <StackPanel x:Name="PanelDetail" Visibility="Collapsed">

                            <!-- DetailHeader -->
                            <Border x:Name="DetailHeader" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock x:Name="DetailMaPhong" FontSize="30"
                                                   FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="DetailLoaiPhong" FontSize="15" Foreground="#DDEEFF"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="8" Padding="8,4" Background="#22FFFFFF">
                                        <TextBlock x:Name="DetailTrangThai" FontSize="13"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Thông tin phòng -->
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Sức chứa" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                <TextBlock x:Name="InfoSoNguoi" HorizontalAlignment="Right"
                                           FontSize="15" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                            </Grid>
                            <Separator Background="#EEE" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Giá/đêm" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                <TextBlock x:Name="InfoGia" HorizontalAlignment="Right"
                                           FontSize="16" FontWeight="Bold" Foreground="#0078D4"/>
                            </Grid>

                            <!-- Tiện nghi -->
                            <TextBlock Text="Tiện nghi" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="TienNghiList" Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,0,4"
                                                Background="{DynamicResource Brush.SurfaceSoft}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="#0078D4" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding TenTienNghi}" FontSize="14" Foreground="#2C4A6E"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoTienNghi" Text="Chưa có tiện nghi"
                                       FontSize="14" Foreground="#BBB" Margin="0,0,0,12"/>

                            <!-- Divider -->
                            <Separator Background="#E0EAF4" Margin="0,4,0,16"/>

                            <!-- ══ PANEL ĐÃ ĐẶT TRƯỚC (PTT05) ══ -->
                            <StackPanel x:Name="PanelDaDatTruoc" Visibility="Collapsed" Margin="0,0,0,12">

                                <TextBlock Text="📋  Thông tin đặt trước"
               FontSize="16" FontWeight="Bold"
               Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,14"/>

                                <!-- Tên khách -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Khách hàng"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock x:Name="LblTenKhachDat"
                   HorizontalAlignment="Right"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Heading}"/>
                                </Grid>
                                <Separator Background="#EEE" Margin="0,0,0,8"/>

                                <!-- Ngày nhận / trả -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngày nhận"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock x:Name="LblNgayNhanDat"
                   HorizontalAlignment="Right"
                   FontSize="14" Foreground="{DynamicResource Brush.Heading}"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngày trả"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock x:Name="LblNgayTraDat"
                   HorizontalAlignment="Right"
                   FontSize="14" Foreground="{DynamicResource Brush.Heading}"/>
                                </Grid>
                                <Separator Background="#EEE" Margin="0,0,0,8"/>

                                <!-- Tiền cọc -->
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Tiền đặt cọc"
                   FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                    <TextBlock x:Name="LblTienCoc"
                   HorizontalAlignment="Right"
                   FontSize="16" FontWeight="Bold" Foreground="#0078D4"/>
                                </Grid>

                                <!-- Nút xác nhận nhận phòng -->
                                <Button x:Name="BtnKhachNhanPhong" Height="44"
            FontSize="16" FontWeight="SemiBold" Cursor="Hand"
            Click="BtnKhachNhanPhong_Click"
            Style="{DynamicResource MacFluent.ButtonPrimary}">
                                    <TextBlock Text="✅  Khách đã nhận phòng"
                   FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                </Button>

                            </StackPanel>

                            <!-- ══ FORM ĐẶT PHÒNG ══ -->
                            <StackPanel x:Name="PanelDatPhong">

                                <TextBlock Text="📅  Đặt phòng" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,14"/>

                                <!-- Tìm khách hàng -->
                                <TextBlock Text="Khách hàng" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                                        Height="36" Margin="0,0,0,4">
                                    <TextBox x:Name="TxtTimKhach" BorderThickness="0" Padding="10,0"
                                             VerticalAlignment="Center" FontSize="15"
                                             TextChanged="TxtTimKhach_TextChanged"/>
                                </Border>
                                <ListBox x:Name="ListKhach" MaxHeight="100" Visibility="Collapsed"
                                         SelectionChanged="ListKhach_SelectionChanged"
                                         DisplayMemberPath="TenKhachHang"
                                         BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtKhachInfo" FontSize="13" Foreground="#0078D4"
                                           Visibility="Collapsed" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <!-- Khách mới -->
                                <Expander Header="➕ Khách mới" Margin="0,0,0,10">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Số điện thoại" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Height="34" Margin="0,0,0,8">
                                            <TextBox x:Name="TxtDienThoai" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="15"/>
                                        </Border>
                                        <TextBlock Text="CCCD" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Height="34">
                                            <TextBox x:Name="TxtCCCD" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="15"/>
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Ngày nhận / trả -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ngày nhận" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <DatePicker x:Name="DpNgayNhan" Height="34" FontSize="14"
                                                    SelectedDateChanged="DatePicker_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ngày trả" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                                        <DatePicker x:Name="DpNgayTra" Height="34" FontSize="14"
                                                    SelectedDateChanged="DatePicker_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <Border CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                                        Background="{DynamicResource Brush.WarningSurface}">
                                    <TextBlock Text="Khuyến mãi sẽ được chọn khi xuất hóa đơn."
                                               FontSize="13"
                                               Foreground="{DynamicResource Brush.WarningText}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Tính giá -->
                                <Border CornerRadius="8" Padding="12,8" Background="{DynamicResource Brush.SurfaceSoft}" Margin="0,0,0,14">
                                    <TextBlock x:Name="TxtTinhGia" FontSize="14" Foreground="{DynamicResource Brush.Heading}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Nút xác nhận -->
                                <Button x:Name="BtnDatPhong" Height="44"
                                        FontSize="16" FontWeight="SemiBold" Cursor="Hand"
                                        Click="BtnDatPhong_Click"
                                        Style="{DynamicResource MacFluent.ButtonPrimary}">
                                    <TextBlock Text="📅  Xác nhận đặt phòng"
                                               FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                </Button>

                            </StackPanel>

                            <!-- Thông báo phòng không trống -->
                            <Border x:Name="PanelKhongTrong" Visibility="Collapsed"
                                    CornerRadius="10" Padding="14,10" Background="{DynamicResource Brush.WarningSurface}">
                                <TextBlock x:Name="TxtKhongTrong" FontSize="15" Foreground="{DynamicResource Brush.WarningText}"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </ContentControl>
        </Grid>
    </Grid>
</Page>




