<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,20,28,28">

            <!-- ── Bộ lọc thời gian ── -->
            <ContentControl Margin="0,0,0,20"
                            Background="{DynamicResource Brush.Surface}" Padding="16,10"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="12"
                            helpers:ThemeProperties.ShadowBlurRadius="10"
                            helpers:ThemeProperties.ShadowDepth="0"
                            helpers:ThemeProperties.ShadowOpacity="0.07">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kỳ báo cáo:" FontSize="15" Foreground="{DynamicResource Brush.TextLabel}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker x:Name="DpTuNgay" Height="32" FontSize="15" Width="140"
                                SelectedDate="{Binding TuNgay}"/>
                    <TextBlock Text=" → " FontSize="15" Foreground="{DynamicResource Brush.TextPlaceholder}"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <DatePicker x:Name="DpDenNgay" Height="32" FontSize="15" Width="140"
                                SelectedDate="{Binding DenNgay}"/>
                    <Button Content="Tháng này" Height="32" Padding="12,0" Margin="12,0,0,0"
                            Style="{DynamicResource MacFluent.ButtonBase}"
                            Background="{DynamicResource Brush.SurfaceSoft}" BorderThickness="0" FontSize="14"
                            Command="{Binding FilterThangNayCommand}"/>
                    <Button Content="Quý này" Height="32" Padding="12,0" Margin="8,0,0,0"
                            Style="{DynamicResource MacFluent.ButtonBase}"
                            Background="{DynamicResource Brush.SurfaceSoft}" BorderThickness="0" FontSize="14"
                            Command="{Binding FilterQuyNayCommand}"/>
                    <Button Content="Năm này" Height="32" Padding="12,0" Margin="8,0,0,0"
                            Style="{DynamicResource MacFluent.ButtonBase}"
                            Background="{DynamicResource Brush.SurfaceSoft}" BorderThickness="0" FontSize="14"
                            Command="{Binding FilterNamNayCommand}"/>
                </StackPanel>
            </ContentControl>

            <!-- ── KPI Cards ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Doanh thu -->
                <ContentControl Grid.Column="0" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}"
                                helpers:ThemeProperties.ShadowBlurRadius="20"
                                helpers:ThemeProperties.ShadowDepth="2"
                                helpers:ThemeProperties.ShadowOpacity="0.25">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.BrandPrimary}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="💰 Doanh Thu" FontSize="13" Foreground="White" Opacity="0.85"/>
                        <TextBlock x:Name="TxtDoanhThu" Text="{Binding DoanhThuText}" FontSize="26"
                                   FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Chi phí -->
                <ContentControl Grid.Column="2" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.RoomOccupied}"
                                helpers:ThemeProperties.ShadowBlurRadius="20"
                                helpers:ThemeProperties.ShadowDepth="2"
                                helpers:ThemeProperties.ShadowOpacity="0.25">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.RoomOccupied}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="💸 Chi Phí" FontSize="13" Foreground="White" Opacity="0.85"/>
                        <TextBlock x:Name="TxtChiPhi" Text="{Binding ChiPhiText}" FontSize="26"
                                   FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Lợi nhuận -->
                <ContentControl Grid.Column="4" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.RoomAvailable}"
                                helpers:ThemeProperties.ShadowBlurRadius="20"
                                helpers:ThemeProperties.ShadowDepth="2"
                                helpers:ThemeProperties.ShadowOpacity="0.25">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.RoomAvailable}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="📈 Lợi Nhuận" FontSize="13" Foreground="White" Opacity="0.85"/>
                        <TextBlock x:Name="TxtLoiNhuan" Text="{Binding LoiNhuanText}" FontSize="26"
                                   FontWeight="Bold" Foreground="{Binding LoiNhuanForeground}" Margin="0,6,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Tổng phòng -->
                <ContentControl Grid.Column="6" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.RoomReserved}"
                                helpers:ThemeProperties.ShadowBlurRadius="20"
                                helpers:ThemeProperties.ShadowDepth="2"
                                helpers:ThemeProperties.ShadowOpacity="0.25">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.RoomReserved}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="🏠 Tổng Phòng" FontSize="13" Foreground="White" Opacity="0.85"/>
                        <TextBlock x:Name="TxtTongPhong" Text="{Binding TongPhongText}" FontSize="26"
                                   FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Công suất -->
                <ContentControl Grid.Column="8" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.Info}"
                                helpers:ThemeProperties.ShadowBlurRadius="20"
                                helpers:ThemeProperties.ShadowDepth="2"
                                helpers:ThemeProperties.ShadowOpacity="0.25">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.Info}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="📊 Công Suất" FontSize="13" Foreground="White" Opacity="0.85"/>
                        <TextBlock x:Name="TxtCongSuat" Text="{Binding CongSuatText}" FontSize="26"
                                   FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
                </ContentControl>
            </Grid>

            <!-- ── Row 2: Biểu đồ doanh thu + Trạng thái phòng ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Biểu đồ doanh thu 12 tháng -->
                <ContentControl Grid.Column="0"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Doanh Thu 12 Tháng Gần Nhất" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <!-- Bar chart -->
                        <Grid Height="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <ItemsControl x:Name="BarChart" Grid.Row="0" ItemsSource="{Binding MonthlyRevenue}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="3,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                <Rectangle Height="{Binding BarHeight}"
                                                           VerticalAlignment="Bottom"
                                                           RadiusX="4" RadiusY="4"
                                                           Fill="{Binding BarColor}">
                                                    <Rectangle.ToolTip>
                                                        <TextBlock Text="{Binding Tooltip}"/>
                                                    </Rectangle.ToolTip>
                                                </Rectangle>
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{Binding ThangText}"
                                                       FontSize="12" Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <!-- Trạng thái phòng (pie-like) -->
                <ContentControl Grid.Column="2"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Trạng Thái Phòng" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="PhongStatusList" ItemsSource="{Binding RoomStatusStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="12" Height="12"
                                                   RadiusX="3" RadiusY="3"
                                                   Fill="{Binding MauSac}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TenTT}"
                                                   FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SoPhong}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                                        <!-- Progress bar -->
                                        <Border Grid.Column="5" Height="6" CornerRadius="3"
                                                Background="{DynamicResource Brush.SurfaceSoft}" VerticalAlignment="Center">
                                            <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                    Background="{Binding MauSac}"
                                                    Width="{Binding BarWidth}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12"/>
                        <TextBlock Text="Top Dịch Vụ" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="TopDichVuList" ItemsSource="{Binding TopServices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TenDV}" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}"/>
                                        <Border Grid.Column="1" CornerRadius="6" Padding="8,2"
                                                Background="{DynamicResource Brush.BrandSoft}">
                                            <TextBlock Text="{Binding SoLan}" FontSize="14"
                                                       Foreground="{DynamicResource Brush.BrandPrimary}" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>

            <!-- ── Row 3: Chi phí theo loại + Đặt phòng gần đây ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Chi phí theo loại -->
                <ContentControl Grid.Column="0"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Chi Phí Theo Loại" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="ChiPhiList" ItemsSource="{Binding ExpenseStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Loai}" FontSize="15" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            <Border Height="6" CornerRadius="3"
                                                    Margin="0,4,0,0" HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{DynamicResource Color.RoomOccupied}" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource Color.RoomCleaning}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TongText}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush.WarningText}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>

                <!-- Đặt phòng gần đây -->
                <ContentControl Grid.Column="2"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Đặt Phòng Gần Đây" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="RecentBookings" ItemsSource="{Binding RecentBookings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="10"
                                            Background="{DynamicResource Brush.SurfaceSoft}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenKhachHang}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.TextHeading}"/>
                                                <TextBlock Text="{Binding MaDatPhong}"
                                                           FontSize="13" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,4"
                                                    Background="{Binding StatusColor}">
                                                <TextBlock Text="{Binding TrangThai}"
                                                           FontSize="15" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>



