<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    Title="Dashboard"
    Background="Transparent">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,28">

            <!--  ── Bộ lọc thời gian ──  -->
            <ContentControl
                Margin="0,0,0,20"
                Padding="16,10"
                helpers:ThemeProperties.CornerRadius="12"
                helpers:ThemeProperties.ShadowBlurRadius="10"
                helpers:ThemeProperties.ShadowDepth="0"
                helpers:ThemeProperties.ShadowOpacity="0.07"
                Background="{DynamicResource Brush.Surface}"
                BorderThickness="0"
                Style="{DynamicResource MacFluent.ShadowCard}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Kỳ báo cáo:" />
                    <DatePicker
                        x:Name="DpTuNgay"
                        Width="140"
                        Height="32"
                        FontSize="15"
                        SelectedDate="{Binding TuNgay}" />
                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                        Text=" → " />
                    <DatePicker
                        x:Name="DpDenNgay"
                        Width="140"
                        Height="32"
                        FontSize="15"
                        SelectedDate="{Binding DenNgay}" />
                    <Button
                        Height="32"
                        Margin="12,0,0,0"
                        Padding="12,0"
                        Background="{DynamicResource Brush.SurfaceSoft}"
                        BorderThickness="0"
                        Command="{Binding FilterThangNayCommand}"
                        Content="Tháng này"
                        FontSize="14"
                        Style="{DynamicResource MacFluent.ButtonBase}" />
                    <Button
                        Height="32"
                        Margin="8,0,0,0"
                        Padding="12,0"
                        Background="{DynamicResource Brush.SurfaceSoft}"
                        BorderThickness="0"
                        Command="{Binding FilterQuyNayCommand}"
                        Content="Quý này"
                        FontSize="14"
                        Style="{DynamicResource MacFluent.ButtonBase}" />
                    <Button
                        Height="32"
                        Margin="8,0,0,0"
                        Padding="12,0"
                        Background="{DynamicResource Brush.SurfaceSoft}"
                        BorderThickness="0"
                        Command="{Binding FilterNamNayCommand}"
                        Content="Năm này"
                        FontSize="14"
                        Style="{DynamicResource MacFluent.ButtonBase}" />
                </StackPanel>
            </ContentControl>

            <!--  ── KPI Cards ──  -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Doanh thu  -->
                <ContentControl
                    Grid.Column="0"
                    Height="100"
                    Padding="18,14"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="20"
                    helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}"
                    helpers:ThemeProperties.ShadowDepth="2"
                    helpers:ThemeProperties.ShadowOpacity="0.25"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.BrandPrimary}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Opacity="0.85"
                            Text="💰 Doanh Thu" />
                        <TextBlock
                            x:Name="TxtDoanhThu"
                            Margin="0,6,0,0"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding DoanhThuText}" />
                    </StackPanel>
                </ContentControl>

                <!--  Chi phí  -->
                <ContentControl
                    Grid.Column="2"
                    Height="100"
                    Padding="18,14"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="20"
                    helpers:ThemeProperties.ShadowColor="{DynamicResource Color.RoomOccupied}"
                    helpers:ThemeProperties.ShadowDepth="2"
                    helpers:ThemeProperties.ShadowOpacity="0.25"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.RoomOccupied}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Opacity="0.85"
                            Text="💸 Chi Phí" />
                        <TextBlock
                            x:Name="TxtChiPhi"
                            Margin="0,6,0,0"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding ChiPhiText}" />
                    </StackPanel>
                </ContentControl>

                <!--  Lợi nhuận  -->
                <ContentControl
                    Grid.Column="4"
                    Height="100"
                    Padding="18,14"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="20"
                    helpers:ThemeProperties.ShadowColor="{DynamicResource Color.RoomAvailable}"
                    helpers:ThemeProperties.ShadowDepth="2"
                    helpers:ThemeProperties.ShadowOpacity="0.25"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.RoomAvailable}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Opacity="0.85"
                            Text="📈 Lợi Nhuận" />
                        <TextBlock
                            x:Name="TxtLoiNhuan"
                            Margin="0,6,0,0"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="{Binding LoiNhuanForeground}"
                            Text="{Binding LoiNhuanText}" />
                    </StackPanel>
                </ContentControl>

                <!--  Tổng phòng  -->
                <ContentControl
                    Grid.Column="6"
                    Height="100"
                    Padding="18,14"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="20"
                    helpers:ThemeProperties.ShadowColor="{DynamicResource Color.RoomReserved}"
                    helpers:ThemeProperties.ShadowDepth="2"
                    helpers:ThemeProperties.ShadowOpacity="0.25"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.RoomReserved}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Opacity="0.85"
                            Text="🏠 Tổng Phòng" />
                        <TextBlock
                            x:Name="TxtTongPhong"
                            Margin="0,6,0,0"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding TongPhongText}" />
                    </StackPanel>
                </ContentControl>

                <!--  Công suất  -->
                <ContentControl
                    Grid.Column="8"
                    Height="100"
                    Padding="18,14"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="20"
                    helpers:ThemeProperties.ShadowColor="{DynamicResource Color.Info}"
                    helpers:ThemeProperties.ShadowDepth="2"
                    helpers:ThemeProperties.ShadowOpacity="0.25"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <ContentControl.Background>
                        <SolidColorBrush Color="{DynamicResource Color.Info}" />
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            Foreground="White"
                            Opacity="0.85"
                            Text="📊 Công Suất" />
                        <TextBlock
                            x:Name="TxtCongSuat"
                            Margin="0,6,0,0"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding CongSuatText}" />
                    </StackPanel>
                </ContentControl>
            </Grid>

            <!--  ── Row 2: Biểu đồ doanh thu + Trạng thái phòng ──  -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <!--  Biểu đồ doanh thu 12 tháng  -->
                <ContentControl
                    Grid.Column="0"
                    Padding="20"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="12"
                    helpers:ThemeProperties.ShadowDepth="0"
                    helpers:ThemeProperties.ShadowOpacity="0.07"
                    Background="{DynamicResource Brush.Surface}"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="Doanh Thu 12 Tháng Gần Nhất" />
                        <!--  Bar chart  -->
                        <Grid Height="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="24" />
                            </Grid.RowDefinitions>
                            <ItemsControl
                                x:Name="BarChart"
                                Grid.Row="0"
                                ItemsSource="{Binding MonthlyRevenue}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="3,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                <Rectangle
                                                    Height="{Binding BarHeight}"
                                                    VerticalAlignment="Bottom"
                                                    Fill="{Binding BarColor}"
                                                    RadiusX="4"
                                                    RadiusY="4">
                                                    <Rectangle.ToolTip>
                                                        <TextBlock Text="{Binding Tooltip}" />
                                                    </Rectangle.ToolTip>
                                                </Rectangle>
                                            </Grid>
                                            <TextBlock
                                                Grid.Row="1"
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                Text="{Binding ThangText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <!--  Trạng thái phòng (pie-like)  -->
                <ContentControl
                    Grid.Column="2"
                    Padding="20"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="12"
                    helpers:ThemeProperties.ShadowDepth="0"
                    helpers:ThemeProperties.ShadowOpacity="0.07"
                    Background="{DynamicResource Brush.Surface}"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="Trạng Thái Phòng" />
                        <ItemsControl x:Name="PhongStatusList" ItemsSource="{Binding RoomStatusStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle
                                            Grid.Column="0"
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Fill="{Binding MauSac}"
                                            RadiusX="3"
                                            RadiusY="3" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding TenTT}" />
                                        <TextBlock
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource Brush.Heading}"
                                            Text="{Binding SoPhong}" />
                                        <!--  Progress bar  -->
                                        <Border
                                            Grid.Column="5"
                                            Height="6"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource Brush.SurfaceSoft}"
                                            CornerRadius="3">
                                            <Border
                                                Width="{Binding BarWidth}"
                                                Height="6"
                                                HorizontalAlignment="Left"
                                                Background="{Binding MauSac}"
                                                CornerRadius="3" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12" />
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="Top Dịch Vụ" />
                        <ItemsControl x:Name="TopDichVuList" ItemsSource="{Binding TopServices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="14"
                                            Foreground="{DynamicResource Brush.TextLabel}"
                                            Text="{Binding TenDV}" />
                                        <Border
                                            Grid.Column="1"
                                            Padding="8,2"
                                            Background="{DynamicResource Brush.BrandSoft}"
                                            CornerRadius="6">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource Brush.BrandPrimary}"
                                                Text="{Binding SoLan}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>

            <!--  ── Row 3: Chi phí theo loại + Đặt phòng gần đây ──  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Chi phí theo loại  -->
                <ContentControl
                    Grid.Column="0"
                    Padding="20"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="12"
                    helpers:ThemeProperties.ShadowDepth="0"
                    helpers:ThemeProperties.ShadowOpacity="0.07"
                    Background="{DynamicResource Brush.Surface}"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="Chi Phí Theo Loại" />
                        <ItemsControl x:Name="ChiPhiList" ItemsSource="{Binding ExpenseStats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="15"
                                                Foreground="{DynamicResource Brush.TextPrimary}"
                                                Text="{Binding Loai}" />
                                            <Border
                                                Width="{Binding BarWidth}"
                                                Height="6"
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Left"
                                                CornerRadius="3">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Offset="0" Color="{DynamicResource Color.RoomOccupied}" />
                                                        <GradientStop Offset="1" Color="{DynamicResource Color.RoomCleaning}" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource Brush.WarningText}"
                                            Text="{Binding TongText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>

                <!--  Đặt phòng gần đây  -->
                <ContentControl
                    Grid.Column="2"
                    Padding="20"
                    helpers:ThemeProperties.CornerRadius="16"
                    helpers:ThemeProperties.ShadowBlurRadius="12"
                    helpers:ThemeProperties.ShadowDepth="0"
                    helpers:ThemeProperties.ShadowOpacity="0.07"
                    Background="{DynamicResource Brush.Surface}"
                    BorderThickness="0"
                    Style="{DynamicResource MacFluent.ShadowCard}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="Đặt Phòng Gần Đây" />
                        <ItemsControl x:Name="RecentBookings" ItemsSource="{Binding RecentBookings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="12,10"
                                        Background="{DynamicResource Brush.SurfaceSoft}"
                                        CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource Brush.TextHeading}"
                                                    Text="{Binding TenKhachHang}" />
                                                <TextBlock
                                                    FontSize="13"
                                                    Foreground="{DynamicResource Brush.TextMuted}"
                                                    Text="{Binding MaDatPhong}" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Padding="8,4"
                                                Background="{Binding StatusColor}"
                                                CornerRadius="6">
                                                <TextBlock
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding TrangThai}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>



