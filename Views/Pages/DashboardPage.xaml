<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,20,28,28">

            <!-- ── Bộ lọc thời gian ── -->
            <ContentControl Margin="0,0,0,20"
                            Background="{DynamicResource Brush.Surface}" Padding="16,10"
                            BorderThickness="0"
                            Style="{DynamicResource MacFluent.ShadowCard}"
                            helpers:ThemeProperties.CornerRadius="12"
                            helpers:ThemeProperties.ShadowBlurRadius="10"
                            helpers:ThemeProperties.ShadowDepth="0"
                            helpers:ThemeProperties.ShadowOpacity="0.07">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kỳ báo cáo:" FontSize="15" Foreground="{DynamicResource Brush.TextLabel}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker x:Name="DpTuNgay" Height="32" FontSize="15" Width="140"
                                SelectedDateChanged="DateFilter_Changed"/>
                    <TextBlock Text=" → " FontSize="15" Foreground="{DynamicResource Brush.TextPlaceholder}"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <DatePicker x:Name="DpDenNgay" Height="32" FontSize="15" Width="140"
                                SelectedDateChanged="DateFilter_Changed"/>
                    <Button Content="Tháng này" Height="32" Padding="12,0" Margin="12,0,0,0"
                            Style="{DynamicResource MacFluent.ButtonBase}"
                            Background="{DynamicResource Brush.SurfaceSoft}" BorderThickness="0" FontSize="14"
                            Click="BtnThangNay_Click"/>
                    <Button Content="Quý này" Height="32" Padding="12,0" Margin="8,0,0,0"
                            Style="{DynamicResource MacFluent.ButtonBase}"
                            Background="{DynamicResource Brush.SurfaceSoft}" BorderThickness="0" FontSize="14"
                            Click="BtnQuyNay_Click"/>
                    <Button Content="Năm này" Height="32" Padding="12,0" Margin="8,0,0,0"
                            Style="{DynamicResource MacFluent.ButtonBase}"
                            Background="{DynamicResource Brush.SurfaceSoft}" BorderThickness="0" FontSize="14"
                            Click="BtnNamNay_Click"/>
                </StackPanel>
            </ContentControl>

            <!-- ── KPI Cards ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Doanh thu -->
                <ContentControl Grid.Column="0" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="{DynamicResource Color.BrandPrimary}"
                                helpers:ThemeProperties.ShadowBlurRadius="18"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.3">
                    <ContentControl.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{DynamicResource Color.BrandPrimary}" Offset="0"/>
                            <GradientStop Color="{DynamicResource Color.BrandSecondary}" Offset="1"/>
                        </LinearGradientBrush>
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="💰 Doanh Thu" FontSize="13" Foreground="#CCE8FF"/>
                        <TextBlock x:Name="TxtDoanhThu" Text="—" FontSize="24"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Chi phí -->
                <ContentControl Grid.Column="2" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="#E17055"
                                helpers:ThemeProperties.ShadowBlurRadius="18"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.3">
                    <ContentControl.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E17055" Offset="0"/>
                            <GradientStop Color="#FDCB6E" Offset="1"/>
                        </LinearGradientBrush>
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="💸 Chi Phí" FontSize="13" Foreground="#FFEAA7"/>
                        <TextBlock x:Name="TxtChiPhi" Text="—" FontSize="24"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Lợi nhuận -->
                <ContentControl Grid.Column="4" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="#00B894"
                                helpers:ThemeProperties.ShadowBlurRadius="18"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.3">
                    <ContentControl.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00B894" Offset="0"/>
                            <GradientStop Color="#00CEC9" Offset="1"/>
                        </LinearGradientBrush>
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="📈 Lợi Nhuận" FontSize="13" Foreground="#B2F0E8"/>
                        <TextBlock x:Name="TxtLoiNhuan" Text="—" FontSize="24"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Tổng phòng -->
                <ContentControl Grid.Column="6" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="#6C5CE7"
                                helpers:ThemeProperties.ShadowBlurRadius="18"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.3">
                    <ContentControl.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6C5CE7" Offset="0"/>
                            <GradientStop Color="#A29BFE" Offset="1"/>
                        </LinearGradientBrush>
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="🏠 Tổng Phòng" FontSize="13" Foreground="#DDD9FF"/>
                        <TextBlock x:Name="TxtTongPhong" Text="—" FontSize="24"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Công suất -->
                <ContentControl Grid.Column="8" Padding="18,14" Height="100"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowColor="#E84393"
                                helpers:ThemeProperties.ShadowBlurRadius="18"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.3">
                    <ContentControl.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FD79A8" Offset="0"/>
                            <GradientStop Color="#E84393" Offset="1"/>
                        </LinearGradientBrush>
                    </ContentControl.Background>
                    <StackPanel>
                        <TextBlock Text="📊 Công Suất" FontSize="13" Foreground="#FFD6EC"/>
                        <TextBlock x:Name="TxtCongSuat" Text="—" FontSize="24"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </ContentControl>
            </Grid>

            <!-- ── Row 2: Biểu đồ doanh thu + Trạng thái phòng ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Biểu đồ doanh thu 12 tháng -->
                <ContentControl Grid.Column="0"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Doanh Thu 12 Tháng Gần Nhất" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <!-- Bar chart -->
                        <Grid Height="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <ItemsControl x:Name="BarChart" Grid.Row="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="3,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                <Rectangle Height="{Binding BarHeight}"
                                                           VerticalAlignment="Bottom"
                                                           RadiusX="4" RadiusY="4"
                                                           Fill="{Binding BarColor}">
                                                    <Rectangle.ToolTip>
                                                        <TextBlock Text="{Binding Tooltip}"/>
                                                    </Rectangle.ToolTip>
                                                </Rectangle>
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{Binding ThangText}"
                                                       FontSize="12" Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <!-- Trạng thái phòng (pie-like) -->
                <ContentControl Grid.Column="2"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Trạng Thái Phòng" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="PhongStatusList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="12" Height="12"
                                                   RadiusX="3" RadiusY="3"
                                                   Fill="{Binding MauSac}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TenTT}"
                                                   FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SoPhong}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                                        <!-- Progress bar -->
                                        <Border Grid.Column="5" Height="6" CornerRadius="3"
                                                Background="{DynamicResource Brush.SurfaceSoft}" VerticalAlignment="Center">
                                            <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                    Background="{Binding MauSac}"
                                                    Width="{Binding BarWidth}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12"/>
                        <TextBlock Text="Top Dịch Vụ" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="TopDichVuList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TenDV}" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}"/>
                                        <Border Grid.Column="1" CornerRadius="6" Padding="8,2"
                                                Background="#EBF5FB">
                                            <TextBlock Text="{Binding SoLan}" FontSize="14"
                                                       Foreground="#0078D4" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>

            <!-- ── Row 3: Chi phí theo loại + Đặt phòng gần đây ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Chi phí theo loại -->
                <ContentControl Grid.Column="0"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Chi Phí Theo Loại" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="ChiPhiList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Loai}" FontSize="15" Foreground="#333"/>
                                            <Border Height="6" CornerRadius="3"
                                                    Margin="0,4,0,0" HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#E17055" Offset="0"/>
                                                        <GradientStop Color="#FDCB6E" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TongText}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush.WarningText}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>

                <!-- Đặt phòng gần đây -->
                <ContentControl Grid.Column="2"
                                Background="{DynamicResource Brush.Surface}" Padding="20"
                                BorderThickness="0"
                                Style="{DynamicResource MacFluent.ShadowCard}"
                                helpers:ThemeProperties.CornerRadius="16"
                                helpers:ThemeProperties.ShadowBlurRadius="12"
                                helpers:ThemeProperties.ShadowDepth="0"
                                helpers:ThemeProperties.ShadowOpacity="0.07">
                    <StackPanel>
                        <TextBlock Text="Đặt Phòng Gần Đây" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="RecentBookings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="10"
                                            Background="#F8FBFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenKhachHang}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           Foreground="#1A3A5C"/>
                                                <TextBlock Text="{Binding MaDatPhong}"
                                                           FontSize="15" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,4"
                                                    Background="{Binding StatusColor}">
                                                <TextBlock Text="{Binding TrangThai}"
                                                           FontSize="15" FontWeight="Bold" Foreground="#FFFFFF"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>



