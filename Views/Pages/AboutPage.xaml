<Page
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AboutPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Border
            MaxWidth="600"
            Margin="16"
            Padding="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="12"
            Effect="{DynamicResource MaterialShadow3}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center"
                    FontSize="72"
                    Text="🏩" />

                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryBrush}"
                    Text="PHẦN MỀM QUẢN LÝ KHÁCH SẠN" />

                <TextBlock
                    Margin="0,4,0,24"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="Gray"
                    Text="Phiên bản 1.0.0 (Bản quyền 2026)" />

                <Separator Margin="0,0,0,24" Background="{DynamicResource BorderBrush}" />

                <Border
                    Margin="0,0,0,24"
                    Padding="24"
                    Background="{DynamicResource BackgroundBrush}"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="THÔNG TIN TÁC GIẢ" />
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="Gray" Text="Sinh viên:" />
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="Medium"
                                Text="Phạm Tấn Lợi" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="Gray" Text="Mã số sinh viên:" />
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="Medium"
                                Text="23116508" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="Gray" Text="Lớp:" />
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="Medium"
                                Text="23.1 UDPM2" />
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="Gray" Text="Đơn vị:" />
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="Medium"
                                Text="Trường Cao đẳng nghề Cần Thơ" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Button
                    Width="250"
                    Height="45"
                    Command="{Binding MoHuongDanCommand}"
                    Content="MỞ HƯỚNG DẪN SỬ DỤNG"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
