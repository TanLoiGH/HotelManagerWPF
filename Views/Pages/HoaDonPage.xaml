<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.HoaDonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Hoá Đơn">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ContentControl Grid.Row="0"
                        Background="{DynamicResource Brush.Surface}" Padding="16,12"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="14"
                        helpers:ThemeProperties.ShadowBlurRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnTatCa" Content="Tất cả"
                        Click="FilterStatus_Click" Tag=""
                        Style="{DynamicResource MacFluent.FilterButton.Active}"/>
                <Button Grid.Column="2" Content="Chưa TT"
                        Click="FilterStatus_Click" Tag="Chưa thanh toán"
                        Style="{DynamicResource MacFluent.FilterButton}"/>
                <Button Grid.Column="4" Content="Đã TT"
                        Click="FilterStatus_Click" Tag="Đã thanh toán"
                        Style="{DynamicResource MacFluent.FilterButton}"/>

                <Border Grid.Column="6" CornerRadius="10" BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1.5" Padding="10,0" Height="36">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtSearch" BorderThickness="0"
                                 Background="Transparent" VerticalAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ContentControl>

        <!-- DataGrid -->
        <ContentControl Grid.Row="2"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <DataGrid x:Name="HoaDonGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="15"
                      BorderThickness="0" Padding="8" RowHeight="44"
                      SelectionChanged="HoaDonGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HD" Binding="{Binding MaHoaDon}" Width="90"/>
                    <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                    <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLapText}" Width="110"/>
                    <DataGridTextColumn Header="Tiền phòng" Binding="{Binding TienPhongText}" Width="120"/>
                    <DataGridTextColumn Header="Tiền DV" Binding="{Binding TienDichVuText}" Width="100"/>
                    <DataGridTextColumn Header="Tổng TT" Binding="{Binding TongThanhToanText}" Width="120"/>
                    <DataGridTemplateColumn Header="Trạng thái" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,3" Margin="4"
                                        Background="{Binding StatusColor}" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TrangThai}" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </ContentControl>

        <!-- Action buttons -->
        <!-- Action buttons — thêm BtnXuatHD -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnXuatHD" Content="🧾  Xuất hóa đơn"
            Height="40" Padding="20,0" Margin="0,0,12,0"
            FontSize="15"
            Style="{DynamicResource MacFluent.ButtonAction.Edit}"
            Click="BtnXuatHD_Click"/>
            <Button x:Name="BtnThemDichVu" Content="🍽️  Thêm dịch vụ"
            Height="40" Padding="20,0" Margin="0,0,12,0"
            FontSize="15" IsEnabled="False"
            Style="{DynamicResource MacFluent.ButtonAction.Add}"
            Click="BtnThemDichVu_Click"/>
            <Button x:Name="BtnThanhToan" Content="💳  Thanh toán"
            Height="40" Padding="20,0"
            FontSize="15" FontWeight="SemiBold"
            IsEnabled="False"
            Style="{DynamicResource MacFluent.ButtonPrimary}"
            Click="BtnThanhToan_Click"/>
        </StackPanel>

    </Grid>
</Page>




