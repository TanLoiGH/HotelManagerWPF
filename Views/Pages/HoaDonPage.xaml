<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.HoaDonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent" Title="Hoá Đơn">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Quản lý Hóa đơn" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                <Border Background="{DynamicResource Brush.SurfaceSoft}" CornerRadius="15" Padding="10,4" Margin="15,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="Green" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtPrintStatus" Text="Máy in: Sẵn sàng" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnTatCa" Content="Tất cả" Click="FilterStatus_Click" Tag="" Style="{DynamicResource MacFluent.FilterButton.Active}" Margin="0,0,8,0"/>
                <Button Content="Chưa TT" Click="FilterStatus_Click" Tag="Chưa thanh toán" Style="{DynamicResource MacFluent.FilterButton}" Margin="0,0,8,0"/>
                <Button Content="Đã TT" Click="FilterStatus_Click" Tag="Đã thanh toán" Style="{DynamicResource MacFluent.FilterButton}"/>
            </StackPanel>
        </Grid>

        <!-- Search & Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Border CornerRadius="8" Background="{DynamicResource Brush.SurfaceSoft}" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                    <TextBox x:Name="TxtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                             VerticalAlignment="Center" FontSize="15" Tag="Tìm mã hóa đơn, tên khách..."
                             TextChanged="TxtSearch_TextChanged"/>
                </Grid>
            </Border>

            <Button Grid.Column="1" x:Name="BtnTestPrint" Content="🧪 In thử" 
                    Margin="12,0,0,0" Padding="15,0" Height="38"
                    Style="{DynamicResource MacFluent.ButtonSecondary}"
                    Click="BtnTestPrint_Click"/>
        </Grid>

        <!-- DataGrid -->
        <ContentControl Grid.Row="2"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <DataGrid x:Name="HoaDonGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="15"
                      BorderThickness="0" Padding="8" RowHeight="44"
                      SelectionChanged="HoaDonGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HD" Binding="{Binding MaHoaDon}" Width="90"/>
                    <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                    <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLapText}" Width="110"/>
                    <DataGridTextColumn Header="Tiền phòng" Binding="{Binding TienPhongText}" Width="120"/>
                    <DataGridTextColumn Header="Tiền DV" Binding="{Binding TienDichVuText}" Width="100"/>
                    <DataGridTextColumn Header="Tổng TT" Binding="{Binding TongThanhToanText}" Width="120"/>
                    <DataGridTemplateColumn Header="Trạng thái" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,3" Margin="4"
                                        Background="{Binding StatusColor}" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TrangThai}" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <!-- Double click -->
                                <EventSetter Event="MouseDoubleClick" Handler="HoaDonRow_DoubleClick"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </ContentControl>

        <!-- Action buttons -->
        <!-- Action buttons — thêm BtnXuatHD -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnInHoaDon" Content="🖨️  In hóa đơn"
            Height="40" Padding="20,0" Margin="0,0,12,0"
            FontSize="15" IsEnabled="False"
            Style="{DynamicResource MacFluent.ButtonAction.AddSoft}"
            Click="BtnInHoaDon_Click"/>
            <Button x:Name="BtnXuatHD" Content="🧾  Xuất hóa đơn"
            Height="40" Padding="20,0" Margin="0,0,12,0"
            FontSize="15"
            Style="{DynamicResource MacFluent.ButtonAction.Edit}"
            Click="BtnXuatHD_Click"/>
            <Button x:Name="BtnThemDichVu" Content="🍽️  Thêm dịch vụ"
            Height="40" Padding="20,0" Margin="0,0,12,0"
            FontSize="15" IsEnabled="False"
            Style="{DynamicResource MacFluent.ButtonAction.Add}"
            Click="BtnThemDichVu_Click"/>
            <Button x:Name="BtnThanhToan" Content="💳  Thanh toán"
            Height="40" Padding="20,0"
            FontSize="15" FontWeight="SemiBold"
            IsEnabled="False"
            Style="{DynamicResource MacFluent.ButtonPrimary}"
            Click="BtnThanhToan_Click"/>
        </StackPanel>

    </Grid>
</Page>




