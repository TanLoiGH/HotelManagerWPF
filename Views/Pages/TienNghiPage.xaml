<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.TienNghiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent"
      Title="Tiện Nghi">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0"
                        Background="{DynamicResource Brush.Surface}" Padding="20"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                    <TextBlock Text="Chọn phòng kiểm tra" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="CboPhong" Height="38" FontSize="15" SelectionChanged="CboPhong_SelectionChanged"/>
                    <TextBlock x:Name="TxtAlert" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource Brush.WarningText}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource Brush.Border}" Margin="0,4"/>

                <Grid Grid.Column="2" Margin="24,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Đổi trạng thái:" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Width="110"/>
                        <ComboBox x:Name="CboTrangThai" Height="36" Width="220" FontSize="15" Margin="0,0,12,0"/>
                        <Button Content="Lưu cập nhật" Height="36" Padding="16,0" FontSize="14"
                                Style="{DynamicResource MacFluent.ButtonAction.Edit}"
                                Click="BtnCapNhat_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Ghi chi phí:" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Width="110"/>
                        <ComboBox x:Name="CboLoaiXuLy" Height="36" Width="110" FontSize="15" Margin="0,0,12,0">
                            <ComboBoxItem Content="Sửa chữa" IsSelected="True"/>
                            <ComboBoxItem Content="Thay mới"/>
                        </ComboBox>

                        <Border CornerRadius="6" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Height="36" Margin="0,0,12,0" Background="{DynamicResource Brush.Control}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="TxtChiPhi" Width="120" BorderThickness="0" Background="Transparent" Padding="12,0" FontSize="15" VerticalAlignment="Center" ToolTip="Nhập chi phí (VNĐ)"/>
                                <TextBlock Text="VNĐ" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Ghi &amp; Hoàn tất" Height="36" Padding="16,0" FontSize="14"
                                Style="{DynamicResource MacFluent.ButtonAction.Save}"
                                Click="BtnGhiXuLy_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ContentControl>

        <Border Grid.Row="2" Background="#1DF5F5F5" CornerRadius="10" Padding="16,12" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="💡 Mẹo thao tác nhanh:" FontWeight="SemiBold" FontSize="15" FontStyle="Italic" Margin="0,0,0,6"/>
                <TextBlock FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}" TextWrapping="Wrap" LineHeight="22">
                    <Run Text="1." FontWeight="Bold"/> <Run Text="Báo hỏng siêu tốc: "/> <Run Text="Click đúp chuột (Double-click)" FontWeight="SemiBold"/> <Run Text=" vào dòng tiện nghi đang 'Hoạt động tốt' để chuyển ngay sang 'Cần bảo trì'."/> <LineBreak/>
                    <Run Text="2." FontWeight="Bold"/> <Run Text="Xử lý &amp; Ghi chi phí: "/> <Run Text="Click chọn 1 dòng tiện nghi bị hỏng bên dưới, con trỏ chuột sẽ tự động đưa vào ô nhập "/> <Run Text="Chi phí" FontWeight="SemiBold"/> <Run Text=" -> Nhập số tiền và bấm Ghi (Tiện nghi sẽ tự động phục hồi về Hoạt động tốt)."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="4"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <DataGrid x:Name="TienNghiGrid"
                      SelectionChanged="TienNghiGrid_SelectionChanged"
                      MouseDoubleClick="TienNghiGrid_MouseDoubleClick"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="15"
                      BorderThickness="0" Padding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên tiện nghi" Binding="{Binding TenTienNghi}" Width="*"/>
                    <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding TenNCC}" Width="160"/>
                    <DataGridTextColumn Header="Hạn bảo hành" Binding="{Binding HanBaoHanhText}" Width="120"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TenTrangThai}" Width="150"/>
                    <DataGridCheckBoxColumn Header="Cảnh báo" Binding="{Binding CanBaoTri}" Width="90"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanBaoTri}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.WarningSurface}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </ContentControl>
    </Grid>
</Page>