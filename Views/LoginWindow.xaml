<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Đăng nhập - Quản Lý Khách Sạn"
        Width="900" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Background}"
        
        KeyDown="Window_KeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="20"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>


    <Border  ClipToBounds="True" MouseLeftButtonDown="Window_DragMove">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ CỘT TRÁI: Gradient M365 ══ -->
            <Border Grid.Column="0" >
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource Color.Heading}" Offset="0.0"/>
                        <GradientStop Color="{DynamicResource Color.BrandPrimary}" Offset="0.5"/>
                        <GradientStop Color="{DynamicResource Color.BrandSecondary}" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Ellipse Width="280" Height="280"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-80,-80,0,0" Opacity="0.15">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Ellipse Width="200" Height="200"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-60,-60" Opacity="0.12"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">

                        <Border Width="72" Height="72" CornerRadius="20"
                                HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#E8F4FD" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🏨" FontSize="38"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Quản Lý Khách Sạn"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White" TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Phạm Tấn Lợi"
                                   FontSize="15" Foreground="#B3D9F7"
                                   TextAlignment="Center" HorizontalAlignment="Center"
                                   Margin="0,6,0,32"/>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="32" Height="32" CornerRadius="8"
                                         Margin="0,0,12,0">
                                    <TextBlock Text="📊" FontSize="17"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Brush.SurfaceSoft}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Quản lý đặt phòng" FontSize="15"
                                               FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Theo dõi real-time" FontSize="13" Foreground="#B3D9F7"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="32" Height="32" CornerRadius="8"
                                         Margin="0,0,12,0">
                                    <TextBlock Text="💰" FontSize="17"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Brush.SurfaceSoft}" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Hóa đơn &amp; Doanh thu" FontSize="15"
                                               FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Báo cáo tài chính" FontSize="13" Foreground="#B3D9F7"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8"
                                         Margin="0,0,12,0">
                                    <TextBlock Text="👥" FontSize="17"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Brush.SurfaceSoft}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Quản lý nhân viên" FontSize="15"
                                               FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Phân quyền linh hoạt" FontSize="13" Foreground="#B3D9F7"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ CỘT PHẢI: Form đăng nhập ══ -->
            <Border Grid.Column="1" Background="{DynamicResource Brush.Surface}" CornerRadius="0 20 20 0">
                <Grid>
                    <Button Content="✕" Width="32" Height="32"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,12,0"
                            FontSize="15" Foreground="{DynamicResource Brush.TextSubtle}"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseButton_Click"
                            Style="{DynamicResource MacFluent.ButtonGhost}"/>

                    <StackPanel VerticalAlignment="Center" Margin="56,0,56,0">

                        <TextBlock Text="Chào mừng trở lại 👋"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,6"/>
                        <TextBlock Text="Đăng nhập để tiếp tục"
                                   FontSize="15" Foreground="{DynamicResource Brush.TextPlaceholder}"
                                   Margin="0,0,0,32"/>

                        <!-- Tên đăng nhập -->
                        <TextBlock Text="Tên đăng nhập" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,6"/>
                        <Border Height="44" Margin="0,0,0,16"
                                Style="{DynamicResource MacFluent.InputFrame}"
                                FocusManager.FocusedElement="{Binding ElementName=TxtUsername}"> <!-- Đặt con trỏ -->
                            <TextBox x:Name="TxtUsername"
                                     Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalAlignment="Center"
                                     Padding="14,0" FontSize="16" Foreground="{DynamicResource Brush.TextPrimary}"
                                     TabIndex="0" KeyDown="Input_KeyDown"/>
                        </Border>

                        <!-- Mật khẩu -->
                        <TextBlock Text="Mật khẩu" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,6"/>
                        <Border Height="44" Margin="0,0,0,8"
                                Style="{DynamicResource MacFluent.InputFrame}">
                            <PasswordBox x:Name="PbPassword"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center"
                                         Padding="14,0" FontSize="16" Foreground="{DynamicResource Brush.TextPrimary}"
                                         TabIndex="1" KeyDown="Input_KeyDown"/>
                        </Border>

                         
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource Brush.Error}" FontSize="14" Margin="0,0,0,16"
                                   Visibility="{Binding ErrorMessage,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>

                        <!-- Nút đăng nhập — ControlTemplate để có CornerRadius -->
                        <Button Height="46"
                                Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=PbPassword}"
                                Cursor="Hand"
                                Style="{DynamicResource MacFluent.ButtonPrimary}">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Đăng nhập"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                <Setter Property="Text" Value="Đang xử lý..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <TextBlock Text="© 2026 Phạm Tấn Lợi · QLKS v1.0"
                                   FontSize="14" Foreground="{DynamicResource Brush.TextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,28,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>





