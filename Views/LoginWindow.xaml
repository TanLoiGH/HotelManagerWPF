<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:h="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
    Title="Đăng nhập - Quản Lý Khách Sạn"
    Width="900"
    Height="580"
    AllowsTransparency="False"
    Background="{DynamicResource Brush.Background}"
    Icon="/Themes/hotel.ico"
    KeyDown="Window_KeyDown"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="15"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>


    <Border ClipToBounds="True" MouseLeftButtonDown="Window_DragMove">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  ══ CỘT TRÁI: Gradient M365 ══  -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="{DynamicResource Color.Heading}" />
                        <GradientStop Offset="0.5" Color="{DynamicResource Color.BrandPrimary}" />

                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Ellipse
                        Width="280"
                        Height="280"
                        Margin="-80,-80,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Opacity="0.15">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Offset="0" Color="{DynamicResource Color.SurfacePrimary}" />
                                <GradientStop Offset="1" Color="Transparent" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Ellipse
                        Width="200"
                        Height="200"
                        Margin="0,0,-60,-60"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Opacity="0.12" />

                    <StackPanel
                        Margin="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                        <Border
                            Width="72"
                            Height="72"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Center"
                            CornerRadius="20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="{DynamicResource Color.SurfacePrimary}" />
                                    <GradientStop Offset="1" Color="{DynamicResource Color.BrandSoft}" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="38"
                                Text="🏨" />
                        </Border>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Quản Lý Khách Sạn"
                            TextAlignment="Center" />
                        <TextBlock
                            Margin="0,6,0,32"
                            HorizontalAlignment="Center"
                            FontSize="18"
                            Foreground="{DynamicResource Brush.TextSubtle}"
                            Text="Phạm Tấn Lợi"
                            TextAlignment="Center" />

                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <Border
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,12,0"
                                    CornerRadius="8">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        Foreground="{DynamicResource Brush.SurfaceSoft}"
                                        Text="📊" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Quản lý đặt phòng" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource Brush.TextSubtle}"
                                        Text="Theo dõi real-time" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <Border
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,12,0"
                                    CornerRadius="8">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        Foreground="{DynamicResource Brush.SurfaceSoft}"
                                        Text="💰" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Hóa đơn &amp; Doanh thu" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource Brush.TextSubtle}"
                                        Text="Báo cáo tài chính" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,12,0"
                                    CornerRadius="8">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        Foreground="{DynamicResource Brush.SurfaceSoft}"
                                        Text="👥" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Quản lý nhân viên" />
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource Brush.TextSubtle}"
                                        Text="Phân quyền linh hoạt" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

            <!--  ══ CỘT PHẢI: Form đăng nhập ══  -->
            <Border
                Grid.Column="1"
                Background="{DynamicResource Brush.Surface}"
                CornerRadius="0 20 20 0">
                <Grid>
                    <Button
                        Width="32"
                        Height="32"
                        Margin="0,20,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Content="✕"
                        Cursor="Hand"
                        Foreground="{DynamicResource Brush.TextSubtle}"
                        Style="{DynamicResource MacFluent.ButtonGhost}" />

                    <StackPanel Margin="56,0,56,0" VerticalAlignment="Center">

                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="Chào mừng trở lại 👋" />
                        <TextBlock
                            Margin="0,0,0,32"
                            FontSize="15"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            Text="Đăng nhập để tiếp tục" />

                        <!--  Tên đăng nhập  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Tên đăng nhập" />
                        <Border
                            Height="44"
                            Margin="0,0,0,16"
                            FocusManager.FocusedElement="{Binding ElementName=TxtUsername}"
                            Style="{DynamicResource MacFluent.InputFrame}">
                            <!--  Đặt con trỏ  -->
                            <TextBox
                                x:Name="TxtUsername"
                                Margin="8"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16"
                                Foreground="{DynamicResource Brush.TextPrimary}"
                                KeyDown="Input_KeyDown"
                                TabIndex="0"
                                Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>

                        <!--  Mật khẩu  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Mật khẩu" />
                        <Border
                            Height="44"
                            Margin="0,0,0,8"
                            Style="{DynamicResource MacFluent.InputFrame}">
                            <PasswordBox
                                x:Name="PbPassword"
                                Margin="8"
                                VerticalAlignment="Center"
                                h:PasswordBoxBinding.BoundPassword="{Binding MatKhau, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16"
                                Foreground="{DynamicResource Brush.TextPrimary}"
                                KeyDown="Input_KeyDown"
                                TabIndex="1" />
                        </Border>


                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.Error}"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                        <!--  Nút đăng nhập — ControlTemplate để có CornerRadius  -->
                        <Button
                            Height="44"
                            Margin="50,10,50,-15"
                            Click="LoginButton_Click"
                            Cursor="Hand"
                            IsDefault="True"
                            Style="{DynamicResource MacFluent.ButtonPrimary}">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Đăng nhập" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                <Setter Property="Text" Value="Đang xử lý..." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <TextBlock
                            Margin="0,28,0,0"
                            HorizontalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextSecondary}"
                            Text="© 2026 Phạm Tấn Lợi · QLKS v1.0" />
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>





