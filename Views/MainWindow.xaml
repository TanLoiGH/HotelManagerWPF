<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
        Title="Hotelify - Quản Lý Khách Sạn"
        Height="860" Width="1380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    

    <!-- Root border bo tròn -->
    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EAF4FB" Offset="0.0"/>
                <GradientStop Color="#D6EAF8" Offset="0.5"/>
                <GradientStop Color="#C9E6F5" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════
                 SIDEBAR TRÁI — Glassmorphism
            ══════════════════════════════════════════════════ -->
            <Border Grid.Column="0" CornerRadius="20 0 0 20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0C2D5A" Offset="0.0"/>
                        <GradientStop Color="#0F3D80" Offset="0.5"/>
                        <GradientStop Color="#0A2650" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- decorative circles -->
                    <Ellipse Width="260" Height="260"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-100,-130,0" Opacity="0.06">
                        <Ellipse.Fill><RadialGradientBrush>
                            <GradientStop Color="#00BCF2" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush></Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="180" Height="180"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-60,0,0,-60" Opacity="0.08">
                        <Ellipse.Fill><RadialGradientBrush>
                            <GradientStop Color="#0078D4" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush></Ellipse.Fill>
                    </Ellipse>

                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Logo -->
                            <RowDefinition Height="*"/>     <!-- Menu -->
                            <RowDefinition Height="Auto"/>  <!-- Profile -->
                        </Grid.RowDefinitions>

                        <!-- ── LOGO ── -->
                        <Border Grid.Row="0" Padding="24,28,24,20">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="12"
                                        Background="#1A5DA8">
                                    <TextBlock Text="🏨" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Hotelify"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="Hotel Management"
                                               FontSize="10" Foreground="#6FA8D0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── MENU ITEMS ── -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="16,0">

                                <!-- Section label -->
                                <TextBlock Text="TỔNG QUAN" FontSize="10" FontWeight="Bold"
                                           Foreground="#4A7FA5" Margin="8,8,0,8"/>

                                <Border x:Name="BtnDashboard"
                                        CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="#1E4D8C" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_Dashboard"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="QUẢN LÝ" FontSize="10" FontWeight="Bold"
                                           Foreground="#4A7FA5" Margin="8,16,0,8"/>

                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_Phong"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Phòng" FontSize="14"
                                                   Foreground="#B3D4EE" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_KhachHang"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👥" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Khách Hàng" FontSize="14"
                                                   Foreground="#B3D4EE" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="TÀI CHÍNH" FontSize="10" FontWeight="Bold"
                                           Foreground="#4A7FA5" Margin="8,16,0,8"/>

                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_HoaDon"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧾" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Hoá Đơn" FontSize="14"
                                                   Foreground="#B3D4EE" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>


                                <TextBlock Text="HỆ THỐNG" FontSize="10" FontWeight="Bold"
                                           Foreground="#4A7FA5" Margin="8,16,0,8"/>

                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_NhanVien"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🪪" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Nhân Viên" FontSize="14"
                                                   Foreground="#B3D4EE" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_NhaCungCap"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏭" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Nhà Cung Cấp" FontSize="14"
                                                   Foreground="#B3D4EE" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── PROFILE CARD ── -->
                        <Border Grid.Row="2" Margin="16,0,16,16" CornerRadius="14" Padding="14,12"
                                Background="#0A2040">
                            <Border.BorderBrush><SolidColorBrush Color="#1A4A7A"/></Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding WelcomeMessage}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding MaQuyen}"
                                               FontSize="11" Foreground="#6FA8D0" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="↩" Width="32" Height="32"
                                        FontSize="16" Foreground="#FF6B6B"
                                        Background="#1A0808" BorderThickness="0"
                                        ToolTip="Đăng xuất" Cursor="Hand"
                                        Click="Logout_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="8" Background="#1A1A2E"
                                                    Width="32" Height="32">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3A1A1A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 NỘI DUNG PHẢI — Content Area
            ══════════════════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Background="#F0F7FD" Padding="24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtPageTitle"
                                   Text="Dashboard"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#0F3460"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding NgayHienTai}"
                                       FontSize="12" Foreground="#888"
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <!-- Drag zone -->
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="#E4EEF7" Cursor="Hand"
                                    ToolTip="Di chuyển cửa sổ"
                                    MouseLeftButtonDown="TitleBar_DragMove">
                                <TextBlock Text="⠿" FontSize="16" Foreground="#888"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="#E4EEF7" Cursor="Hand" Margin="8,0,0,0"
                                    MouseLeftButtonDown="CloseWindow_Click" ToolTip="Đóng">
                                <TextBlock Text="✕" FontSize="13" Foreground="#999"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content Frame -->
                <Frame x:Name="ContentFrame"
                       Grid.Row="1"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </Grid>

        </Grid>
    </Border>
</Window>
