<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
    Title="Banana - Quản Lý Khách Sạn"
    Width="1680"
    Height="960"
    AllowsTransparency="False"
    Background="{DynamicResource Brush.Background}"
    Icon="/Themes/hotel.ico"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="15"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!--  Root border bo tròn  -->
    <Border ClipToBounds="True" CornerRadius="20">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Color.Background}" />
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--
                ══════════════════════════════════════════════════
                SIDEBAR TRÁI — Dark Navigation
                ══════════════════════════════════════════════════
            -->
            <Border
                Grid.Column="0"
                Background="{DynamicResource Brush.SidebarBackground}"
                BorderBrush="{DynamicResource Brush.SidebarBorder}"
                BorderThickness="0,0,1,0">

                <Border.Resources>
                    <!--  Default nav typography/icons: avoids dark TextPrimary on dark sidebar  -->
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.SidebarText}" />
                        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Border.Resources>

                <Grid>
                    <!--  decorative circles (optional, reduced opacity)  -->
                    <Ellipse
                        Width="260"
                        Height="260"
                        Margin="0,-100,-130,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Opacity="0.03">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Offset="0" Color="{DynamicResource Color.BrandPrimary}" />
                                <GradientStop Offset="1" Color="Transparent" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  Logo  -->
                            <RowDefinition Height="Auto" />
                            <!--  Profile Card  -->
                            <RowDefinition Height="*" />
                            <!--  Menu (scrollable)  -->
                            <RowDefinition Height="Auto" />
                            <!--  Settings Button  -->
                        </Grid.RowDefinitions>

                        <!--  ── LOGO ── ad  -->
                        <Border Grid.Row="0" Padding="24,28,24,20">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="{DynamicResource Brush.SidebarActive}"
                                    CornerRadius="12">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="22"
                                        Text="🏨" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.SidebarText}"
                                        Text="Banana" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource Brush.SidebarTextMuted}"
                                        Text="Hotel Management" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  ── PROFILE CARD (Đưa lên ngay dưới Logo) ──  -->
                        <Border
                            Grid.Row="1"
                            Margin="16,8,16,16"
                            Padding="14,12"
                            Background="{DynamicResource Brush.SidebarSurface}"
                            BorderBrush="{DynamicResource Brush.SidebarBorder}"
                            BorderThickness="1"
                            CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Brush.SidebarText}"
                                        Text="{Binding WelcomeMessage}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource Brush.SidebarTextMuted}"
                                        Text="{Binding MaQuyen}" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Width="30"
                                    Height="30"
                                    Click="Logout_Click"
                                    Content="⏻"
                                    Cursor="Hand"
                                    Style="{DynamicResource MacFluent.IconButton.Danger}"
                                    ToolTip="Đăng xuất" />
                            </Grid>
                        </Border>

                        <!--  ── SIDEBAR MENU ITEMS (Scrollable) ──  -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="16,0">

                                <!--  =====================  -->
                                <!--  DASHBOARD (Trang chính)  -->
                                <!--  =====================  -->
                                <Border
                                    x:Name="BtnDashboard"
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="{DynamicResource Brush.SidebarActive}"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_Dashboard">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="📊" />
                                        <TextBlock FontWeight="SemiBold" Text="Dashboard" />
                                    </StackPanel>
                                </Border>

                                <!--  Báo Cáo  -->
                                <Border
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_BaoCao">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="📈" />
                                        <TextBlock Text="Báo Cáo" />
                                    </StackPanel>
                                </Border>

                                <!--  =====================  -->
                                <!--  LỄ TÂN  -->
                                <!--  =====================  -->
                                <TextBlock
                                    Margin="12,20,0,8"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.SidebarTextMuted}"
                                    Opacity="0.6"
                                    Text="LỄ TÂN" />

                                <!--  Phòng  -->
                                <Border
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_Phong">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="🛏️" />
                                        <TextBlock Text="Sơ đồ Phòng" />
                                    </StackPanel>
                                </Border>

                                <!--  Hoá Đơn  -->
                                <Border
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_HoaDon">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="🧾" />
                                        <TextBlock Text="Hoá Đơn" />
                                    </StackPanel>
                                </Border>

                                <!--  =====================  -->
                                <!--  ADMIN  -->
                                <!--  =====================  -->
                                <StackPanel x:Name="AdminSection">
                                    <TextBlock
                                        Margin="12,20,0,8"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.SidebarTextMuted}"
                                        Opacity="0.8"
                                        Text="QUẢN TRỊ VIÊN" />

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_NhanVien">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="🧑🏻‍🤝‍🧑" />
                                            <TextBlock Text="Nhân Viên" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_LoaiKhach">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="💎" />
                                            <TextBlock Text="Loại Khách" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_KhachHang">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="👥" />
                                            <TextBlock Text="Khách Hàng" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_LoaiPhong">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="🏷️" />
                                            <TextBlock Text="Loại Phòng" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_QuanTriPhong">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="🏠" />
                                            <TextBlock Text="Phòng" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_NhaCungCap">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="🏭" />
                                            <TextBlock Text="Nhà Cung Cấp" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_DanhMucTienNghi">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="🧰" />
                                            <TextBlock Text="DM Tiện Nghi" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_DichVu">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="⭐" />
                                            <TextBlock Text="Dịch vụ" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_PhuongThucThanhToan">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="💳" />
                                            <TextBlock Text="PT Thanh Toán" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,2"
                                        Padding="14,12"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        Cursor="Hand"
                                        MouseEnter="NavItem_MouseEnter"
                                        MouseLeave="NavItem_MouseLeave"
                                        MouseLeftButtonDown="Nav_LoaiChiPhi">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,12,0" Text="💸" />
                                            <TextBlock Text="Loại Chi Phí" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!--  =====================  -->
                                <!--  QUẢN LÝ  -->
                                <!--  =====================  -->
                                <TextBlock
                                    Margin="12,20,0,8"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.SidebarTextMuted}"
                                    Opacity="0.6"
                                    Text="QUẢN LÝ" />

                                <!--  Chi Phí  -->
                                <Border
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_ChiPhi">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="💸" />
                                        <TextBlock Text="Chi Phí" />
                                    </StackPanel>
                                </Border>

                                <!--  Khuyến Mãi  -->
                                <Border
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_KhuyenMai">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="🎁" />
                                        <TextBlock Text="Khuyến Mãi" />
                                    </StackPanel>
                                </Border>

                                <!--  Tiện Nghi  -->
                                <Border
                                    Margin="0,2"
                                    Padding="14,12"
                                    Background="Transparent"
                                    CornerRadius="12"
                                    Cursor="Hand"
                                    MouseEnter="NavItem_MouseEnter"
                                    MouseLeave="NavItem_MouseLeave"
                                    MouseLeftButtonDown="Nav_TienNghi">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="🛏️" />
                                        <TextBlock Text="Tiện Nghi" />
                                    </StackPanel>
                                </Border>

                                <TextBlock
                                    Margin="12,20,0,8"
                                    DockPanel.Dock="Left"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.SidebarTextMuted}"
                                    Opacity="0.8" />

                            </StackPanel>
                        </ScrollViewer>

                        <!--  ── CÀI ĐẶT (Đặt dưới cùng, ngoài scroll) ──  -->
                        <Border
                            Grid.Row="3"
                            Margin="16,0,16,16"
                            Padding="15"
                            Background="#F2474B54"
                            CornerRadius="15"
                            Cursor="Hand"
                            MouseEnter="NavItem_MouseEnter"
                            MouseLeave="NavItem_MouseLeave"
                            MouseLeftButtonDown="Nav_CaiDat">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="40,0,10,0"
                                    FontSize="25"
                                    Text="⛭"
                                    TextAlignment="Center" />
                                <TextBlock FontWeight="SemiBold" Text="Cài đặt" />
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!--
                ══════════════════════════════════════════════════
                NỘI DUNG PHẢI — Content Area (giữ nguyên)
                ══════════════════════════════════════════════════
            -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Top Bar  -->
                <Border
                    Grid.Row="0"
                    Padding="24,0"
                    Background="{DynamicResource Brush.Surface}"
                    Cursor="Hand"
                    MouseLeftButtonDown="TitleBar_DragMove"
                    ToolTip="Di chuyển cửa sổ">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="TxtPageTitle"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.TextHeading}"
                            Text="Dashboard" />

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,600,0"
                                VerticalAlignment="Center"
                                FontSize="17"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="{Binding NgayHienTai}" />

                            <Border
                                Width="32"
                                Height="32"
                                Margin="8,0,0,0"
                                Background="{DynamicResource Brush.SurfaceSoft}"
                                CornerRadius="8"
                                Cursor="Hand"
                                MouseLeftButtonDown="CloseWindow_Click"
                                ToolTip="Đóng">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{DynamicResource Brush.TextMuted}"
                                    Text="✕" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Page Content Frame  -->
                <Frame
                    x:Name="ContentFrame"
                    Grid.Row="1"
                    Background="Transparent"
                    NavigationUIVisibility="Hidden" />
            </Grid>

        </Grid>
    </Border>
</Window>
