<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Banana - Quản Lý Khách Sạn"
        Height="960" Width="1680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Background}"
        ResizeMode="CanResizeWithGrip"
        Icon="/Themes/hotel.ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="15"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!-- Root border bo tròn -->
    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Color.Background}" />
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════
                 SIDEBAR TRÁI — Dark Navigation
            ══════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.SidebarBackground}"
                    BorderBrush="{DynamicResource Brush.SidebarBorder}"
                    BorderThickness="0,0,1,0">

                <Border.Resources>
                    <!-- Default nav typography/icons: avoids dark TextPrimary on dark sidebar -->
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.SidebarText}" />
                        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Border.Resources>

                <Grid>
                    <!-- decorative circles (optional, reduced opacity) -->
                    <Ellipse Width="260" Height="260"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-100,-130,0" Opacity="0.03">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{DynamicResource Color.BrandPrimary}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Logo -->
                            <RowDefinition Height="Auto"/>
                            <!-- Profile Card -->
                            <RowDefinition Height="*"/>
                            <!-- Menu (scrollable) -->
                            <RowDefinition Height="Auto"/>
                            <!-- Settings Button -->
                        </Grid.RowDefinitions>

                        <!-- ── LOGO ── ad --> 
                        <Border Grid.Row="0" Padding="24,28,24,20">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="12"
                                        Background="{DynamicResource Brush.SidebarActive}">
                                    <TextBlock Text="🏨" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Banana"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource Brush.SidebarText}"/>
                                    <TextBlock Text="Hotel Management"
                                               FontSize="12" Foreground="{DynamicResource Brush.SidebarTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── PROFILE CARD (Đưa lên ngay dưới Logo) ── -->
                        <Border Grid.Row="1" Margin="16,8,16,16" CornerRadius="14" Padding="14,12"
                                Background="{DynamicResource Brush.SidebarSurface}"
                                BorderBrush="{DynamicResource Brush.SidebarBorder}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding WelcomeMessage}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.SidebarText}" 
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding MaQuyen}"
                                               FontSize="12" Foreground="{DynamicResource Brush.SidebarTextMuted}" 
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Content="out"
                                        Width="40"
                                        Height="30"
                                        ToolTip="Đăng xuất"
                                        Cursor="Hand"
                                        Style="{DynamicResource MacFluent.IconButton.Danger}"
                                        Click="Logout_Click"/>
                            </Grid>
                        </Border>

                        <!-- ── SIDEBAR MENU ITEMS (Scrollable) ── -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="16,0">

                                <!-- ===================== -->
                                <!-- DASHBOARD (Trang chính) -->
                                <!-- ===================== -->
                                <Border x:Name="BtnDashboard"
                                        CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="{DynamicResource Brush.SidebarActive}" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_Dashboard"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" Margin="0,0,12,0"/>
                                        <TextBlock Text="Dashboard" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <!-- Báo Cáo -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_BaoCao"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📈" Margin="0,0,12,0"/>
                                        <TextBlock Text="Báo Cáo"/>
                                    </StackPanel>
                                </Border>

                                <!-- ===================== -->
                                <!-- LỄ TÂN -->
                                <!-- ===================== -->
                                <TextBlock Text="LỄ TÂN"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.SidebarTextMuted}" 
                                           Margin="12,20,0,8" Opacity="0.6"/>

                                <!-- Phòng -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_Phong"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" Margin="0,0,12,0"/>
                                        <TextBlock Text="Phòng"/>
                                    </StackPanel>
                                </Border>

                                <!-- Hoá Đơn -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_HoaDon"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧾" Margin="0,0,12,0"/>
                                        <TextBlock Text="Hoá Đơn"/>
                                    </StackPanel>
                                </Border>

                                <!-- ===================== -->
                                <!-- ADMIN -->
                                <!-- ===================== -->
                                <StackPanel x:Name="AdminSection">
                                    <TextBlock Text="HỆ THỐNG"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource Brush.SidebarTextMuted}" 
                                               Margin="12,20,0,8" Opacity="0.6"/>

                                    <!-- Dịch vụ -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_QuanTriPhong"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⭐" Margin="0,0,12,0"/>
                                            <TextBlock Text="Phòng"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Dịch vụ -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_DichVu"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⭐" Margin="0,0,12,0"/>
                                            <TextBlock Text="Dịch vụ"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Loại chi phí -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_LoaiChiPhi"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💸" Margin="0,0,12,0"/>
                                            <TextBlock Text="Loại Chi Phí"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Phương thức thanh toán -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_PhuongThucThanhToan"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💳" Margin="0,0,12,0"/>
                                            <TextBlock Text="PT Thanh Toán"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Danh mục tiện nghi -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_DanhMucTienNghi"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🧰" Margin="0,0,12,0"/>
                                            <TextBlock Text="DM Tiện Nghi"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Khách Hàng -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_KhachHang"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👥" Margin="0,0,12,0"/>
                                            <TextBlock Text="Khách Hàng"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Loại Khách -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_LoaiKhach"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💎" Margin="0,0,12,0"/>
                                            <TextBlock Text="Loại Khách"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Loại Phòng -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_LoaiPhong"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏷️" Margin="0,0,12,0"/>
                                            <TextBlock Text="Loại Phòng"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Nhà Cung Cấp -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_NhaCungCap"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏭" Margin="0,0,12,0"/>
                                            <TextBlock Text="Nhà Cung Cấp"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Nhân Viên -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="Nav_NhanVien"
                                            MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💼" Margin="0,0,12,0"/>
                                            <TextBlock Text="Nhân Viên"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===================== -->
                                <!-- QUẢN LÝ -->
                                <!-- ===================== -->
                                <TextBlock Text="QUẢN LÝ"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.SidebarTextMuted}" 
                                           Margin="12,20,0,8" Opacity="0.6"/>

                                <!-- Chi Phí -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_ChiPhi"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💸" Margin="0,0,12,0"/>
                                        <TextBlock Text="Chi Phí"/>
                                    </StackPanel>
                                </Border>

                                <!-- Khuyến Mãi -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_KhuyenMai"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎁" Margin="0,0,12,0"/>
                                        <TextBlock Text="Khuyến Mãi"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tiện Nghi -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                                        Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="Nav_TienNghi"
                                        MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🛏️" Margin="0,0,12,0"/>
                                        <TextBlock Text="Tiện Nghi"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── CÀI ĐẶT (Đặt dưới cùng, ngoài scroll) ── -->
                        <Border Grid.Row="3" Margin="16,0,16,16" CornerRadius="15" Padding="15"
                                 Cursor="Hand"
                                Background="#F2474B54"
                                MouseLeftButtonDown="Nav_CaiDat"
                                MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⛭" Margin="40,0,10,0" FontSize="25" TextAlignment="Center"/>
                                <TextBlock Text="Cài đặt" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 NỘI DUNG PHẢI — Content Area (giữ nguyên)
            ══════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="24,0"
                        MouseLeftButtonDown="TitleBar_DragMove"
                        Cursor="Hand"
                        ToolTip="Di chuyển cửa sổ">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtPageTitle"
                                   Text="Dashboard"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.TextHeading}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding NgayHienTai}"
                                       FontSize="17" Foreground="{DynamicResource Brush.TextMuted}"
                                       VerticalAlignment="Center" Margin="0,0,600,0"/>

                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{DynamicResource Brush.SurfaceSoft}" Cursor="Hand" Margin="8,0,0,0"
                                    MouseLeftButtonDown="CloseWindow_Click" ToolTip="Đóng">
                                <TextBlock Text="✕" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content Frame -->
                <Frame x:Name="ContentFrame"
                       Grid.Row="1"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </Grid>

        </Grid>
    </Border>
</Window>
