<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="815" Width="1372">
    <Grid>
        <!-- Chia layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                   CornerRadius="24"
                   Padding="20"
                   BorderThickness="1"
                   BorderBrush="#66FFFFFF" Margin="0,-39,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#B3FFFFFF" Offset="0"/>
                        <GradientStop Color="#7ADCEBFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26"
                                     ShadowDepth="0"
                                     Opacity="0.22"
                                     Color="#5A7FB7"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="34" Height="34" Fill="#4D5DA8FF"/>
                        <TextBlock Text="Hotelfiy"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  FontSize="22"
                                  FontWeight="SemiBold"
                                  Foreground="#1F2F50"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">

                        <Border CornerRadius="12" Padding="12,10" Background="#66FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="KHÁCH HÀNG"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open_KHACH_HANG"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="PHÒNG"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-PHONG"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="ĐẶT PHÒNG"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-DAT_PHONG"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="DỊCH VỤ"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-DICH_VU"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="HOÁ ĐƠN"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-HOA_DON"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="THANH TOÁN"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-THANH_TOAN"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="NHÂN VIÊN"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-NHAN_VIEN"/>
                        </Border>

                        <Border CornerRadius="12" Padding="12,10" Background="#45FFFFFF" Margin="0,0,0,8">
                            <TextBlock Text="NHÀ CUNG CẤP"
                   FontSize="16"
                   Foreground="#2E4068"
                   MouseDown="Open-NHA_CUNG_CAP"/>
                        </Border>

                    </StackPanel>

                    <Border Grid.Row="2"
                           CornerRadius="16"
                           Padding="14"
                           BorderBrush="#73FFFFFF"
                           BorderThickness="1"
                           Background="#5EFFFFFF" RenderTransformOrigin="0.5,0.5" Margin="0,556,0,0" Height="92" VerticalAlignment="Top">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform Y="20"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="{Binding WelcomeMessage}"
                                      TextWrapping="Wrap"
                                      FontWeight="SemiBold"
                                      Foreground="#2C3F65"/>
                            <Button Content="Logout"
                                   Margin="0,12,0,0"
                                   Height="34"
                                   BorderThickness="0"
                                   Foreground="Azure"
                                   FontWeight="SemiBold" Background="#FFEF3434" Width="90"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            
            <Border Grid.Column="2"
                   CornerRadius="20"
                   Padding="24"
                   Background="#CCFFFFFF"
                   BorderBrush="#66FFFFFF"
                   BorderThickness="1" Margin="0,-39,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                     ShadowDepth="0"
                                     Opacity="0.12"
                                     Color="#4C5D80"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Rooms"
                              FontSize="30"
                              FontWeight="Bold"
                              Foreground="#213253"/>
                    <TextBlock Text="Glassmorphism sidebar đã được áp dụng cho giao diện chính."
                              Margin="0,8,0,0"
                              FontSize="16"
                              Foreground="#4B5F82"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
