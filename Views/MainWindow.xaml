<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Hotelify - Quản Lý Khách Sạn"
        Height="960" Width="1680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Background}"
        ResizeMode="CanResizeWithGrip">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="20"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    

    <!-- Root border bo tròn -->
    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EAF4FB" Offset="0.0"/>
                <GradientStop Color="#D6EAF8" Offset="0.5"/>
                <GradientStop Color="#C9E6F5" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════
                 SIDEBAR TRÁI — Glassmorphism
            ══════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.NavGradient}">

                <Border.Resources>
                    <!-- Default nav typography/icons: avoids dark TextPrimary on dark sidebar -->
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.NavText}" />
                        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Border.Resources>

                <Grid>
                    <!-- decorative circles -->
                    <Ellipse Width="260" Height="260"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-100,-130,0" Opacity="0.06">
                        <Ellipse.Fill><RadialGradientBrush>
                            <GradientStop Color="{DynamicResource Color.BrandSecondary}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush></Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="180" Height="180"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-60,0,0,-60" Opacity="0.08">
                        <Ellipse.Fill><RadialGradientBrush>
                            <GradientStop Color="{DynamicResource Color.BrandPrimary}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush></Ellipse.Fill>
                    </Ellipse>

                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Logo -->
                            <RowDefinition Height="*"/>     <!-- Menu -->
                            <RowDefinition Height="Auto"/>  <!-- Profile -->
                        </Grid.RowDefinitions>

                        <!-- ── LOGO ── -->
                        <Border Grid.Row="0" Padding="24,28,24,20">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="12"
                                        Background="{DynamicResource Brush.NavChip}">
                                    <TextBlock Text="🏨" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Hotelify"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource Brush.NavText}"/>
                                    <TextBlock Text="Hotel Management"
                                               FontSize="12" Foreground="{DynamicResource Brush.NavMuted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── SIDEBAR MENU ITEMS ── -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="16,0">

                                <!-- ===================== -->
                                <!-- DASHBOARD (Trang chính) -->
                                <!-- ===================== -->
                                <Border x:Name="BtnDashboard"
                 CornerRadius="12" Padding="14,12" Margin="0,2"
                 Background="{DynamicResource Brush.NavSelected}" Cursor="Hand"
                 MouseLeftButtonDown="Nav_Dashboard"
                 MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊"/>
                                        <TextBlock Text="Dashboard"/>
                                    </StackPanel>
                                </Border>

                                <!-- ===================== -->
                                <!-- LỄ TÂN -->
                                <!-- ===================== -->
                                <TextBlock Text="Lễ Tân"
                   FontSize="{StaticResource Font.Size.Caption}" FontWeight="Bold"
                   Foreground="{DynamicResource Brush.NavMuted}" Margin="8,8,0,8"/>

                                <!-- Phòng -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                Background="Transparent" Cursor="Hand"
                MouseLeftButtonDown="Nav_Phong"
                MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠"/>
                                        <TextBlock Text="Phòng"/>
                                    </StackPanel>
                                </Border>

                                <!-- Hoá Đơn -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                Background="Transparent" Cursor="Hand"
                MouseLeftButtonDown="Nav_HoaDon"
                MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧾"/>
                                        <TextBlock Text="Hoá Đơn"/>
                                    </StackPanel>
                                </Border>

                                <!-- ===================== -->
                                <!-- ADMIN -->
                                <!-- ===================== -->
                                <StackPanel x:Name="AdminSection">
                                    <TextBlock Text="Admin"
                       FontSize="{StaticResource Font.Size.Caption}" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.NavGroupLabel}" Margin="8,8,0,8"/>

                                    <!-- Dịch vụ (CRUD danh mục) -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                   Background="Transparent" Cursor="Hand"
                   MouseLeftButtonDown="Nav_DichVu"
                   MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⭐"/>
                                            <TextBlock Text="Dịch vụ"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Loại chi phí (CRUD) -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                   Background="Transparent" Cursor="Hand"
                   MouseLeftButtonDown="Nav_LoaiChiPhi"
                   MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💸"/>
                                            <TextBlock Text="Loại Chi Phí"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Phương thức thanh toán (CRUD) -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                   Background="Transparent" Cursor="Hand"
                   MouseLeftButtonDown="Nav_PhuongThucThanhToan"
                   MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💳"/>
                                            <TextBlock Text="PT Thanh Toán"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Danh mục tiện nghi (CRUD) -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                   Background="Transparent" Cursor="Hand"
                   MouseLeftButtonDown="Nav_DanhMucTienNghi"
                   MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🧰"/>
                                            <TextBlock Text="DM Tiện Nghi"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Khách Hàng -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonDown="Nav_KhachHang"
                    MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👥"/>
                                            <TextBlock Text="Khách Hàng"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Loại Khách -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonDown="Nav_LoaiKhach"
                    MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⭐"/>
                                            <TextBlock Text="Loại Khách"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Loại Phòng -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonDown="Nav_LoaiPhong"
                    MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏷️"/>
                                            <TextBlock Text="Loại Phòng"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Nhà Cung Cấp -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonDown="Nav_NhaCungCap"
                    MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏭"/>
                                            <TextBlock Text="Nhà Cung Cấp"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Nhân Viên -->
                                    <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                    Background="Transparent" Cursor="Hand"
                    MouseLeftButtonDown="Nav_NhanVien"
                    MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🪪"/>
                                            <TextBlock Text="Nhân Viên"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===================== -->
                                <!-- KHÁC -->
                                <!-- ===================== -->
                                <TextBlock Text="Khác"
                   FontSize="12" FontWeight="Bold"
                   Foreground="#4A7FA5" Margin="8,16,0,8"/>

                                <!-- Chi Phí -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                Background="Transparent" Cursor="Hand"
                MouseLeftButtonDown="Nav_ChiPhi"
                MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💸"/>
                                        <TextBlock Text="Chi Phí"/>
                                    </StackPanel>
                                </Border>

                                <!-- Khuyến Mãi -->
                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                Background="Transparent" Cursor="Hand"
                MouseLeftButtonDown="Nav_KhuyenMai"
                MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎁"/>
                                        <TextBlock Text="Khuyến Mãi"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="12" Padding="14,12" Margin="0,2"
                Background="Transparent" Cursor="Hand"
                MouseLeftButtonDown="Nav_TienNghi"
                MouseEnter="NavItem_MouseEnter" MouseLeave="NavItem_MouseLeave">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text=" #"/>
                                        <TextBlock Text="Tiện Nghi"/>
                                    </StackPanel>
                                </Border>



                            </StackPanel>
                        </ScrollViewer>
                        <!-- ── PROFILE CARD ── -->
                        <Border Grid.Row="2" Margin="16,0,16,16" CornerRadius="14" Padding="14,12"
                                Background="{DynamicResource Brush.NavProfileBg}"
                                BorderBrush="{DynamicResource Brush.NavHover}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding WelcomeMessage}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.NavText}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding MaQuyen}"
                                               FontSize="13" Foreground="{DynamicResource Brush.NavMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                                Content="↩"
                                                Width="30"
                                                Height="30"
                                                ToolTip="Đăng xuất"
                                                Cursor="Hand"
                                                Style="{DynamicResource MacFluent.IconButton.Danger}"
                                               
                                                Click="Logout_Click"/>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════
                 NỘI DUNG PHẢI — Content Area
            ══════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Background="{DynamicResource Brush.SurfaceAlt}" Padding="24,0"
                        MouseLeftButtonDown="TitleBar_DragMove" CornerRadius="20"
                        Cursor="Hand"
                        ToolTip="Di chuyển cửa sổ">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtPageTitle"
                                   Text="Dashboard"
                                   FontSize="{StaticResource Font.Size.Title}" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Heading}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding NgayHienTai}"
                                       FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                            
                            
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="#E4EEF7" Cursor="Hand" Margin="8,0,0,0"
                                    MouseLeftButtonDown="CloseWindow_Click" ToolTip="Đóng">
                                <TextBlock Text="✕" FontSize="15" Foreground="{DynamicResource Brush.TextSubtle}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content Frame -->
                <Frame x:Name="ContentFrame"
                       Grid.Row="1"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </Grid>

        </Grid>
    </Border>
</Window>




