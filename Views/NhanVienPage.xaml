<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.NhanVienPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Nhân Viên">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="14" Background="White" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtTongNV" FontSize="14" FontWeight="Bold"
                           Foreground="#0F3460" VerticalAlignment="Center"/>
                <Border Grid.Column="1" CornerRadius="10" BorderBrush="#E0EAF4"
                        BorderThickness="1.5" Padding="10,0" Height="36">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtSearch" BorderThickness="0"
                                 Background="Transparent" VerticalAlignment="Center"
                                 FontSize="13" Width="160"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="16" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <DataGrid x:Name="NVGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="13"
                      BorderThickness="0" Padding="8" RowHeight="44">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NV" Binding="{Binding MaNhanVien}" Width="90"/>
                    <DataGridTextColumn Header="Tên nhân viên" Binding="{Binding TenNhanVien}" Width="*"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu}" Width="130"/>
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding DienThoai}" Width="120"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TenTrangThai}" Width="110"/>
                    <DataGridTextColumn Header="Quyền" Binding="{Binding QuyenText}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>