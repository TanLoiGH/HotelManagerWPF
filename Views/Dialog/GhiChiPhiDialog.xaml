<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.GhiChiPhiDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ghi Chi Phí" Width="460" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <StackPanel Margin="24">

        <TextBlock Text="Loại chi phí" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
        <ComboBox x:Name="CboLoaiCP" Height="34" FontSize="15" Margin="0,0,0,12"/>

        <TextBlock Text="Mô tả chi phí" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="36" Margin="0,0,0,12">
            <TextBox x:Name="TxtTenChiPhi" BorderThickness="0" Padding="10,0"
                     VerticalAlignment="Center" FontSize="15"
                     />
        </Border>

        <TextBlock Text="Số tiền (₫)" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="36" Margin="0,0,0,12">
            <TextBox x:Name="TxtSoTien" BorderThickness="0" Padding="10,0"
                     VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"
                     TextAlignment="Right"/>
        </Border>

        <TextBlock Text="Nhà cung cấp (nếu có)" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
        <ComboBox x:Name="CboNCC" Height="34" FontSize="15" Margin="0,0,0,12"/>

        <TextBlock Text="Phòng liên quan (nếu sửa chữa)" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
        <ComboBox x:Name="CboPhong" Height="34" FontSize="15" Margin="0,0,0,12"/>

        <TextBlock Text="Ghi chú" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Margin="0,0,0,20">
            <TextBox x:Name="TxtGhiChu" BorderThickness="0" Padding="10,6"
                     FontSize="15" Height="52" AcceptsReturn="True" TextWrapping="Wrap"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Hủy" Height="38" FontSize="15"
                    Click="BtnHuy_Click" Background="#F5F5F5" BorderThickness="0"/>
            <Button Grid.Column="2" Content="Lưu chi phí" Height="38" FontSize="15"
                    FontWeight="SemiBold" Foreground="White" Background="#E17055"
                    BorderThickness="0" Click="BtnLuu_Click"/>
        </Grid>
    </StackPanel>
</Window>


