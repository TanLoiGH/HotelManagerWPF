<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.TienNghiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Tiện Nghi">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" CornerRadius="14" Background="White" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Phòng" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboPhong" Height="34" FontSize="13"
                              SelectionChanged="CboPhong_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Cập nhật trạng thái" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboTrangThai" Height="34" FontSize="13"/>
                </StackPanel>

                <TextBlock x:Name="TxtAlert" Grid.Column="3" FontSize="13"
                           Foreground="#E17055" VerticalAlignment="Center"
                           Margin="16,0" Visibility="Collapsed"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="Cập nhật" Height="34" Padding="16,0" FontSize="13"
                            Background="#0078D4" Foreground="White" BorderThickness="0"
                            Click="BtnCapNhat_Click" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Chi phí sửa chữa (₫)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" BorderBrush="#DDE" BorderThickness="1.5">
                                <TextBox x:Name="TxtChiPhiSuaChua" BorderThickness="0" Padding="8,0"
                                         VerticalAlignment="Center" FontSize="13" Height="30"/>
                            </Border>
                            <Button Grid.Column="2" Content="Ghi" Height="30" Padding="10,0"
                                    FontSize="13" Background="#E17055" Foreground="White"
                                    BorderThickness="0" Click="BtnGhiSuaChua_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid tiện nghi -->
        <Border Grid.Row="2" CornerRadius="16" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <DataGrid x:Name="TienNghiGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="13"
                      BorderThickness="0" Padding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên tiện nghi" Binding="{Binding TenTienNghi}" Width="*"/>
                    <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding TenNCC}" Width="160"/>
                    <DataGridTextColumn Header="Hạn bảo hành" Binding="{Binding HanBaoHanhText}" Width="120"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TenTrangThai}" Width="130"/>
                    <DataGridCheckBoxColumn Header="Cần bảo trì" Binding="{Binding CanBaoTri}" Width="90"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanBaoTri}" Value="True">
                                <Setter Property="Background" Value="#FFF3E0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
    </Grid>
</Page>
