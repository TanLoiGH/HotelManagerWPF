<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DichVuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Dịch Vụ">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <Border Grid.Column="0" CornerRadius="16" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="16,12" BorderBrush="#F0F5FA"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTongDV" FontSize="14" FontWeight="Bold"
                                       Foreground="#0F3460" VerticalAlignment="Center"/>
                            <Border CornerRadius="8" Padding="10,0" Height="34"
                                    BorderBrush="#E0EAF4" BorderThickness="1.5" Margin="16,0,0,0" Width="180">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtSearch" BorderThickness="0"
                                             Background="Transparent" VerticalAlignment="Center"
                                             FontSize="13" TextChanged="TxtSearch_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1" Content="➕  Thêm dịch vụ"
                                Height="36" Padding="16,0" FontSize="13"
                                FontWeight="SemiBold" Foreground="White"
                                Background="#0078D4" BorderThickness="0" Cursor="Hand"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="DvGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="13"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="DvGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã DV" Binding="{Binding MaDichVu}" Width="90"/>
                        <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding TenDichVu}" Width="*"/>
                        <DataGridTextColumn Header="Giá" Binding="{Binding GiaText}" Width="120"/>
                        <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh}" Width="90"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,3" Margin="4"
                                            Background="{Binding ActiveColor}" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ActiveText}"
                                                   FontSize="11" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0F7FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Form thêm/sửa -->
        <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Chi tiết dịch vụ"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#0F3460" Margin="0,0,0,20"/>

                <!-- Empty state -->
                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock Text="🍽️" FontSize="48" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                    <TextBlock Text="Chọn dịch vụ hoặc bấm Thêm mới"
                               FontSize="13" Foreground="#AAA"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <!-- Form -->
                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock Text="Tên dịch vụ *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="13"/>
                    </Border>

                    <TextBlock Text="Giá (₫) *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtGia" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="13" TextAlignment="Right"/>
                    </Border>

                    <TextBlock Text="Đơn vị tính" FontSize="12" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtDonVi" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="13"/>
                    </Border>

                    <CheckBox x:Name="ChkActive" Content="Đang hoạt động"
                              IsChecked="True" FontSize="13" Margin="0,0,0,20"/>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                Height="38" FontSize="13" Foreground="#E74C3C"
                                Background="#FEF0F0" BorderThickness="0" Cursor="Hand"
                                Click="BtnXoa_Click"/>
                        <Button Grid.Column="2" x:Name="BtnLuu" Content="💾 Lưu"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" Background="#0078D4"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnLuu_Click"/>
                    </Grid>

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>