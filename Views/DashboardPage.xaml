<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Title="Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,20,28,28">

            <!-- ── Stats Cards Row ──────────────────────────── -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card: Tổng phòng -->
                <Border Grid.Column="0" CornerRadius="16" Padding="20" Height="110">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0078D4" Offset="0"/>
                            <GradientStop Color="#00BCF2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Tổng Phòng" FontSize="12" Foreground="#CCE8FF"/>
                        <TextBlock x:Name="TxtTongPhong" Grid.Row="1"
                                   Text="—" FontSize="36" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Text="🏠 Tất cả phòng" FontSize="11" Foreground="#CCE8FF"/>
                    </Grid>
                </Border>

                <!-- Card: Phòng trống -->
                <Border Grid.Column="2" CornerRadius="16" Padding="20" Height="110">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00B894" Offset="0"/>
                            <GradientStop Color="#00CEC9" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#00B894" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Phòng Trống" FontSize="12" Foreground="#B2EBE0"/>
                        <TextBlock x:Name="TxtPhongTrong" Grid.Row="1"
                                   Text="—" FontSize="36" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Text="✅ Sẵn sàng đón khách" FontSize="11" Foreground="#B2EBE0"/>
                    </Grid>
                </Border>

                <!-- Card: Đang sử dụng -->
                <Border Grid.Column="4" CornerRadius="16" Padding="20" Height="110">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E17055" Offset="0"/>
                            <GradientStop Color="#FDCB6E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#E17055" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Đang Sử Dụng" FontSize="12" Foreground="#FFEAA7"/>
                        <TextBlock x:Name="TxtPhongOccupied" Grid.Row="1"
                                   Text="—" FontSize="36" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Text="🔑 Khách đang ở" FontSize="11" Foreground="#FFEAA7"/>
                    </Grid>
                </Border>

                <!-- Card: Doanh thu tháng -->
                <Border Grid.Column="6" CornerRadius="16" Padding="20" Height="110">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6C5CE7" Offset="0"/>
                            <GradientStop Color="#A29BFE" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Doanh Thu Tháng" FontSize="12" Foreground="#DDA9FF"/>
                        <TextBlock x:Name="TxtDoanhThu" Grid.Row="1"
                                   Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Text="💰 Đã thanh toán" FontSize="11" Foreground="#DDA9FF"/>
                    </Grid>
                </Border>

            </Grid>

            <!-- ── Main Content: Room Grid + Bookings ──────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Room Status Grid -->
                <Border Grid.Column="0" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.08" Color="#0078D4"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Sơ đồ Phòng" FontSize="16" FontWeight="Bold" Foreground="#0F3460"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- Legend -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                    <Ellipse Width="10" Height="10" Fill="#00B894" VerticalAlignment="Center"/>
                                    <TextBlock Text="Trống" FontSize="11" Foreground="#666" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                    <Ellipse Width="10" Height="10" Fill="#E17055" VerticalAlignment="Center"/>
                                    <TextBlock Text="Đang ở" FontSize="11" Foreground="#666" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#FDCB6E" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dọn dẹp" FontSize="11" Foreground="#666" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <ItemsControl x:Name="RoomGrid">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="80" Height="70" Margin="6" CornerRadius="10"
                                            Background="{Binding CardBackground}" Cursor="Hand">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                                              Color="{Binding ShadowColor}" Opacity="0.25"/>
                                        </Border.Effect>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding MaPhong}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TenLoaiPhong}"
                                                       FontSize="9" Foreground="#DDEEFF"
                                                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="72"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- Recent Bookings -->
                <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.08" Color="#0078D4"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Đặt Phòng Gần Đây" FontSize="16"
                                   FontWeight="Bold" Foreground="#0F3460" Margin="0,0,0,16"/>

                        <ItemsControl x:Name="RecentBookings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="12,10" CornerRadius="10"
                                            Background="#F8FBFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenKhachHang}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1A3A5C"/>
                                                <TextBlock Text="{Binding MaDatPhong}"
                                                           FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,4"
                                                    Background="{Binding StatusColor}">
                                                <TextBlock Text="{Binding TrangThai}"
                                                           FontSize="10" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock x:Name="TxtNoBookings"
                                   Text="Chưa có đặt phòng nào"
                                   FontSize="13" Foreground="#AAA"
                                   HorizontalAlignment="Center" Margin="0,20"/>
                    </StackPanel>
                </Border>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
