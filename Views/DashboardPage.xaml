<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,20,28,28">

            <!-- ── Bộ lọc thời gian ── -->
            <Border CornerRadius="12" Background="White" Padding="16,10" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kỳ báo cáo:" FontSize="13" Foreground="#555"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <DatePicker x:Name="DpTuNgay" Height="32" FontSize="13" Width="140"
                                SelectedDateChanged="DateFilter_Changed"/>
                    <TextBlock Text=" → " FontSize="13" Foreground="#888"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <DatePicker x:Name="DpDenNgay" Height="32" FontSize="13" Width="140"
                                SelectedDateChanged="DateFilter_Changed"/>
                    <Button Content="Tháng này" Height="32" Padding="12,0" Margin="12,0,0,0"
                            Background="#EBF5FB" BorderThickness="0" FontSize="12"
                            Click="BtnThangNay_Click"/>
                    <Button Content="Quý này" Height="32" Padding="12,0" Margin="8,0,0,0"
                            Background="#EBF5FB" BorderThickness="0" FontSize="12"
                            Click="BtnQuyNay_Click"/>
                    <Button Content="Năm này" Height="32" Padding="12,0" Margin="8,0,0,0"
                            Background="#EBF5FB" BorderThickness="0" FontSize="12"
                            Click="BtnNamNay_Click"/>
                </StackPanel>
            </Border>

            <!-- ── KPI Cards ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Doanh thu -->
                <Border Grid.Column="0" CornerRadius="16" Padding="18,14" Height="100">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0078D4" Offset="0"/>
                            <GradientStop Color="#00BCF2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="18" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="💰 Doanh Thu" FontSize="11" Foreground="#CCE8FF"/>
                        <TextBlock x:Name="TxtDoanhThu" Text="—" FontSize="22"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Chi phí -->
                <Border Grid.Column="2" CornerRadius="16" Padding="18,14" Height="100">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E17055" Offset="0"/>
                            <GradientStop Color="#FDCB6E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#E17055" BlurRadius="18" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="💸 Chi Phí" FontSize="11" Foreground="#FFEAA7"/>
                        <TextBlock x:Name="TxtChiPhi" Text="—" FontSize="22"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Lợi nhuận -->
                <Border Grid.Column="4" CornerRadius="16" Padding="18,14" Height="100">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00B894" Offset="0"/>
                            <GradientStop Color="#00CEC9" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#00B894" BlurRadius="18" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📈 Lợi Nhuận" FontSize="11" Foreground="#B2F0E8"/>
                        <TextBlock x:Name="TxtLoiNhuan" Text="—" FontSize="22"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tổng phòng -->
                <Border Grid.Column="6" CornerRadius="16" Padding="18,14" Height="100">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6C5CE7" Offset="0"/>
                            <GradientStop Color="#A29BFE" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#6C5CE7" BlurRadius="18" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🏠 Tổng Phòng" FontSize="11" Foreground="#DDD9FF"/>
                        <TextBlock x:Name="TxtTongPhong" Text="—" FontSize="22"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Công suất -->
                <Border Grid.Column="8" CornerRadius="16" Padding="18,14" Height="100">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FD79A8" Offset="0"/>
                            <GradientStop Color="#E84393" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#E84393" BlurRadius="18" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📊 Công Suất" FontSize="11" Foreground="#FFD6EC"/>
                        <TextBlock x:Name="TxtCongSuat" Text="—" FontSize="22"
                                   FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 2: Biểu đồ doanh thu + Trạng thái phòng ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Biểu đồ doanh thu 12 tháng -->
                <Border Grid.Column="0" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Doanh Thu 12 Tháng Gần Nhất" FontSize="15"
                                   FontWeight="Bold" Foreground="#0F3460" Margin="0,0,0,16"/>
                        <!-- Bar chart -->
                        <Grid Height="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <ItemsControl x:Name="BarChart" Grid.Row="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="3,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                <Rectangle Height="{Binding BarHeight}"
                                                           VerticalAlignment="Bottom"
                                                           RadiusX="4" RadiusY="4"
                                                           Fill="{Binding BarColor}">
                                                    <Rectangle.ToolTip>
                                                        <TextBlock Text="{Binding Tooltip}"/>
                                                    </Rectangle.ToolTip>
                                                </Rectangle>
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{Binding ThangText}"
                                                       FontSize="10" Foreground="#888"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Trạng thái phòng (pie-like) -->
                <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Trạng Thái Phòng" FontSize="15"
                                   FontWeight="Bold" Foreground="#0F3460" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="PhongStatusList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="12" Height="12"
                                                   RadiusX="3" RadiusY="3"
                                                   Fill="{Binding MauSac}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TenTT}"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SoPhong}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#0F3460" VerticalAlignment="Center"/>
                                        <!-- Progress bar -->
                                        <Border Grid.Column="5" Height="6" CornerRadius="3"
                                                Background="#EEF" VerticalAlignment="Center">
                                            <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                    Background="{Binding MauSac}"
                                                    Width="{Binding BarWidth}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12"/>
                        <TextBlock Text="Top Dịch Vụ" FontSize="14" FontWeight="Bold"
                                   Foreground="#0F3460" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="TopDichVuList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TenDV}" FontSize="12" Foreground="#555"/>
                                        <Border Grid.Column="1" CornerRadius="6" Padding="8,2"
                                                Background="#EBF5FB">
                                            <TextBlock Text="{Binding SoLan}" FontSize="12"
                                                       Foreground="#0078D4" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 3: Chi phí theo loại + Đặt phòng gần đây ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Chi phí theo loại -->
                <Border Grid.Column="0" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Chi Phí Theo Loại" FontSize="15"
                                   FontWeight="Bold" Foreground="#0F3460" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="ChiPhiList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Loai}" FontSize="13" Foreground="#333"/>
                                            <Border Height="6" CornerRadius="3"
                                                    Margin="0,4,0,0" HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#E17055" Offset="0"/>
                                                        <GradientStop Color="#FDCB6E" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TongText}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#E17055" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Đặt phòng gần đây -->
                <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Đặt Phòng Gần Đây" FontSize="15"
                                   FontWeight="Bold" Foreground="#0F3460" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="RecentBookings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="10"
                                            Background="#F8FBFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenKhachHang}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1A3A5C"/>
                                                <TextBlock Text="{Binding MaDatPhong}"
                                                           FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,4"
                                                    Background="{Binding StatusColor}">
                                                <TextBlock Text="{Binding TrangThai}"
                                                           FontSize="10" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>