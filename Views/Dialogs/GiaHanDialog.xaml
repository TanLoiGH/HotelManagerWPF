<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.GiaHanDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="GiaHanDialog"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,15"
            HorizontalAlignment="Center"
            FontSize="18"
            FontWeight="Bold"
            Foreground="#2563EB"
            Text="GIA HẠN PHÒNG" />

        <TextBlock
            Grid.Row="1"
            Margin="0,0,0,5"
            FontSize="14"
            Text="Chọn ngày trả phòng mới:" />

        <DatePicker
            x:Name="DpNgayTraMoi"
            Grid.Row="2"
            Height="35"
            VerticalContentAlignment="Center"
            FontSize="14" />

        <StackPanel
            Grid.Row="4"
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="35"
                Margin="0,0,10,0"
                Background="#E5E7EB"
                BorderBrush="Transparent"
                Click="BtnCancel_Click"
                Content="Hủy bỏ" />
            <Button
                Width="90"
                Height="35"
                Background="#2563EB"
                BorderBrush="Transparent"
                Click="BtnOk_Click"
                Content="Xác nhận"
                FontWeight="SemiBold"
                Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
