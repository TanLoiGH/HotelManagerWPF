<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.GiaHanDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Gia hạn phòng"
    Width="450"
    Height="260"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Surface}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{DynamicResource Brush.Heading}"
                Text="📅 Gia hạn phòng" />

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Brush.TextLabel}"
                    Text="Chọn ngày trả phòng mới:" />

                <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                    <DatePicker
                        x:Name="DpNgayTraMoi"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextPrimary}" />
                </Border>
            </StackPanel>

            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="90"
                    Margin="0,0,12,0"
                    Click="BtnCancel_Click"
                    Content="Hủy bỏ"
                    Style="{DynamicResource MacFluent.ButtonSecondary}" />
                <Button
                    Width="110"
                    Click="BtnOk_Click"
                    Content="Xác nhận"
                    Style="{DynamicResource MacFluent.ButtonPrimary}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>