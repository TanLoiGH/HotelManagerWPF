<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.PrintPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xem trước bản in" Height="750" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="XEM TRƯỚC HÓA ĐƠN" FontSize="20" FontWeight="Bold" 
                       Foreground="{DynamicResource Brush.Accent}"/>
            <TextBlock x:Name="TxtPrinterStatus" Text="Trạng thái máy in: Đang kiểm tra..." 
                       FontSize="13" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
        </StackPanel>

        <!-- Preview Area -->
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}" 
                CornerRadius="8" Background="White">
            <FlowDocumentScrollViewer x:Name="DocViewer" VerticalScrollBarVisibility="Auto" Zoom="100"/>
        </Border>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnExportPdf" Content="📄 Xuất PDF" Height="40" Padding="15,0" Margin="0,0,10,0"
                    Style="{DynamicResource MacFluent.ButtonAction.AddSoft}" Click="BtnExportPdf_Click"/>
            
            <Button x:Name="BtnPrint" Content="🖨️ In ngay" Height="40" Padding="20,0"
                    Style="{DynamicResource MacFluent.ButtonPrimary}" Click="BtnPrint_Click"/>
            
            <Button Content="Đóng" Height="40" Padding="15,0" Margin="10,0,0,0"
                    Style="{DynamicResource MacFluent.ButtonSecondary}" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
