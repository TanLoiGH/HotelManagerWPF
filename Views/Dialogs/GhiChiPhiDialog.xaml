<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.GhiChiPhiDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ghi Chi Phí"
    Width="500"
    MaxHeight="750"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Surface}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="24,20,24,16"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Heading}"
                    Text="💸 Ghi Chi Phí" />
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Loại chi phí *" />
                        <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                            <ComboBox
                                x:Name="CboLoaiCP"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                Foreground="{DynamicResource Brush.TextPrimary}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Mô tả chi phí *" />
                        <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                            <TextBox
                                x:Name="TxtTenChiPhi"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                Foreground="{DynamicResource Brush.TextPrimary}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextLabel}"
                            Text="Số tiền (₫) *" />
                        <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                            <TextBox
                                x:Name="TxtSoTien"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextPrimary}"
                                TextAlignment="Right" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,16">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            Text="Nhà cung cấp (nếu có)" />
                        <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                            <ComboBox
                                x:Name="CboNCC"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                Foreground="{DynamicResource Brush.TextPrimary}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,0,0,16">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            Text="Phòng liên quan (nếu sửa chữa)" />
                        <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                            <ComboBox
                                x:Name="CboPhong"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                Foreground="{DynamicResource Brush.TextPrimary}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="5">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            Text="Ghi chú thêm" />
                        <Border Style="{DynamicResource MacFluent.InputFrame}">
                            <TextBox
                                x:Name="TxtGhiChu"
                                Height="70"
                                Padding="10,8"
                                AcceptsReturn="True"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="15"
                                Foreground="{DynamicResource Brush.TextPrimary}"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="24,16"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,16,16">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Width="100"
                        Height="40"
                        Margin="0,0,12,0"
                        Click="BtnHuy_Click"
                        Content="Hủy bỏ"
                        Style="{DynamicResource MacFluent.ButtonSecondary}" />
                    <Button
                        Width="130"
                        Height="40"
                        Click="BtnLuu_Click"
                        Content="Lưu chi phí"
                        Style="{DynamicResource MacFluent.ButtonPrimary}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>