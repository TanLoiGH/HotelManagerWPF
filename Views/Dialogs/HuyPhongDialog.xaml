<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.HuyPhongDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="HuyPhongDialog"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,15"
            FontSize="20"
            FontWeight="Bold"
            Foreground="{DynamicResource Brush.Error}"
            Text="⚠️ XÁC NHẬN HỦY PHÒNG"
            TextAlignment="Center" />

        <StackPanel Grid.Row="1">
            <TextBlock
                Margin="0,0,0,5"
                FontSize="14"
                Foreground="{DynamicResource Brush.TextLabel}"
                Text="Lý do hủy:" />
            <Border
                Height="36"
                Margin="0,0,0,15"
                CornerRadius="6"
                Style="{DynamicResource MacFluent.InputFrame}">
                <ComboBox
                    x:Name="cboLyDo"
                    Padding="8,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="15"
                    IsEditable="True">
                    <ComboBoxItem Content="Huỷ riêng phòng này" />
                    <ComboBoxItem Content="Khách đổi ý / Hủy trước hạn" />
                    <ComboBoxItem Content="Khách không đến (No-show)" />
                    <ComboBoxItem Content="Lỗi hệ thống / Khách sạn sai sót" />
                    <ComboBoxItem Content="Dịch bệnh / Thiên tai" />
                </ComboBox>
            </Border>

            <DockPanel Margin="0,0,0,5">
                <TextBlock
                    DockPanel.Dock="Left"
                    FontSize="14"
                    Foreground="{DynamicResource Brush.TextLabel}"
                    Text="Số tiền hoàn lại cho khách:" />
                <TextBlock
                    x:Name="txtGoiYCoc"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.TextPlaceholder}"
                    Text="(Khách đã cọc: 0 đ)" />
            </DockPanel>

            <Border
                Height="36"
                CornerRadius="6"
                Style="{DynamicResource MacFluent.InputFrame}">
                <TextBox
                    x:Name="txtTienHoan"
                    Padding="8,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Text="0"
                    TextAlignment="Right" />
            </Border>

            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                <Button
                    Margin="0,0,10,0"
                    Padding="10,2"
                    Background="Transparent"
                    BorderBrush="#0078D7"
                    BorderThickness="1"
                    Click="BtnHoanDu_Click"
                    Content="Hoàn đủ cọc"
                    Foreground="#0078D7" />
                <Button
                    Padding="10,2"
                    Background="Transparent"
                    BorderBrush="{DynamicResource Brush.Error}"
                    BorderThickness="1"
                    Click="BtnKhongHoan_Click"
                    Content="Không hoàn (0đ)"
                    Foreground="{DynamicResource Brush.Error}" />
            </StackPanel>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="0,15,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="36"
                Margin="0,0,10,0"
                Click="BtnHuy_Click"
                Content="Quay lại"
                Style="{DynamicResource MacFluent.ButtonSecondary}" />
            <Button
                Width="120"
                Margin="0,0,0,0"
                Background="#E81123"
                Click="BtnXacNhan_Click"
                Content="Xác nhận Hủy"
                Style="{DynamicResource MacFluent.ButtonPrimary}" />
        </StackPanel>
    </Grid>
</Window>
