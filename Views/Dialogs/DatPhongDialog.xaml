<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.DatPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đặt Phòng" Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: thông tin phòng -->
        <Border Grid.Row="0" CornerRadius="10" Padding="14,10" Background="#EBF5FB">
            <TextBlock x:Name="TxtPhong" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Heading}"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Tìm khách hàng -->
                <TextBlock Text="Khách hàng" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="36" Margin="0,0,0,4">
                    <TextBox x:Name="TxtTimKhach" BorderThickness="0" Padding="10,0"
                             VerticalAlignment="Center" FontSize="15"
                             TextChanged="TxtTimKhach_TextChanged"
                             />
                </Border>

                <!-- Dropdown kết quả tìm kiếm -->
                <ListBox x:Name="ListKhach" MaxHeight="120" Visibility="Collapsed"
                         SelectionChanged="ListKhach_SelectionChanged"
                         DisplayMemberPath="TenKhachHang"
                         BorderBrush="#DDE" BorderThickness="1" Margin="0,0,0,4"/>

                <!-- Info hạng KH -->
                <TextBlock x:Name="TxtKhachInfo" FontSize="13" Foreground="#0078D4"
                           Visibility="Collapsed" Margin="0,0,0,8"/>

                <!-- Nếu khách mới: nhập thêm -->
                <Expander Header="Khách mới — nhập thông tin" Margin="0,0,0,12">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Số điện thoại" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="34" Margin="0,0,0,8">
                            <TextBox x:Name="TxtDienThoai" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="15"/>
                        </Border>
                        <TextBlock Text="CCCD" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE" BorderThickness="1.5" Height="34">
                            <TextBox x:Name="TxtCCCD" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="15"/>
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- Ngày nhận / trả -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ngày nhận phòng" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpNgayNhan" SelectedDateChanged="DatePicker_Changed"
                                    FontSize="15" Height="34"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ngày trả phòng" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpNgayTra" SelectedDateChanged="DatePicker_Changed"
                                    FontSize="15" Height="34"/>
                    </StackPanel>
                </Grid>

                <Border CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,12"
                        Background="{DynamicResource Brush.WarningSurface}">
                    <TextBlock Text="Khuyến mãi sẽ được chọn khi xuất hóa đơn."
                               FontSize="13"
                               Foreground="{DynamicResource Brush.WarningText}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Tính giá -->
                <Border CornerRadius="8" Padding="12,8" Background="{DynamicResource Brush.SurfaceSoft}">
                    <TextBlock x:Name="TxtTinhGia" FontSize="15" Foreground="{DynamicResource Brush.Heading}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="BtnHuy" Content="Hủy" Height="38"
                    FontSize="15" Click="BtnHuy_Click"
                    Background="#F5F5F5" BorderThickness="0"/>
            <Button Grid.Column="2" x:Name="BtnXacNhan" Content="Xác nhận đặt phòng" Height="38"
                    FontSize="15" FontWeight="SemiBold"
                    Style="{DynamicResource MacFluent.ButtonPrimary}"
                    Click="BtnXacNhan_Click"/>
        </Grid>
    </Grid>
</Window>





