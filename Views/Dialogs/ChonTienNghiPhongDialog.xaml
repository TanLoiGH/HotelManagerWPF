<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.ChonTienNghiPhongDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Chọn tiện nghi cho phòng"
    Width="560"
    Height="620"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Surface}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{DynamicResource Brush.Heading}"
                Text="🧰 Chọn tiện nghi cho phòng" />

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Height="36"
                    Padding="10,0"
                    CornerRadius="8"
                    Style="{DynamicResource MacFluent.InputFrame}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource Brush.TextPlaceholder}"
                            Text="🔍" />
                        <TextBox
                            x:Name="TxtSearch"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="15"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            TextChanged="TxtSearch_TextChanged" />
                    </StackPanel>
                </Border>

                <Button
                    Grid.Column="2"
                    Height="36"
                    Padding="14,0"
                    Click="BtnChonHet_Click"
                    Content="Chọn hết"
                    Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                <Button
                    Grid.Column="4"
                    Height="36"
                    Padding="14,0"
                    Click="BtnBoChon_Click"
                    Content="Bỏ chọn"
                    Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}" />
            </Grid>

            <Border
                Grid.Row="4"
                Padding="10"
                Background="{DynamicResource Brush.SurfaceSoft}"
                CornerRadius="12">
                <ListView
                    x:Name="ListTienNghi"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <CheckBox
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                VerticalContentAlignment="Center"
                                Cursor="Hand"
                                IsChecked="{Binding IsChecked, Mode=TwoWay}">
                                <CheckBox.Template>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Border
                                            x:Name="CardBorder"
                                            Padding="12,10"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="Transparent"
                                            BorderThickness="1.5"
                                            CornerRadius="10">
                                            <Grid Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    x:Name="CheckMark"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="0,0,14,0"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5">
                                                    <TextBlock
                                                        x:Name="Mark"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="✓"
                                                        Visibility="Collapsed" />
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource Brush.Heading}"
                                                        Text="{Binding TenTienNghi}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                        Text="{Binding TenNCC}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="CheckMark" Property="Background" Value="{DynamicResource Brush.BrandPrimary}" />
                                                <Setter TargetName="CheckMark" Property="BorderBrush" Value="{DynamicResource Brush.BrandPrimary}" />
                                                <Setter TargetName="Mark" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource Brush.BrandPrimary}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource Brush.Hover}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </CheckBox.Template>
                            </CheckBox>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Height="40"
                    Click="BtnHuy_Click"
                    Content="Hủy bỏ"
                    Style="{DynamicResource MacFluent.ButtonSecondary}" />
                <Button
                    Grid.Column="2"
                    Height="40"
                    Click="BtnXacNhan_Click"
                    Content="Xác nhận"
                    Style="{DynamicResource MacFluent.ButtonPrimary}" />
            </Grid>
        </Grid>
    </Border>
</Window>