<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.ChonTienNghiPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn tiện nghi cho phòng" Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border CornerRadius="8" Padding="10,0" Height="34"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtSearch" BorderThickness="0"
                             Background="Transparent" VerticalAlignment="Center"
                             FontSize="15" TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>
            </Border>
            <Button Grid.Column="2" Content="Chọn hết" Height="34" Padding="14,0"
                    Style="{DynamicResource MacFluent.ButtonAction.Add}"
                    Click="BtnChonHet_Click"/>
            <Button Grid.Column="4" Content="Bỏ chọn" Height="34" Padding="14,0"
                    Style="{DynamicResource MacFluent.ButtonAction.DeleteSoft}"
                    Click="BtnBoChon_Click"/>
        </Grid>

        <Border Grid.Row="2" CornerRadius="12" Padding="10"
                Background="{DynamicResource Brush.Surface}">
            <!-- 
                Sử dụng ListView kết hợp với Virtualization để hiệu năng mượt mà.
                Đã khôi phục khả năng click toàn vùng Card (Hit-testing) và Keyboard Navigation (Space).
            -->
            <ListView x:Name="ListTienNghi" 
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <!-- Vô hiệu hóa selection mặc định để Card UI tự xử lý sự kiện click -->
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Focusable" Value="False"/> <!-- Để CheckBox bên trong nhận Focus thay thế -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- CheckBox giờ đây là root của DataTemplate để chiếm toàn bộ vùng click -->
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" 
                                  HorizontalAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  Cursor="Hand"
                                  Padding="0">
                            
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="CardBorder" CornerRadius="10" Padding="12,10" 
                                            Background="{DynamicResource Brush.SurfaceSoft}" 
                                            BorderThickness="1.5" BorderBrush="Transparent">
                                        <Grid Background="Transparent"> <!-- Grid background Transparent rất quan trọng cho Hit-testing -->
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox Custom Look -->
                                            <Border x:Name="CheckMark" Width="22" Height="22" 
                                                    CornerRadius="5" BorderThickness="1.5"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    Background="White" Margin="0,0,14,0">
                                                <TextBlock x:Name="Mark" Text="✓" FontSize="14" FontWeight="Bold" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TenTienNghi}" FontSize="15" 
                                                           Foreground="{DynamicResource Brush.Heading}" 
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TenNCC}" FontSize="12" 
                                                           Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="CheckMark" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                                            <Setter TargetName="CheckMark" Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                            <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource Brush.Action.AddSoft}"/>
                                        </Trigger>
                                        <!-- Hiệu ứng hover cho toàn Card -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource Brush.Hover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Hủy" Height="38"
                    Background="#F5F5F5" BorderThickness="0"
                    Click="BtnHuy_Click"/>
            <Button Grid.Column="2" Content="Xác nhận" Height="38"
                    Style="{DynamicResource MacFluent.ButtonPrimary}"
                    Click="BtnXacNhan_Click"/>
        </Grid>
    </Grid>
</Window>

