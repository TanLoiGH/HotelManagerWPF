<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.HoaDonChiTietDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Dialogs" 
        xmlns:viewmodels="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels" 
            d:DataContext="{d:DesignInstance Type=viewmodels:HoaDonChiTietViewModel}"
        mc:Ignorable="d"
        Title="Chi tiết hóa đơn"
        Width="1080"
        Height="880"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Surface}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + Actions -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="CHI TIẾT HÓA ĐƠN" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding MaHoaDon}" FontSize="14"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="In Tiền Phòng" Command="{Binding InHoaDonTienPhongCommand}" Margin="0,0,10,0"/>
                <Button Content="In Dịch Vụ" Command="{Binding InHoaDonDichVuCommand}" Margin="0,0,10,0"/>
                <Button Content="🧾  Tạm in" Height="38" Padding="16,0" Margin="0,0,10,0"
                        Style="{DynamicResource MacFluent.ButtonAction.AddSoft}"
                        Command="{Binding TamInCommand}"/>
                <Button Content="🖨️  In hóa đơn" Height="38" Padding="16,0" Margin="0,0,10,0"
                        Style="{DynamicResource MacFluent.ButtonAction.AddSoft}"
                        Command="{Binding InHoaDonCommand}"/>
                <Button Content="🍽️  Thêm dịch vụ" Height="38" Padding="16,0" Margin="0,0,10,0"
                        Style="{DynamicResource MacFluent.ButtonAction.Add}"
                        Command="{Binding ThemDichVuCommand}"/>
                <Button Content="Đóng" Height="38" Padding="16,0"
                        Style="{DynamicResource MacFluent.ButtonSecondary}"
                        Command="{Binding DongCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Chi tiết hoá đơn (60%) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Thông tin chung -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Khách hàng" Foreground="{DynamicResource Brush.TextLabel}"/>
                        <TextBlock Text="{Binding KhachHangDisplay}" FontWeight="Bold"/>

                        <TextBlock Text="Nhân viên Check-in" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding NhanVienCheckInDisplay}" FontWeight="Bold"/>

                        <TextBlock Text="Ngày lập" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding NgayLap,StringFormat=dd/MM/yyyy}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Trạng thái" Foreground="{DynamicResource Brush.TextLabel}"/>
                        <TextBlock Text="{Binding TrangThai}" FontWeight="Bold" Foreground="#FF47C31C"/>

                        <TextBlock Text="Khuyến mãi" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding KhuyenMai}"/>
                    </StackPanel>
                </Grid>

                <!-- Tabs -->
                <TabControl Grid.Row="1">
                    <TabItem Header="Phòng">
                        <DataGrid ItemsSource="{Binding Phongs}"
                                  SelectedItem="{Binding SelectedPhong}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" FontSize="18">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Phòng" Binding="{Binding MaPhong}" Width="90"/>
                                <DataGridTextColumn Header="Ngày nhận" Binding="{Binding NgayNhan,StringFormat=dd/MM}" Width="110"/>
                                <DataGridTextColumn Header="Ngày trả" Binding="{Binding NgayTra,StringFormat=dd/MM}" Width="110"/>
                                <DataGridTextColumn Header="Số đêm" Binding="{Binding SoDem}" Width="80"/>
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGiaText}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Dịch vụ">
                        <DataGrid ItemsSource="{Binding DichVus}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" FontSize="18">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Dịch vụ" Binding="{Binding TenDichVu}" Width="*"/>
                                <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="70"/>
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGiaText}" Width="120"/>
                                <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTienText}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>

                <!-- Tổng tiền -->
                <Border Grid.Row="2" Margin="0,14,0,0"
                        Background="{DynamicResource Brush.SurfaceSoft}"
                        CornerRadius="12" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="Tiền phòng" Foreground="{DynamicResource Brush.TextLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TienPhongHienThi}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Text="Tiền dịch vụ" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TienDichVuHienThi}" FontWeight="SemiBold" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="2" Text="VAT" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VatPhanTramHienThi}" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="3" Text="TỔNG THANH TOÁN" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TongThanhToanHienThi}"
                                   FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.BrandPrimary}" Margin="0,10,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: Thanh toán (40%) -->
            <Border Grid.Column="2"
                    Background="{DynamicResource Brush.Surface}"
                    CornerRadius="16"
                    Padding="18"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource Brush.Border}">
                <Grid>
                    <Grid.RowDefinitions >
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- THANH TOÁN -->
                    <Grid Grid.Row="1"  Margin="0,4" Visibility="{Binding TienCoc, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='>0'}">
                        <TextBlock Text="Đã trừ tiền cọc:" FontStyle="Italic" Foreground="#D32F2F"/>
                        <TextBlock Text="{Binding TienCocHienThi}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#D32F2F"/>
                        <TextBlock Text="---------------------" HorizontalAlignment="Right" Margin="0,15,0,0" Foreground="BlueViolet"/>
                    </Grid>
                    <TextBlock Grid.Row="0" Text="THANH TOÁN" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <TextBlock Text="{Binding ConLaiHienThi}" FontSize="14"
                                   Foreground="{DynamicResource Brush.Error}" HorizontalAlignment="Right"/>

                        <StackPanel Visibility="{Binding CoLichSu, Converter={StaticResource BoolToVis}}" Margin="0,10,0,10">
                            <TextBlock Text="Lịch sử giao dịch" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextPlaceholder}" Margin="0,0,0,6"/>
                            <ListBox ItemsSource="{Binding LichSuThanhToan}" MaxHeight="110"
                                     BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" FontSize="14">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding LoaiGiaoDich}" FontSize="14" />
                                            <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold" Margin="210,0,0,0"
                                                       Text="{Binding SoTienText}"/>
                                        </Grid>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            
                            <TextBlock Text="Hóa đơn đã chốt, chỉ được xem." Margin="0,0,0,10"
                                       Foreground="{DynamicResource Brush.TextPlaceholder}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoTheChinhSua}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoTheChinhSua}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                            <TextBlock Text="Số tiền thanh toán" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                            <Border CornerRadius="8" Style="{DynamicResource MacFluent.InputFrame}" Height="36" Margin="0,0,0,10">
                                    <TextBox BorderThickness="0" Padding="10,0"
                                         VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"
                                         TextAlignment="Right"
                                              x:Name="txtSoTien"
                                         Text="{Binding SoTienNhap, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="txtSoTien_TextChanged"/>
                            </Border>

                            <TextBlock Text="Phương thức thanh toán" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                            <ComboBox Height="34" FontSize="15" Margin="0,0,0,10" 
                                      ItemsSource="{Binding DanhSachPhuongThucThanhToan}"
                                      DisplayMemberPath="TenPhuongThuc"
                                      SelectedItem="{Binding PhuongThucThanhToanDuocChon}"/>

                            <TextBlock Text="Loại giao dịch" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                            <ComboBox Height="34" FontSize="15" Margin="0,0,0,10"
                                      ItemsSource="{Binding DanhSachLoaiGiaoDich}"
                                      SelectedItem="{Binding LoaiGiaoDichDuocChon}"/>

                            <TextBlock Text="Ghi chú" FontSize="14" Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                            <Border CornerRadius="8" Style="{DynamicResource MacFluent.InputFrame}" Margin="0,0,0,16">
                                <TextBox BorderThickness="0" Padding="10,6"
                                         FontSize="15" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                         Text="{Binding NoiDung, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" Orientation="Vertical">

                        <TextBlock  Text="Cập nhật trả sớm hôm nay" FontSize="14" Foreground="{DynamicResource Brush.TextDisabled}" Margin="0,0,0,4"/>
                        <Button Content="Thanh toán ngay" Height="40" Margin="0,0,0,10" Command="{Binding CapNhatTraSomHomNayCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MacFluent.ButtonSecondary}" >
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoTheCapNhatTraSom}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Xác nhận" Height="40" Margin="0,25,0,00"
                                FontSize="15" FontWeight="SemiBold"
                                Command="{Binding ThanhToanCommand}">
                            <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MacFluent.ButtonPrimary}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CoTheChinhSua}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Trả phòng" Height="40" Margin="0,10,0,0"
                                FontSize="15" FontWeight="SemiBold"
                                Command="{Binding TraPhongCommand}"
                                Visibility="{Binding CoTheTraPhong, Converter={StaticResource BoolToVis}}"
                                Style="{StaticResource MacFluent.ButtonPrimary}"/>
                        
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
