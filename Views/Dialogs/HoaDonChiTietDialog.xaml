<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.HoaDonChiTietDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Dialogs"
        mc:Ignorable="d"
        Title="Chi tiết hóa đơn"
        Width="720"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Surface}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->

        <StackPanel Margin="0 0 0 20">
            <TextBlock Text="CHI TIẾT HÓA ĐƠN"
FontSize="24"
FontWeight="Bold"/>
            <TextBlock Text="{Binding MaHoaDon}"
FontSize="14"/>
        </StackPanel>

        <!-- Thông tin chung -->

        <Grid Grid.Row="1" Margin="0 0 0 20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Khách hàng"/>
                <TextBlock Text="{Binding KhachHang}" FontWeight="Bold"/>

                <TextBlock Text="Nhân viên"/>
                <TextBlock Text="{Binding NhanVien}" FontWeight="Bold"/>

                <TextBlock Text="Ngày lập"/>
                <TextBlock Text="{Binding NgayLap,StringFormat=dd/MM/yyyy}"/>
            </StackPanel>

            <StackPanel Grid.Column="1">

                <TextBlock Text="Trạng thái"/>
                <TextBlock Text="{Binding TrangThai}" FontWeight="Bold"/>

            </StackPanel>

        </Grid>

        <!-- Tabs -->

        <TabControl Grid.Row="2">

            <!-- Phòng -->

            <TabItem Header="Phòng">

                <DataGrid ItemsSource="{Binding Phongs}"
AutoGenerateColumns="False"
IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Phòng"
Binding="{Binding MaPhong}"/>

                        <DataGridTextColumn Header="Ngày nhận"
Binding="{Binding NgayNhan,StringFormat=dd/MM}"/>

                        <DataGridTextColumn Header="Ngày trả"
Binding="{Binding NgayTra,StringFormat=dd/MM}"/>

                        <DataGridTextColumn Header="Số đêm"
Binding="{Binding SoDem}"/>

                        <DataGridTextColumn Header="Đơn giá"
Binding="{Binding DonGiaText}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </TabItem>

            <!-- Dịch vụ -->

            <TabItem Header="Dịch vụ">

                <DataGrid ItemsSource="{Binding DichVus}"
AutoGenerateColumns="False"
IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Dịch vụ"
Binding="{Binding TenDichVu}"
Width="*"/>

                        <DataGridTextColumn Header="SL"
Binding="{Binding SoLuong}"/>

                        <DataGridTextColumn Header="Đơn giá"
Binding="{Binding DonGiaText}"/>

                        <DataGridTextColumn Header="Thành tiền"
Binding="{Binding ThanhTienText}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </TabItem>

        </TabControl>

        <!-- Tổng tiền -->

        <StackPanel Grid.Row="3"
HorizontalAlignment="Right"
Margin="0 20 0 0">

            <TextBlock Text="{Binding TienPhongText}"/>
            <TextBlock Text="{Binding TienDichVuText}"/>
            <TextBlock Text="{Binding VATText}"/>

            <TextBlock Text="{Binding TongThanhToanText}"
FontSize="24"
FontWeight="Bold"/>

        </StackPanel>

    </Grid>
</Window>
