<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.HoaDonChiTietDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
    Title="Chi tiết hóa đơn"
    Width="1080"
    Height="800"
    d:DataContext="{d:DesignInstance Type=viewmodels:HoaDonChiTietViewModel}"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Background}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.15"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.Heading}"
                        Text="CHI TIẾT HÓA ĐƠN" />
                    <TextBlock
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="{Binding MaHoaDon}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Height="38"
                        Margin="0,0,10,0"
                        Padding="16,0"
                        Command="{Binding InHoaDonTienPhongCommand}"
                        Content="In Tiền Phòng"
                        Style="{DynamicResource MacFluent.ButtonSecondary}" />
                    <Button
                        Height="38"
                        Margin="0,0,10,0"
                        Padding="16,0"
                        Command="{Binding InHoaDonDichVuCommand}"
                        Content="In Dịch Vụ"
                        Style="{DynamicResource MacFluent.ButtonSecondary}" />
                    <Button
                        Height="38"
                        Margin="0,0,10,0"
                        Padding="16,0"
                        Command="{Binding TamInCommand}"
                        Content="🧾 Tạm in"
                        Style="{DynamicResource MacFluent.ButtonAction.AddSoft}" />
                    <Button
                        Height="38"
                        Margin="0,0,10,0"
                        Padding="16,0"
                        Command="{Binding InHoaDonCommand}"
                        Content="🖨️ In hóa đơn"
                        Style="{DynamicResource MacFluent.ButtonAction.AddSoft}" />
                    <Button
                        Height="38"
                        Margin="0,0,10,0"
                        Padding="16,0"
                        Command="{Binding ThemDichVuCommand}"
                        Content="🍽️ Thêm dịch vụ"
                        Style="{DynamicResource MacFluent.ButtonAction.Add}" />
                    <Button
                        Height="38"
                        Padding="16,0"
                        Command="{Binding DongCommand}"
                        Content="Đóng"
                        Style="{DynamicResource MacFluent.ButtonSecondary}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="4*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Brush.TextLabel}" Text="Khách hàng" />
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding KhachHangDisplay}" />

                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Nhân viên Check-in" />
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding NhanVienCheckInDisplay}" />

                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Nhân viên Check-out" />
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding NhanVienCheckOutDisplay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Ngày lập HĐ" />
                                <TextBlock Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding NgayLap, StringFormat=dd/MM/yyyy}" />

                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Mã đặt phòng:" />
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="{Binding MaDatPhong}" />

                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Trạng thái" />
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource Brush.Success}"
                                    Text="{Binding TrangThai}" />

                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Khuyến mãi" />
                                <TextBlock Foreground="{DynamicResource Brush.TextPrimary}" Text="{Binding KhuyenMai}" />
                            </StackPanel>
                        </Grid>

                        <TabControl
                            Grid.Row="1"
                            Margin="0,15,0,0"
                            Background="Transparent"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,1,0,0">
                            <TabItem Header="📋 Danh sách Phòng">
                                <DataGrid
                                    AutoGenerateColumns="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    FontSize="15"
                                    GridLinesVisibility="Horizontal"
                                    HeadersVisibility="Column"
                                    HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                    IsReadOnly="True"
                                    ItemsSource="{Binding Phongs}"
                                    RowHeight="45"
                                    SelectedItem="{Binding SelectedPhong}"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="100"
                                            Binding="{Binding MaPhong}"
                                            ElementStyle="{DynamicResource CenterCell}"
                                            Header="Phòng" />
                                        <DataGridTextColumn
                                            Width="120"
                                            Binding="{Binding NgayNhan, StringFormat=dd/MM/yyyy}"
                                            ElementStyle="{DynamicResource CenterCell}"
                                            Header="Ngày Nhận" />
                                        <DataGridTextColumn
                                            Width="120"
                                            Binding="{Binding NgayTra, StringFormat=dd/MM/yyyy}"
                                            ElementStyle="{DynamicResource CenterCell}"
                                            Header="Ngày Trả" />
                                        <DataGridTextColumn
                                            Width="80"
                                            Binding="{Binding SoDem}"
                                            ElementStyle="{DynamicResource CenterCell}"
                                            Header="Đêm" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding DonGiaText}"
                                            ElementStyle="{DynamicResource RightCell}"
                                            Header="Đơn Giá (VNĐ)" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <TabItem Header="🍹 Dịch vụ sử dụng">
                                <DataGrid
                                    AutoGenerateColumns="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CanUserAddRows="False"
                                    FontSize="15"
                                    GridLinesVisibility="Horizontal"
                                    HeadersVisibility="Column"
                                    HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                    IsReadOnly="True"
                                    ItemsSource="{Binding DichVus}"
                                    RowHeight="45"
                                    SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding TenDichVu}"
                                            Header="Tên Dịch Vụ" />
                                        <DataGridTextColumn
                                            Width="80"
                                            Binding="{Binding MaPhong}"
                                            ElementStyle="{DynamicResource CenterCell}"
                                            Header="Phòng" />
                                        <DataGridTextColumn
                                            Width="60"
                                            Binding="{Binding SoLuong}"
                                            ElementStyle="{DynamicResource CenterCell}"
                                            Header="SL" />
                                        <DataGridTextColumn
                                            Width="110"
                                            Binding="{Binding DonGiaText}"
                                            ElementStyle="{DynamicResource RightCell}"
                                            Header="Đơn Giá" />
                                        <DataGridTextColumn
                                            Width="140"
                                            Binding="{Binding ThanhTienText}"
                                            ElementStyle="{DynamicResource RightCell}"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource Brush.Success}"
                                            Header="Thành Tiền" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>

                        <Border
                            Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="14"
                            Background="{DynamicResource Brush.SurfaceSoft}"
                            CornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="Tổng tiền phòng" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="{Binding TienPhongHienThi}" />
                                </DockPanel>

                                <DockPanel Grid.Row="1" Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="Tổng dịch vụ" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="{Binding TienDichVuHienThi}" />
                                </DockPanel>

                                <DockPanel Grid.Row="2" Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="{Binding VatPercent, StringFormat='VAT ({0:N0}%):'}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="{Binding TienVatHienThi}" />
                                </DockPanel>

                                <Separator
                                    Grid.Row="3"
                                    Margin="0,8"
                                    Background="{DynamicResource Brush.BorderStrong}" />

                                <DockPanel Grid.Row="4" Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.TextHeading}"
                                        Text="TỔNG BILL:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.TextHeading}"
                                        Text="{Binding TongThanhToanHienThi}" />
                                </DockPanel>

                                <DockPanel Grid.Row="5" Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        Foreground="{DynamicResource Brush.Error}"
                                        Text="Đã đặt cọc:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource Brush.Error}"
                                        Text="{Binding TienCocHienThi}" />
                                </DockPanel>

                                <Separator
                                    Grid.Row="6"
                                    Margin="0,8"
                                    Background="{DynamicResource Brush.BorderStrong}" />

                                <DockPanel Grid.Row="7" Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                        Text="{Binding LabelDuNo}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.BrandPrimary}"
                                        Text="{Binding SoTienDuNoHienThi}" />
                                </DockPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="20"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,14"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.Heading}"
                            Text="THANH TOÁN" />

                        <Border
                            Grid.Row="1"
                            Margin="0,0,0,20"
                            Padding="15"
                            Background="{DynamicResource Brush.SurfaceSoft}"
                            CornerRadius="8">
                            <StackPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="Tổng bill:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Brush.TextHeading}"
                                        Text="{Binding TongThanhToanHienThi}" />
                                </DockPanel>
                                <DockPanel Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        Foreground="{DynamicResource Brush.TextPrimary}"
                                        Text="Đã thanh toán:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource Brush.TextHeading}"
                                        Text="{Binding TongDaThuHienThi}" />
                                </DockPanel>
                                <Separator Margin="0,8" Background="{DynamicResource Brush.BorderStrong}" />
                                <DockPanel Margin="0,4">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.Error}"
                                        Text="{Binding LabelDuNo}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource Brush.Error}"
                                        Text="{Binding SoTienDuNoHienThi}" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2" Margin="0,0,0,12">
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="14"
                                Foreground="{DynamicResource Brush.Error}"
                                Text="{Binding ConLaiHienThi}" />

                            <StackPanel Margin="0,10,0,10" Visibility="{Binding CoLichSu, Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextLabel}"
                                    Text="Lịch sử giao dịch" />
                                <ListBox
                                    MaxHeight="120"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    FontSize="14"
                                    ItemsSource="{Binding LichSuThanhToan}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <TextBlock
                                                    FontSize="14"
                                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                                    Text="{Binding LoaiGiaoDich}" />
                                                <TextBlock
                                                    Margin="160,0,0,0"
                                                    HorizontalAlignment="Right"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource Brush.TextHeading}"
                                                    Text="{Binding SoTienText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </StackPanel>

                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontStyle="Italic"
                                    Foreground="{DynamicResource Brush.WarningText}"
                                    Text="Hóa đơn đã chốt, chỉ được xem.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CoTheChinhSua}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CoTheChinhSua}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextLabel}"
                                        Text="Số tiền thanh toán" />
                                    <Border
                                        Height="40"
                                        Margin="0,0,0,14"
                                        Style="{DynamicResource MacFluent.InputFrame}">
                                        <TextBox
                                            x:Name="txtSoTien"
                                            Padding="10,0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource Brush.TextPrimary}"
                                            Text="{Binding SoTienNhap, UpdateSourceTrigger=PropertyChanged}"
                                            TextAlignment="Right"
                                            TextChanged="txtSoTien_TextChanged" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextLabel}"
                                        Text="Phương thức thanh toán" />
                                    <Border
                                        Height="40"
                                        Margin="0,0,0,14"
                                        Style="{DynamicResource MacFluent.InputFrame}">
                                        <ComboBox
                                            Padding="10,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            DisplayMemberPath="TenPhuongThuc"
                                            FontSize="15"
                                            Foreground="{DynamicResource Brush.TextPrimary}"
                                            ItemsSource="{Binding DanhSachPhuongThucThanhToan}"
                                            SelectedItem="{Binding PhuongThucThanhToanDuocChon}" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextLabel}"
                                        Text="Loại giao dịch" />
                                    <Border
                                        Height="40"
                                        Margin="0,0,0,14"
                                        Style="{DynamicResource MacFluent.InputFrame}">
                                        <ComboBox
                                            Padding="10,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="15"
                                            Foreground="{DynamicResource Brush.TextPrimary}"
                                            ItemsSource="{Binding DanhSachLoaiGiaoDich}"
                                            SelectedItem="{Binding LoaiGiaoDichDuocChon}" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="14"
                                        Foreground="{DynamicResource Brush.TextLabel}"
                                        Text="Ghi chú" />
                                    <Border Margin="0,0,0,16" Style="{DynamicResource MacFluent.InputFrame}">
                                        <TextBox
                                            Height="60"
                                            Padding="10,6"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="15"
                                            Foreground="{DynamicResource Brush.TextPrimary}"
                                            Text="{Binding NoiDung, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="4" Orientation="Vertical">
                            <Button
                                Height="40"
                                Margin="0,0,0,10"
                                Command="{Binding CapNhatTraSomHomNayCommand}"
                                Content="Kết toán - trả sớm hôm nay">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource MacFluent.ButtonSecondary}" TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoTheCapNhatTraSom}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button
                                Height="42"
                                Margin="0,15,0,0"
                                Command="{Binding ThanhToanCommand}"
                                Content="Thanh toán"
                                FontSize="15">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource MacFluent.ButtonPrimary}" TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoTheChinhSua}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button
                                Height="42"
                                Margin="0,10,0,0"
                                Command="{Binding TraPhongCommand}"
                                Content="Trả phòng"
                                FontSize="15"
                                Style="{DynamicResource MacFluent.ButtonPrimary}"
                                Visibility="{Binding CoTheTraPhong, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>