<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.DoiPhongDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLyKhachSan_PhamTanLoi.Views.Dialogs"
      mc:Ignorable="d" 
        WindowStartupLocation="CenterOwner"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DoiPhongDialog"
        >

    <Border Padding="24" Background="{DynamicResource Brush.Surface}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🔀  Chuyển phòng" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.Heading}"/>
                <TextBlock Text="Chọn phòng trống mới để chuyển khách sang" FontSize="13" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="8" Padding="16,12" Background="{DynamicResource Brush.SurfaceSoft}" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Phòng hiện tại:" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="14" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource Brush.RoomOccupiedSoft}" CornerRadius="6" Padding="8,2" Margin="10,0,0,0">
                        <TextBlock x:Name="TxtPhongCu" Text="---" Foreground="{DynamicResource Brush.RoomOccupied}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Phòng mới (Đang trống)" Margin="0,0,0,8" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Height="42">
                    <ComboBox x:Name="CboPhongMoi" DisplayMemberPath="TenPhong" SelectedValuePath="MaPhong" 
                              FontSize="15" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnHuy" Click="BtnHuy_Click" Width="80" Height="40" Background="Transparent" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5" Margin="0,0,12,0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="Hủy" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                </Button>

                <Button x:Name="BtnXacNhan" Click="BtnXacNhan_Click" Width="130" Height="40" Style="{DynamicResource MacFluent.ButtonPrimary}" Cursor="Hand">
                    <TextBlock Text="Xác nhận đổi" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
