<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.DoiPhongDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Chuyển phòng"
    Width="450"
    Height="330"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Surface}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Heading}"
                    Text="🔀 Chuyển phòng" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.TextMuted}"
                    Text="Chọn phòng trống mới để chuyển khách sang" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Margin="0,0,0,20"
                Padding="16,12"
                Background="{DynamicResource Brush.SurfaceSoft}"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                        Text="Phòng hiện tại:" />
                    <Border
                        Margin="10,0,0,0"
                        Padding="8,2"
                        Background="{DynamicResource Brush.RoomOccupiedSoft}"
                        CornerRadius="6">
                        <TextBlock
                            x:Name="TxtPhongCu"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.RoomOccupied}"
                            Text="---" />
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Brush.TextLabel}"
                    Text="Phòng mới (Đang trống):" />
                <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                    <ComboBox
                        x:Name="CboPhongMoi"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="TenPhong"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextPrimary}"
                        SelectedValuePath="MaPhong" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="BtnHuy"
                    Grid.Column="0"
                    Height="40"
                    Click="BtnHuy_Click"
                    Content="Hủy bỏ"
                    Style="{DynamicResource MacFluent.ButtonSecondary}" />

                <Button
                    x:Name="BtnXacNhan"
                    Grid.Column="2"
                    Height="40"
                    Click="BtnXacNhan_Click"
                    Content="Xác nhận đổi"
                    Style="{DynamicResource MacFluent.ButtonPrimary}" />
            </Grid>
        </Grid>
    </Border>
</Window>