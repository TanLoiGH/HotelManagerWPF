<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.Dialogs.DoiPhongDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DoiPhongDialog"
    d:DesignHeight="450"
    d:DesignWidth="800"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d" WindowStyle="ToolWindow">

    <Border Padding="24" Background="{DynamicResource Brush.Surface}" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Heading}"
                    Text="🔀  Chuyển phòng" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.TextMuted}"
                    Text="Chọn phòng trống mới để chuyển khách sang" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Margin="0,0,0,16"
                Padding="16,12"
                Background="{DynamicResource Brush.SurfaceSoft}"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource Brush.TextPlaceholder}"
                        Text="Phòng hiện tại:" />
                    <Border
                        Margin="10,0,0,0"
                        Padding="8,2"
                        Background="{DynamicResource Brush.RoomOccupiedSoft}"
                        CornerRadius="6">
                        <TextBlock
                            x:Name="TxtPhongCu"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.RoomOccupied}"
                            Text="---" />
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Brush.TextPrimary}"
                    Text="Phòng mới (Đang trống)" />
                <Border
                    Height="42"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1.5"
                    CornerRadius="8">
                    <ComboBox
                        x:Name="CboPhongMoi"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="TenPhong"
                        FontSize="15"
                        SelectedValuePath="MaPhong" />
                </Border>
            </StackPanel>

            <StackPanel
                Grid.Row="3"
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    x:Name="BtnHuy"
                    Width="80"
                    Margin="0,0,12,0"
                    Background="Transparent"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1.5"
                    Click="BtnHuy_Click"
                    Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>
                    </Button.Resources>
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextPrimary}"
                        Text="Hủy" />
                </Button>

                <Button
                    x:Name="BtnXacNhan"
                    Width="130"
                    Click="BtnXacNhan_Click"
                    Cursor="Hand"
                    Style="{DynamicResource MacFluent.ButtonPrimary}">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Xác nhận đổi" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
