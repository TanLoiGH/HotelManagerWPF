<Window x:Class="QuanLyKhachSan_PhamTanLoi.Views.ChonDatPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn đặt phòng để xuất hóa đơn"
        Width="500" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="DpGrid" Grid.Row="0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" FontSize="15"
                  BorderBrush="#DDE" BorderThickness="1" RowHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã ĐP" Binding="{Binding MaDatPhong}" Width="90"/>
                <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                <DataGridTextColumn Header="Ngày đặt" Binding="{Binding NgayDatText}" Width="110"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Khuyến mãi áp dụng" FontSize="14" FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="CboKhuyenMai" Height="36"/>
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Hủy" Height="38" FontSize="15"
                    Click="BtnHuy_Click" Background="#F5F5F5" BorderThickness="0"/>
            <Button Grid.Column="2" Content="Xuất hóa đơn" Height="38"
                    FontSize="15" FontWeight="SemiBold"
                    Style="{DynamicResource MacFluent.ButtonPrimary}"
                    Click="BtnChon_Click"/>
        </Grid>
    </Grid>
</Window>
