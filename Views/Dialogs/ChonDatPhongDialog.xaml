<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.ChonDatPhongDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Chọn đặt phòng để xuất hóa đơn"
    Width="550"
    Height="500"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Surface}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{DynamicResource Brush.Heading}"
                Text="🧾 Chọn đặt phòng" />

            <Border
                Grid.Row="2"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                ClipToBounds="True"
                CornerRadius="8">
                <DataGrid
                    x:Name="DpGrid"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="40"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding MaDatPhong}"
                            Header="Mã ĐP" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenKhachHang}"
                            Header="Khách hàng" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding NgayDatText}"
                            Header="Ngày đặt" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding TrangThai}"
                            Header="Trạng thái" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="4">
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Brush.TextLabel}"
                    Text="🎁 Khuyến mãi áp dụng" />
                <Border Height="40" Style="{DynamicResource MacFluent.InputFrame}">
                    <ComboBox
                        x:Name="CboKhuyenMai"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextPrimary}" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Height="40"
                    Click="BtnHuy_Click"
                    Content="Hủy bỏ"
                    Style="{DynamicResource MacFluent.ButtonSecondary}" />
                <Button
                    Grid.Column="2"
                    Height="40"
                    Click="BtnChon_Click"
                    Content="Xuất hóa đơn"
                    Style="{DynamicResource MacFluent.ButtonPrimary}" />
            </Grid>
        </Grid>
    </Border>
</Window>