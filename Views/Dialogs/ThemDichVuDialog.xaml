<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.ThemDichVuDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Thêm Dịch Vụ"
    Width="480"
    Height="560"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0">
            <TextBlock
                FontSize="22"
                FontWeight="Bold"
                Text="Thêm dịch vụ" />
            <TextBlock
                FontSize="13"
                Opacity="0.7"
                Text="Chọn dịch vụ và số lượng để thêm vào phòng" />
        </StackPanel>

        <!--  Danh sách dịch vụ  -->
        <Border
            Grid.Row="2"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="10">

            <DataGrid
                x:Name="DichVuGrid"
                AutoGenerateColumns="False"
                FontSize="15"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                IsReadOnly="True"
                RowHeight="38"
                SelectionMode="Single">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding TenDichVu}"
                        Header="Tên dịch vụ" />

                    <DataGridTextColumn
                        Width="110"
                        Binding="{Binding GiaText}"
                        Header="Giá" />

                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding DonViTinh}"
                        Header="ĐVT" />

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!--  Form  -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <!--  Label  -->
            <StackPanel>
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Chọn phòng" />
                <TextBlock
                    FontSize="12"
                    Opacity="0.6"
                    Text="Phòng sẽ sử dụng dịch vụ" />
            </StackPanel>

            <!--  Combo  -->
            <Border
                Grid.Column="2"
                Height="36"
                CornerRadius="8"
                Style="{DynamicResource MacFluent.InputFrame}">

                <ComboBox
                    x:Name="CboPhong"
                    Padding="10,0"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    FontSize="15" />
            </Border>
        </Grid>

        <!--  Số lượng  -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Số lượng" />
                <TextBlock
                    FontSize="12"
                    Opacity="0.6"
                    Text="Số lượng dịch vụ sử dụng" />
            </StackPanel>

            <Border
                Grid.Column="2"
                Height="36"
                CornerRadius="8"
                Style="{DynamicResource MacFluent.InputFrame}">

                <TextBox
                    x:Name="TxtSoLuong"
                    Padding="10,0"
                    VerticalContentAlignment="Center"
                    BorderThickness="0"
                    FontSize="15"
                    Text="1"
                    TextAlignment="Right" />
            </Border>
        </Grid>

        <!--  Buttons  -->
        <Grid Grid.Row="8" Margin="0,18,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Height="38"
                Background="{DynamicResource Brush.SurfaceSecondary}"
                BorderThickness="0"
                Click="BtnHuy_Click"
                Content="Hủy"
                FontSize="15" />

            <Button
                Grid.Column="2"
                Height="38"
                Click="BtnChon_Click"
                Content="Thêm dịch vụ"
                FontSize="15"
                FontWeight="SemiBold"
                Style="{DynamicResource MacFluent.ButtonAction.Add}" />
        </Grid>

    </Grid>
</Window>