<Window
    x:Class="QuanLyKhachSan_PhamTanLoi.Views.ThemDichVuDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Thêm Dịch Vụ"
    Width="500"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Border
        Margin="15"
        Background="{DynamicResource Brush.Surface}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Brush.Heading}"
                    Text="🍽️ Thêm dịch vụ" />
                <TextBlock
                    FontSize="13"
                    Foreground="{DynamicResource Brush.TextMuted}"
                    Text="Chọn dịch vụ và số lượng để thêm vào phòng" />
            </StackPanel>

            <Border
                Grid.Row="2"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                ClipToBounds="True"
                CornerRadius="10">
                <DataGrid
                    x:Name="DichVuGrid"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="15"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                    IsReadOnly="True"
                    RowHeight="40"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TenDichVu}"
                            Header="Tên dịch vụ" />
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding GiaText}"
                            ElementStyle="{DynamicResource RightCell}"
                            Header="Giá" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding DonViTinh}"
                            ElementStyle="{DynamicResource CenterCell}"
                            Header="ĐVT" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Chọn phòng" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="Phòng sẽ sử dụng dịch vụ" />
                </StackPanel>
                <Border
                    Grid.Column="1"
                    Height="38"
                    Style="{DynamicResource MacFluent.InputFrame}">
                    <ComboBox
                        x:Name="CboPhong"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="15"
                        Foreground="{DynamicResource Brush.TextPrimary}" />
                </Border>
            </Grid>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextLabel}"
                        Text="Số lượng" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="Số lượng dịch vụ sử dụng" />
                </StackPanel>
                <Border
                    Grid.Column="1"
                    Height="38"
                    Style="{DynamicResource MacFluent.InputFrame}">
                    <TextBox
                        x:Name="TxtSoLuong"
                        Padding="10,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Brush.TextPrimary}"
                        Text="1"
                        TextAlignment="Right" />
                </Border>
            </Grid>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Height="40"
                    Click="BtnHuy_Click"
                    Content="Hủy bỏ"
                    IsCancel="True"
                    Style="{DynamicResource MacFluent.ButtonSecondary}" />
                <Button
                    Grid.Column="2"
                    Height="40"
                    Click="BtnChon_Click"
                    Content="Thêm dịch vụ"
                    Style="{DynamicResource MacFluent.ButtonAction.Add}" />
            </Grid>
        </Grid>
    </Border>
</Window>