<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.ChiPhiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Chi Phí">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar lọc -->
        <Border Grid.Row="0" CornerRadius="14" Background="{DynamicResource Brush.Surface}" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DatePicker x:Name="DpTuNgay" Grid.Column="0" Height="34" Width="140" FontSize="15"
                            SelectedDateChanged="Filter_Changed"/>
                <TextBlock Grid.Column="2" Text="→" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                <DatePicker x:Name="DpDenNgay" Grid.Column="4" Height="34" Width="140" FontSize="15"
                            SelectedDateChanged="Filter_Changed"/>

                <TextBlock x:Name="TxtTongChiPhi" Grid.Column="6"
                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.WarningText}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="8" Content="➕  Ghi chi phí"
                        Height="36" Padding="16,0" FontSize="15"
                        FontWeight="SemiBold" Foreground="White"
                        Background="#E17055" BorderThickness="0" Cursor="Hand"
                        Click="BtnThem_Click"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" CornerRadius="16" Background="{DynamicResource Brush.Surface}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <DataGrid x:Name="CpGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="15"
                      BorderThickness="0" Padding="8" RowHeight="44">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã CP" Binding="{Binding MaChiPhi}" Width="90"/>
                    <DataGridTextColumn Header="Tên chi phí" Binding="{Binding TenChiPhi}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding TenLoaiCp}" Width="130"/>
                    <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTienText}" Width="120"/>
                    <DataGridTextColumn Header="Ngày" Binding="{Binding NgayText}" Width="100"/>
                    <DataGridTextColumn Header="Nhà CC" Binding="{Binding TenNcc}" Width="140"/>
                    <DataGridTextColumn Header="Phòng" Binding="{Binding MaPhong}" Width="80"/>
                    <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="160"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF5F0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>

        <!-- Summary bar -->
        <Border Grid.Row="4" CornerRadius="12" Background="{DynamicResource Brush.Surface}" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <ItemsControl x:Name="SummaryItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,24,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Loai}" FontSize="15" Foreground="{DynamicResource Brush.TextLabel}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding TongText}" FontSize="15"
                                           FontWeight="Bold" Foreground="{DynamicResource Brush.WarningText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Page>

