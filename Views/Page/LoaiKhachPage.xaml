<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.LoaiKhachPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Hạng Khách Hàng">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <Border Grid.Column="0" CornerRadius="16" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,12" BorderBrush="#F0F5FA" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtTong" FontSize="14" FontWeight="Bold"
                                   Foreground="#0F3460" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="➕  Thêm hạng"
                                Height="36" Padding="16,0" FontSize="13"
                                FontWeight="SemiBold" Foreground="White"
                                Background="#00B894" BorderThickness="0" Cursor="Hand"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="LkGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="13"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="LkGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaLoaiKhach}" Width="90"/>
                        <DataGridTextColumn Header="Tên hạng" Binding="{Binding TenLoaiKhach}" Width="*"/>
                        <DataGridTextColumn Header="Ngưỡng tích lũy" Binding="{Binding NguongText}" Width="160"/>
                        <DataGridTextColumn Header="Số KH" Binding="{Binding SoKhachHang}" Width="80"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0FFF8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Form -->
        <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Chi tiết hạng khách"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#0F3460" Margin="0,0,0,20"/>

                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock Text="⭐" FontSize="48" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                    <TextBlock Text="Chọn hạng hoặc bấm Thêm mới"
                               FontSize="13" Foreground="#AAA"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock Text="Tên hạng *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="13"/>
                    </Border>

                    <TextBlock Text="Ngưỡng tích lũy (₫)" FontSize="12" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,8">
                        <TextBox x:Name="TxtNguong" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="13"
                                 TextAlignment="Right" Text="0"/>
                    </Border>
                    <TextBlock Text="Khách hàng đạt mức tích lũy này sẽ được nâng hạng tự động."
                               FontSize="11" Foreground="#888" Margin="0,0,0,20"
                               TextWrapping="Wrap"/>

                    <!-- Khuyến mãi áp dụng cho hạng này -->
                    <TextBlock Text="Khuyến mãi đang áp dụng" FontSize="13"
                               FontWeight="SemiBold" Foreground="#0F3460" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="KmList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="10,6" Margin="0,0,0,6"
                                        Background="#F5F0FF">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎁 " Foreground="#6C5CE7"/>
                                        <TextBlock Text="{Binding TenKhuyenMai}"
                                                   FontSize="12" Foreground="#333"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="TxtNoKm" Text="Chưa có khuyến mãi"
                               FontSize="12" Foreground="#BBB" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                Height="38" FontSize="13" Foreground="#E74C3C"
                                Background="#FEF0F0" BorderThickness="0" Cursor="Hand"
                                Click="BtnXoa_Click"/>
                        <Button Grid.Column="2" Content="💾 Lưu"
                                Height="38" FontSize="13" FontWeight="SemiBold"
                                Foreground="White" Background="#00B894"
                                BorderThickness="0" Cursor="Hand" Click="BtnLuu_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>