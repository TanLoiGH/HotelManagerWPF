<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.KhachHangPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Khách Hàng">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" CornerRadius="14" Background="White" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Stats -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTongKhach" FontSize="14" FontWeight="Bold"
                               Foreground="#0F3460" VerticalAlignment="Center"/>
                    <TextBlock Text=" khách hàng" FontSize="14" Foreground="#888"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Search -->
                <Border Grid.Column="2" CornerRadius="10" BorderBrush="#E0EAF4"
                        BorderThickness="1.5" Padding="10,0" Height="36">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtSearch" BorderThickness="0"
                                 Background="Transparent" VerticalAlignment="Center"
                                 FontSize="13" Width="160"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" CornerRadius="16" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <DataGrid x:Name="KhachGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="13"
                      BorderThickness="0" Padding="8"
                      RowHeight="44"
                      SelectionChanged="KhachGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKhachHang}" Width="90"/>
                    <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding DienThoai}" Width="120"/>
                    <DataGridTextColumn Header="CCCD" Binding="{Binding Cccd}" Width="140"/>
                    <DataGridTextColumn Header="Hạng" Binding="{Binding TenLoaiKhach}" Width="100"/>
                    <DataGridTextColumn Header="Tích lũy" Binding="{Binding TichLuyText}" Width="120"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F7FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
    </Grid>
</Page>