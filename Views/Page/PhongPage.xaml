<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.PhongPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:QuanLyKhachSan_PhamTanLoi.ViewModels"
      Background="Transparent" Title="Quản lý Phòng">

    <Page.Resources>
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#DDE8F4"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#4A6B8A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEF5FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterBtnActive" TargetType="Button" BasedOn="{StaticResource FilterBtn}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" CornerRadius="14" Background="White" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.07" Color="#0078D4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAll" Content="Tất cả" Tag="all"
                            Click="Filter_Click" Height="34" Padding="16,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtnActive}"/>
                    <Button Content="🟢 Trống" Tag="PTT01"
                            Click="Filter_Click" Height="34" Padding="14,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtn}"/>
                    <Button Content="🔴 Đang ở" Tag="PTT02"
                            Click="Filter_Click" Height="34" Padding="14,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtn}"/>
                    <Button Content="🟡 Dọn dẹp" Tag="PTT03"
                            Click="Filter_Click" Height="34" Padding="14,0" Margin="0,0,8,0"
                            Style="{StaticResource FilterBtn}"/>
                    <Button Content="🟣 Đã đặt" Tag="PTT05"
                            Click="Filter_Click" Height="34" Padding="14,0"
                            Style="{StaticResource FilterBtn}"/>
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="10" BorderBrush="#E0EAF4"
                        BorderThickness="1.5" Padding="10,0" Height="34" Width="200">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtSearch" BorderThickness="0"
                                 Background="Transparent" VerticalAlignment="Center"
                                 FontSize="13" TextChanged="TxtSearch_TextChanged" Width="150"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Room cards -->
            <Border Grid.Column="0" CornerRadius="16" Background="White" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07" Color="#0078D4"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtRoomCount" Grid.Row="0"
                               FontSize="13" Foreground="#888" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PhongList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="140" Height="120" Margin="8" CornerRadius="14"
                                            Background="{Binding CardBackground}" Cursor="Hand"
                                            MouseLeftButtonDown="PhongCard_Click" Tag="{Binding}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                              Color="{Binding ShadowColor}" Opacity="0.30"/>
                                        </Border.Effect>
                                        <Grid Margin="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MaPhong}"
                                                           FontSize="22" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding TenLoaiPhong}"
                                                           FontSize="11" Foreground="#DDF"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border Grid.Row="1" CornerRadius="6" Padding="6,3"
                                                    Background="#22FFFFFF" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TenTrangThai}"
                                                           FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right panel: Chi tiết + Form đặt phòng -->
            <Border Grid.Column="2" CornerRadius="16" Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07" Color="#0078D4"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- Empty state -->
                        <StackPanel x:Name="PanelEmpty" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🏠" FontSize="48" HorizontalAlignment="Center" Margin="0,40,0,12"/>
                            <TextBlock Text="Chọn một phòng để xem chi tiết và đặt phòng"
                                       FontSize="13" Foreground="#AAA" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Detail + Form -->
                        <StackPanel x:Name="PanelDetail" Visibility="Collapsed">

                            <!-- Room header -->
                            <Border x:Name="DetailHeader" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock x:Name="DetailMaPhong" FontSize="28"
                                                   FontWeight="Bold" Foreground="White"/>
                                        <TextBlock x:Name="DetailLoaiPhong" FontSize="13" Foreground="#DDEEFF"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="8" Padding="8,4" Background="#22FFFFFF">
                                        <TextBlock x:Name="DetailTrangThai" FontSize="11"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Thông tin phòng -->
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Sức chứa" FontSize="12" Foreground="#888"/>
                                <TextBlock x:Name="InfoSoNguoi" HorizontalAlignment="Right"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                            </Grid>
                            <Separator Background="#EEE" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Giá/đêm" FontSize="12" Foreground="#888"/>
                                <TextBlock x:Name="InfoGia" HorizontalAlignment="Right"
                                           FontSize="14" FontWeight="Bold" Foreground="#0078D4"/>
                            </Grid>

                            <!-- Tiện nghi -->
                            <TextBlock Text="Tiện nghi" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0F3460" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="TienNghiList" Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,0,4"
                                                Background="#F0F7FF">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="#0078D4" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding TenTienNghi}" FontSize="12" Foreground="#2C4A6E"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoTienNghi" Text="Chưa có tiện nghi"
                                       FontSize="12" Foreground="#BBB" Margin="0,0,0,12"/>

                            <!-- Divider -->
                            <Separator Background="#E0EAF4" Margin="0,4,0,16"/>

                            <!-- ══ FORM ĐẶT PHÒNG ══ -->
                            <StackPanel x:Name="PanelDatPhong">

                                <TextBlock Text="📅  Đặt phòng" FontSize="14" FontWeight="Bold"
                                           Foreground="#0F3460" Margin="0,0,0,14"/>

                                <!-- Tìm khách hàng -->
                                <TextBlock Text="Khách hàng" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555" Margin="0,0,0,4"/>
                                <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                        Height="36" Margin="0,0,0,4">
                                    <TextBox x:Name="TxtTimKhach" BorderThickness="0" Padding="10,0"
                                             VerticalAlignment="Center" FontSize="13"
                                             TextChanged="TxtTimKhach_TextChanged"/>
                                </Border>
                                <ListBox x:Name="ListKhach" MaxHeight="100" Visibility="Collapsed"
                                         SelectionChanged="ListKhach_SelectionChanged"
                                         DisplayMemberPath="TenKhachHang"
                                         BorderBrush="#DDE8F4" BorderThickness="1" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtKhachInfo" FontSize="11" Foreground="#0078D4"
                                           Visibility="Collapsed" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <!-- Khách mới -->
                                <Expander Header="➕ Khách mới" Margin="0,0,0,10">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Số điện thoại" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5" Height="34" Margin="0,0,0,8">
                                            <TextBox x:Name="TxtDienThoai" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="13"/>
                                        </Border>
                                        <TextBlock Text="CCCD" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5" Height="34">
                                            <TextBox x:Name="TxtCCCD" BorderThickness="0" Padding="10,0"
                                                     VerticalAlignment="Center" FontSize="13"/>
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Ngày nhận / trả -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ngày nhận" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#555" Margin="0,0,0,4"/>
                                        <DatePicker x:Name="DpNgayNhan" Height="34" FontSize="12"
                                                    SelectedDateChanged="DatePicker_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ngày trả" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#555" Margin="0,0,0,4"/>
                                        <DatePicker x:Name="DpNgayTra" Height="34" FontSize="12"
                                                    SelectedDateChanged="DatePicker_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Khuyến mãi -->
                                <TextBlock Text="Khuyến mãi" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CboKhuyenMai" Height="34" FontSize="12"
                                          Margin="0,0,0,10"
                                          SelectionChanged="CboKhuyenMai_Changed"/>

                                <!-- Tính giá -->
                                <Border CornerRadius="8" Padding="12,8" Background="#F0F7FF" Margin="0,0,0,14">
                                    <TextBlock x:Name="TxtTinhGia" FontSize="12" Foreground="#0F3460"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Nút xác nhận -->
                                <Button x:Name="BtnDatPhong" Height="44"
                                        FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                        Click="BtnDatPhong_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#0078D4" Offset="0"/>
                                                        <GradientStop Color="#00BCF2" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="📅  Xác nhận đặt phòng"
                                               FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </Button>

                            </StackPanel>

                            <!-- Thông báo phòng không trống -->
                            <Border x:Name="PanelKhongTrong" Visibility="Collapsed"
                                    CornerRadius="10" Padding="14,10" Background="#FFF3E0">
                                <TextBlock x:Name="TxtKhongTrong" FontSize="13" Foreground="#E17055"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>