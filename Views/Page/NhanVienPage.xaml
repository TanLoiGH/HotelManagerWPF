<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.NhanVienPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Nhân Viên">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <Border Grid.Column="0" CornerRadius="16" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,12" BorderBrush="#F0F5FA" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTongNV" FontSize="14" FontWeight="Bold"
                                       Foreground="#0F3460" VerticalAlignment="Center"/>
                            <Border CornerRadius="8" Padding="10,0" Height="34"
                                    BorderBrush="#E0EAF4" BorderThickness="1.5"
                                    Margin="16,0,0,0" Width="180">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtSearch" BorderThickness="0"
                                             Background="Transparent" VerticalAlignment="Center"
                                             FontSize="13" TextChanged="TxtSearch_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1" Content="➕  Thêm nhân viên"
                                Height="36" Padding="16,0" FontSize="13"
                                FontWeight="SemiBold" Foreground="White"
                                Background="#0F3460" BorderThickness="0" Cursor="Hand"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="NVGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="13"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="NVGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV" Binding="{Binding MaNhanVien}" Width="90"/>
                        <DataGridTextColumn Header="Tên nhân viên" Binding="{Binding TenNhanVien}" Width="*"/>
                        <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu}" Width="120"/>
                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding DienThoai}" Width="120"/>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TenTrangThai}" Width="100"/>
                        <DataGridTextColumn Header="Quyền" Binding="{Binding QuyenText}" Width="140"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0F7FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Form -->
        <Border Grid.Column="2" CornerRadius="16" Background="White" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtFormTitle" Text="Chi tiết nhân viên"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#0F3460" Margin="0,0,0,20"/>

                    <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                        <TextBlock Text="🪪" FontSize="48" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                        <TextBlock Text="Chọn nhân viên hoặc bấm Thêm mới"
                                   FontSize="13" Foreground="#AAA"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                        <TextBlock Text="Họ tên *" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Chức vụ" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtChucVu" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Điện thoại" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtDienThoai" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtEmail" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="CCCD" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtCCCD" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Trạng thái" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CboTrangThai" Height="34" FontSize="13"
                                  Margin="0,0,0,16"/>

                        <Separator Background="#EEE" Margin="0,0,0,16"/>

                        <!-- Tài khoản -->
                        <TextBlock Text="🔐 Tài khoản đăng nhập"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#0F3460" Margin="0,0,0,12"/>

                        <TextBlock Text="Tên đăng nhập" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <TextBox x:Name="TxtTenDangNhap" BorderThickness="0" Padding="10,0"
                                     VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Mật khẩu" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <Border CornerRadius="8" BorderBrush="#DDE8F4" BorderThickness="1.5"
                                Height="36" Margin="0,0,0,12">
                            <PasswordBox x:Name="PbMatKhau" BorderThickness="0" Padding="10,0"
                                         VerticalAlignment="Center" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Quyền" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CboQuyen" Height="34" FontSize="13"
                                  Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                    Height="38" FontSize="13" Foreground="#E74C3C"
                                    Background="#FEF0F0" BorderThickness="0" Cursor="Hand"
                                    Click="BtnXoa_Click"/>
                            <Button Grid.Column="2" x:Name="BtnLuu" Content="💾 Lưu"
                                    Height="38" FontSize="13" FontWeight="SemiBold"
                                    Foreground="White" Background="#0F3460"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnLuu_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>