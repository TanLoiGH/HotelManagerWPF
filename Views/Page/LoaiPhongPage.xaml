<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.LoaiPhongPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Loại Phòng">

    <Grid Margin="28,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách -->
        <Border Grid.Column="0" CornerRadius="16" Background="{DynamicResource Brush.Surface}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,12" BorderBrush="#F0F5FA" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtTong" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Heading}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="➕  Thêm loại phòng"
                                Height="36" Padding="16,0" FontSize="15"
                                FontWeight="SemiBold" Foreground="White"
                                Background="{DynamicResource Brush.BrandPrimary}" BorderThickness="0" Cursor="Hand"
                                Click="BtnThem_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="LpGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" FontSize="15"
                          BorderThickness="0" Padding="8" RowHeight="44"
                          SelectionChanged="LpGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaLoaiPhong}" Width="90"/>
                        <DataGridTextColumn Header="Tên loại phòng" Binding="{Binding TenLoaiPhong}" Width="*"/>
                        <DataGridTextColumn Header="Sức chứa" Binding="{Binding SoNguoiText}" Width="100"/>
                        <DataGridTextColumn Header="Giá/đêm" Binding="{Binding GiaPhongText}" Width="140"/>
                        <DataGridTextColumn Header="Số phòng" Binding="{Binding SoPhong}" Width="90"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Form -->
        <Border Grid.Column="2" CornerRadius="16" Background="{DynamicResource Brush.Surface}" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.07"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="Chi tiết loại phòng"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Heading}" Margin="0,0,0,20"/>

                <StackPanel x:Name="PanelEmpty" HorizontalAlignment="Center">
                    <TextBlock Text="🏠" FontSize="50" HorizontalAlignment="Center" Margin="0,30,0,12"/>
                    <TextBlock Text="Chọn loại phòng hoặc bấm Thêm mới"
                               FontSize="15" Foreground="#AAA"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="PanelForm" Visibility="Collapsed">

                    <TextBlock Text="Tên loại phòng *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtTen" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"/>
                    </Border>

                    <TextBlock Text="Sức chứa (người)" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,12">
                        <TextBox x:Name="TxtSoNguoi" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"
                                 TextAlignment="Right" Text="2"/>
                    </Border>

                    <TextBlock Text="Giá/đêm (₫) *" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextLabel}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1.5"
                            Height="36" Margin="0,0,0,20">
                        <TextBox x:Name="TxtGia" BorderThickness="0" Padding="10,0"
                                 VerticalAlignment="Center" FontSize="15"
                                 TextAlignment="Right"/>
                    </Border>

                    <!-- Danh sách phòng thuộc loại này -->
                    <TextBlock x:Name="TxtPhongList" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}"
                               Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnXoa" Content="🗑 Xóa"
                                Height="38" FontSize="15" Foreground="{DynamicResource Brush.Error}"
                                Background="#FEF0F0" BorderThickness="0" Cursor="Hand"
                                Click="BtnXoa_Click"/>
                        <Button Grid.Column="2" Content="💾 Lưu"
                                Height="38" FontSize="15" FontWeight="SemiBold"
                                Foreground="White" Background="{DynamicResource Brush.BrandPrimary}"
                                BorderThickness="0" Cursor="Hand" Click="BtnLuu_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

