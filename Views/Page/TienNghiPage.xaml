<Page x:Class="QuanLyKhachSan_PhamTanLoi.Views.TienNghiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
      Background="Transparent"
      Title="Tiện Nghi">

    <Grid Margin="28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ContentControl Grid.Row="0"
                        Background="{DynamicResource Brush.Surface}" Padding="16,12"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="14"
                        helpers:ThemeProperties.ShadowBlurRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Phòng" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboPhong" Height="34" FontSize="15"
                              SelectionChanged="CboPhong_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Cập nhật trạng thái" FontSize="14" Foreground="{DynamicResource Brush.TextPlaceholder}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CboTrangThai" Height="34" FontSize="15"/>
                </StackPanel>

                <TextBlock x:Name="TxtAlert" Grid.Column="3" FontSize="15"
                           Foreground="{DynamicResource Brush.WarningText}" VerticalAlignment="Center"
                           Margin="16,0" Visibility="Collapsed"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="Cập nhật" Height="34" Padding="16,0" FontSize="15"
                            Style="{DynamicResource MacFluent.ButtonAction.Edit}"
                            Click="BtnCapNhat_Click" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Chi phí sửa chữa (₫)" FontSize="13" Foreground="{DynamicResource Brush.TextPlaceholder}" Margin="0,0,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" BorderBrush="#DDE" BorderThickness="1.5">
                                <TextBox x:Name="TxtChiPhiSuaChua" BorderThickness="0" Padding="8,0"
                                         VerticalAlignment="Center" FontSize="15" Height="30"/>
                            </Border>
                            <Button Grid.Column="2" Content="Ghi" Height="30" Padding="10,0"
                                    FontSize="15"
                                    Style="{DynamicResource MacFluent.ButtonAction.Edit}"
                                    Click="BtnGhiSuaChua_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ContentControl>

        <!-- DataGrid tiện nghi -->
        <ContentControl Grid.Row="2"
                        Background="{DynamicResource Brush.Surface}"
                        BorderThickness="0"
                        Style="{DynamicResource MacFluent.ShadowCard}"
                        helpers:ThemeProperties.CornerRadius="16">
            <DataGrid x:Name="TienNghiGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="15"
                      BorderThickness="0" Padding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên tiện nghi" Binding="{Binding TenTienNghi}" Width="*"/>
                    <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding TenNCC}" Width="160"/>
                    <DataGridTextColumn Header="Hạn bảo hành" Binding="{Binding HanBaoHanhText}" Width="120"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TenTrangThai}" Width="130"/>
                    <DataGridCheckBoxColumn Header="Cần bảo trì" Binding="{Binding CanBaoTri}" Width="90"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanBaoTri}" Value="True">
                                <Setter Property="Background" Value="#FFF3E0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </ContentControl>
    </Grid>
</Page>


