<!-- ===== DARK CORE COLORS ===== -->
<ResourceDictionary 
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">



    <!-- Nền chính: Xám đen sâu -->
    <Color x:Key="Color.Background">#1C1C1E</Color>
    <!-- Các card/thẻ nổi lên trên nền: Xám nhẹ hơn -->
    <Color x:Key="Color.Surface">#2C2C2E</Color>
    <!-- Border: Cần sáng hơn nền một chút để phân tách -->
    <Color x:Key="Color.Border">#3A3A3C</Color>

    <!-- Chữ chính: Trắng ngà (giảm chói) -->
    <Color x:Key="Key.TextPrimary">#F2F2F7</Color>
    <!-- Chữ phụ: Xám nhạt -->
    <Color x:Key="Color.TextSecondary">#8E8E93</Color>

    <!-- Màu Accent: Giữ nguyên Blue hoặc làm sáng nhẹ lên 1 tông -->
    <Color x:Key="Color.Accent">#0A84FF</Color>
    <Color x:Key="Color.AccentHover">#409CFF</Color>

    <!-- Màu trạng thái (Bổ sung cho hoàn thiện) -->
    <Color x:Key="Color.Error">#FF453A</Color>
    <Color x:Key="Color.Success">#32D74B</Color>

    <!-- ===== BRUSHES ===== -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}"/>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}"/>

    <!-- Hiệu ứng Glass cho Dark Mode: Dùng màu đen mờ -->
    <LinearGradientBrush x:Key="Brush.GlassOverlay" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#20FFFFFF" Offset="0"/>
        <GradientStop Color="#05FFFFFF" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
