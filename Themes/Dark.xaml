<!-- ===== DARK CORE COLORS ===== -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Background">#0B0F14</Color>
    <Color x:Key="Color.Surface">#141A22</Color>
    <Color x:Key="Color.Border">#233042</Color>

    <Color x:Key="Color.TextPrimary">#E6EDF6</Color>
    <Color x:Key="Color.TextSecondary">#9BA7B4</Color>

    <Color x:Key="Color.BrandPrimary">#10B981</Color>
    <Color x:Key="Color.BrandSecondary">#38BDF8</Color>
    <Color x:Key="Color.Accent">#10B981</Color>
    <Color x:Key="Color.AccentHover">#38BDF8</Color>

    <Color x:Key="Color.Heading">#DCE7F3</Color>
    <Color x:Key="Color.TextMuted">#9FB2C8</Color>
    <Color x:Key="Color.TextLabel">#C9D4E1</Color>
    <Color x:Key="Color.TextPlaceholder">#8A97A6</Color>
    <Color x:Key="Color.TextSubtle">#6E7B88</Color>

    <Color x:Key="Color.SurfaceAlt">#0F1620</Color>
    <Color x:Key="Color.SurfaceSoft">#111E2A</Color>
    <Color x:Key="Color.Hover">#1C2633</Color>

    <Color x:Key="Color.WarningSurface">#2A1D0B</Color>
    <Color x:Key="Color.WarningText">#FBBF24</Color>
    <Color x:Key="Color.Error">#F43F5E</Color>
    <Color x:Key="Color.Success">#22C55E</Color>

    <!-- Nav (Sidebar) tokens -->
    <Color x:Key="Color.NavStart">#0B1220</Color>
    <Color x:Key="Color.NavMid">#0F1E33</Color>
    <Color x:Key="Color.NavEnd">#0A1627</Color>
    <Color x:Key="Color.NavText">#FFFFFF</Color>
    <Color x:Key="Color.NavMuted">#9FB2C8</Color>
    <Color x:Key="Color.NavGroupLabel">#6B8BA8</Color>
    <Color x:Key="Color.NavHover">#123047</Color>
    <Color x:Key="Color.NavSelected">#0F3D3E</Color>
    <Color x:Key="Color.NavChip">#10B981</Color>
    <Color x:Key="Color.NavProfileBg">#0A1B2E</Color>

    <!-- ===== BRUSHES ===== -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.TextLabel" Color="{StaticResource Color.TextLabel}" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="{StaticResource Color.TextPlaceholder}" />
    <SolidColorBrush x:Key="Brush.TextSubtle" Color="{StaticResource Color.TextSubtle}" />
    <SolidColorBrush x:Key="Brush.Heading" Color="{StaticResource Color.Heading}" />

    <SolidColorBrush x:Key="Brush.BrandPrimary" Color="{StaticResource Color.BrandPrimary}" />
    <SolidColorBrush x:Key="Brush.BrandSecondary" Color="{StaticResource Color.BrandSecondary}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />

    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.SurfaceSoft" Color="{StaticResource Color.SurfaceSoft}" />
    <SolidColorBrush x:Key="Brush.Hover" Color="{StaticResource Color.Hover}" />

    <SolidColorBrush x:Key="Brush.WarningSurface" Color="{StaticResource Color.WarningSurface}" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="{StaticResource Color.WarningText}" />

    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}" />

    <SolidColorBrush x:Key="Brush.NavText" Color="{StaticResource Color.NavText}" />
    <SolidColorBrush x:Key="Brush.NavMuted" Color="{StaticResource Color.NavMuted}" />
    <SolidColorBrush x:Key="Brush.NavGroupLabel" Color="{StaticResource Color.NavGroupLabel}" />
    <SolidColorBrush x:Key="Brush.NavHover" Color="{StaticResource Color.NavHover}" />
    <SolidColorBrush x:Key="Brush.NavSelected" Color="{StaticResource Color.NavSelected}" />
    <SolidColorBrush x:Key="Brush.NavChip" Color="{StaticResource Color.NavChip}" />
    <SolidColorBrush x:Key="Brush.NavProfileBg" Color="{StaticResource Color.NavProfileBg}" />

    <LinearGradientBrush x:Key="Brush.BrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Color.BrandPrimary}" Offset="0" />
        <GradientStop Color="{StaticResource Color.BrandSecondary}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.GlassOverlay" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#20FFFFFF" Offset="0" />
        <GradientStop Color="#05FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.NavGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Color.NavStart}" Offset="0" />
        <GradientStop Color="{StaticResource Color.NavMid}" Offset="0.5" />
        <GradientStop Color="{StaticResource Color.NavEnd}" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
