<!--  ===== LIGHT CORE COLORS =====  -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ===== BASE COLORS (Nền giao diện) =====  -->
    <Color x:Key="Color.Background">#F5F7FA</Color>
    <Color x:Key="Color.SurfacePrimary">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceSecondary">#F1F5F9</Color>
    <Color x:Key="Color.SurfaceSoft">#EEF2F7</Color>
    <Color x:Key="Color.BorderDefault">#E2E8F0</Color>
    <Color x:Key="Color.BorderStrong">#CBD5E1</Color>
    <Color x:Key="Color.Shadow">#15000000</Color>

    <!--  Legacy mappings for compatibility  -->
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.Border">#E2E8F0</Color>
    <Color x:Key="Color.SurfaceAlt">#F1F5F9</Color>

    <!--  ===== TEXT HIERARCHY =====  -->
    <Color x:Key="Color.TextHeading">#0F172A</Color>
    <Color x:Key="Color.TextPrimary">#1E293B</Color>
    <Color x:Key="Color.TextSecondary">#475569</Color>
    <Color x:Key="Color.TextMuted">#64748B</Color>
    <Color x:Key="Color.TextDisabled">#94A3B8</Color>

    <!--  Legacy text mappings  -->
    <Color x:Key="Color.Heading">#0F172A</Color>
    <Color x:Key="Color.TextSubtle">#64748B</Color>
    <Color x:Key="Color.TextLabel">#475569</Color>
    <Color x:Key="Color.TextPlaceholder">#94A3B8</Color>

    <!--  ===== BRAND COLORS (Màu thương hiệu) =====  -->
    <Color x:Key="Color.BrandPrimary">#739FFE</Color>
    <Color x:Key="Color.BrandHover">#1D4ED8</Color>
    <Color x:Key="Color.BrandPressed">#1E40AF</Color>
    <Color x:Key="Color.BrandSoft">#DBEAFE</Color>
    <Color x:Key="Color.BrandBorder">#93C5FD</Color>

    <!--  ===== ROOM STATUS COLORS (Luxury Refined) =====  -->
    <Color x:Key="Color.RoomAvailable">#10B981</Color>
    <Color x:Key="Color.RoomOccupied">#E11D48</Color>
    <Color x:Key="Color.RoomCleaning">#F59E0B</Color>
    <Color x:Key="Color.RoomReserved">#6366F1</Color>
    <Color x:Key="Color.RoomMaintenance">#64748B</Color>

    <!--  Soft Status Colors (For Badges)  -->
    <Color x:Key="Color.RoomAvailableSoft">#D1FAE5</Color>
    <Color x:Key="Color.RoomOccupiedSoft">#FFE4E6</Color>
    <Color x:Key="Color.RoomCleaningSoft">#FEF3C7</Color>
    <Color x:Key="Color.RoomReservedSoft">#E0E7FF</Color>
    <Color x:Key="Color.RoomMaintenanceSoft">#F1F5F9</Color>

    <!--  ===== OPERATIONAL STATUS COLORS =====  -->
    <Color x:Key="Color.Success">#16A34A</Color>
    <Color x:Key="Color.Warning">#F59E0B</Color>
    <Color x:Key="Color.Error">#DC2626</Color>
    <Color x:Key="Color.Info">#0284C7</Color>

    <Color x:Key="Color.WarningSurface">#FEF3C7</Color>
    <Color x:Key="Color.WarningText">#92400E</Color>

    <!--  ===== SIDEBAR COLOR SYSTEM (Nền tối) =====  -->
    <Color x:Key="Color.SidebarBackground">#1E293B</Color>
    <Color x:Key="Color.SidebarSurface">#33BFC0C6</Color>
    <Color x:Key="Color.SidebarBorder">#B7181414</Color>
    <Color x:Key="Color.SidebarText">#E2E8F0</Color>
    <Color x:Key="Color.SidebarTextMuted">#94A3B8</Color>
    <Color x:Key="Color.SidebarActive">#2563EB</Color>


    <!--  Sidebar legacy mappings  -->
    <Color x:Key="Color.NavStart">#1E293B</Color>
    <Color x:Key="Color.NavMid">#1E293B</Color>
    <Color x:Key="Color.NavEnd">#1E293B</Color>
    <Color x:Key="Color.NavText">#E2E8F0</Color>
    <Color x:Key="Color.NavMuted">#94A3B8</Color>
    <Color x:Key="Color.NavGroupLabel">#94A3B8</Color>
    <Color x:Key="Color.NavHover">#334155</Color>
    <Color x:Key="Color.NavSelected">#2563EB</Color>
    <Color x:Key="Color.NavChip">#EEF2FF</Color>
    <Color x:Key="Color.NavProfileBg">#273449</Color>

    <!--  ===== BRUSHES =====  -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.SurfacePrimary}" />
    <SolidColorBrush x:Key="Brush.SurfaceSecondary" Color="{StaticResource Color.SurfaceSecondary}" />
    <SolidColorBrush x:Key="Brush.SurfaceSoft" Color="{StaticResource Color.SurfaceSoft}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.BorderDefault}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />

    <!--  Text brushes  -->
    <SolidColorBrush x:Key="Brush.TextHeading" Color="{StaticResource Color.TextHeading}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.TextDisabled" Color="{StaticResource Color.TextDisabled}" />

    <!--  Legacy text brushes  -->
    <SolidColorBrush x:Key="Brush.Heading" Color="{StaticResource Color.TextHeading}" />
    <SolidColorBrush x:Key="Brush.TextLabel" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="{StaticResource Color.TextDisabled}" />
    <SolidColorBrush x:Key="Brush.TextSubtle" Color="{StaticResource Color.TextMuted}" />

    <!--  Brand brushes  -->
    <SolidColorBrush x:Key="Brush.BrandPrimary" Color="{StaticResource Color.BrandPrimary}" />
    <SolidColorBrush x:Key="Brush.BrandHover" Color="{StaticResource Color.BrandHover}" />
    <SolidColorBrush x:Key="Brush.BrandPressed" Color="{StaticResource Color.BrandPressed}" />
    <SolidColorBrush x:Key="Brush.BrandSoft" Color="{StaticResource Color.BrandSoft}" />
    <SolidColorBrush x:Key="Brush.BrandBorder" Color="{StaticResource Color.BrandBorder}" />

    <!--  Legacy brand mapping  -->
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.BrandPrimary}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.BrandHover}" />

    <!--  Room Status brushes  -->
    <SolidColorBrush x:Key="Brush.RoomAvailable" Color="{StaticResource Color.RoomAvailable}" />
    <SolidColorBrush x:Key="Brush.RoomOccupied" Color="{StaticResource Color.RoomOccupied}" />
    <SolidColorBrush x:Key="Brush.RoomCleaning" Color="{StaticResource Color.RoomCleaning}" />
    <SolidColorBrush x:Key="Brush.RoomReserved" Color="{StaticResource Color.RoomReserved}" />
    <SolidColorBrush x:Key="Brush.RoomMaintenance" Color="{StaticResource Color.RoomMaintenance}" />

    <!--  Soft Status brushes  -->
    <SolidColorBrush x:Key="Brush.RoomAvailableSoft" Color="{StaticResource Color.RoomAvailableSoft}" />
    <SolidColorBrush x:Key="Brush.RoomOccupiedSoft" Color="{StaticResource Color.RoomOccupiedSoft}" />
    <SolidColorBrush x:Key="Brush.RoomCleaningSoft" Color="{StaticResource Color.RoomCleaningSoft}" />
    <SolidColorBrush x:Key="Brush.RoomReservedSoft" Color="{StaticResource Color.RoomReservedSoft}" />
    <SolidColorBrush x:Key="Brush.RoomMaintenanceSoft" Color="{StaticResource Color.RoomMaintenanceSoft}" />

    <!--  Operational brushes  -->
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}" />

    <SolidColorBrush x:Key="Brush.WarningSurface" Color="{StaticResource Color.WarningSurface}" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="{StaticResource Color.WarningText}" />
    <SolidColorBrush x:Key="Brush.ErrorSoft" Color="{StaticResource Color.RoomOccupiedSoft}" />

    <!--  Sidebar brushes  -->
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="{StaticResource Color.SidebarBackground}" />
    <SolidColorBrush x:Key="Brush.SidebarSurface" Color="{StaticResource Color.SidebarSurface}" />
    <SolidColorBrush x:Key="Brush.SidebarBorder" Color="{StaticResource Color.SidebarBorder}" />
    <SolidColorBrush x:Key="Brush.SidebarText" Color="{StaticResource Color.SidebarText}" />
    <SolidColorBrush x:Key="Brush.SidebarTextMuted" Color="{StaticResource Color.SidebarTextMuted}" />
    <SolidColorBrush x:Key="Brush.SidebarActive" Color="{StaticResource Color.SidebarActive}" />

    <!--  Legacy nav brushes  -->
    <SolidColorBrush x:Key="Brush.NavText" Color="{StaticResource Color.NavText}" />
    <SolidColorBrush x:Key="Brush.NavMuted" Color="{StaticResource Color.NavMuted}" />
    <SolidColorBrush x:Key="Brush.NavGroupLabel" Color="{StaticResource Color.NavGroupLabel}" />
    <SolidColorBrush x:Key="Brush.NavHover" Color="{StaticResource Color.NavHover}" />
    <SolidColorBrush x:Key="Brush.NavSelected" Color="{StaticResource Color.NavSelected}" />
    <SolidColorBrush x:Key="Brush.NavChip" Color="{StaticResource Color.NavChip}" />
    <SolidColorBrush x:Key="Brush.NavProfileBg" Color="{StaticResource Color.NavProfileBg}" />

    <!--  Action (Semantic Buttons) mapping  -->
    <SolidColorBrush x:Key="Brush.Action.Add" Color="{StaticResource Color.BrandPrimary}" />
    <SolidColorBrush x:Key="Brush.Action.AddHover" Color="{StaticResource Color.BrandHover}" />
    <SolidColorBrush x:Key="Brush.Action.AddPressed" Color="{StaticResource Color.BrandPressed}" />
    <SolidColorBrush x:Key="Brush.Action.AddSoft" Color="{StaticResource Color.BrandSoft}" />
    <SolidColorBrush x:Key="Brush.Action.AddSoftHover" Color="{StaticResource Color.BrandBorder}" />
    <SolidColorBrush x:Key="Brush.Action.AddSoftPressed" Color="{StaticResource Color.BrandBorder}" />
    <SolidColorBrush x:Key="Brush.Action.AddText" Color="#FFFFFF" />

    <SolidColorBrush x:Key="Brush.Action.Edit" Color="{StaticResource Color.RoomCleaning}" />
    <SolidColorBrush x:Key="Brush.Action.EditHover" Color="#D97706" />
    <SolidColorBrush x:Key="Brush.Action.EditPressed" Color="#B45309" />
    <SolidColorBrush x:Key="Brush.Action.EditSoft" Color="{StaticResource Color.RoomCleaningSoft}" />
    <SolidColorBrush x:Key="Brush.Action.EditSoftHover" Color="{StaticResource Color.RoomCleaningSoft}" />
    <SolidColorBrush x:Key="Brush.Action.EditSoftPressed" Color="{StaticResource Color.RoomCleaningSoft}" />
    <SolidColorBrush x:Key="Brush.Action.EditText" Color="#FFFFFF" />

    <SolidColorBrush x:Key="Brush.Action.Delete" Color="{StaticResource Color.RoomOccupied}" />
    <SolidColorBrush x:Key="Brush.Action.DeleteHover" Color="#DC2626" />
    <SolidColorBrush x:Key="Brush.Action.DeletePressed" Color="#B91C1C" />
    <SolidColorBrush x:Key="Brush.Action.DeleteSoft" Color="{StaticResource Color.RoomOccupiedSoft}" />
    <SolidColorBrush x:Key="Brush.Action.DeleteSoftHover" Color="{StaticResource Color.RoomOccupiedSoft}" />
    <SolidColorBrush x:Key="Brush.Action.DeleteSoftPressed" Color="{StaticResource Color.RoomOccupiedSoft}" />
    <SolidColorBrush x:Key="Brush.Action.DeleteText" Color="#FFFFFF" />

    <SolidColorBrush x:Key="Brush.Filter.Border" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.Filter.Text" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.Filter.Hover" Color="{StaticResource Color.SurfaceSecondary}" />
    <SolidColorBrush x:Key="Brush.Filter.Active" Color="{StaticResource Color.BrandSoft}" />
    <SolidColorBrush x:Key="Brush.Filter.ActiveText" Color="{StaticResource Color.BrandPrimary}" />
    <SolidColorBrush x:Key="Brush.Filter.ActiveHover" Color="{StaticResource Color.BrandBorder}" />

    <!--  Gradients  -->
    <LinearGradientBrush x:Key="Brush.NavGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource Color.NavStart}" />
        <GradientStop Offset="1" Color="{StaticResource Color.NavEnd}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.BrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Offset="0" Color="{StaticResource Color.BrandPrimary}" />
        <GradientStop Offset="1" Color="{StaticResource Color.BrandHover}" />
    </LinearGradientBrush>

    <!--  Misc  -->
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.Hover" Color="{StaticResource Color.SurfaceSecondary}" />
    <SolidColorBrush
        x:Key="Brush.OverlayWhite20"
        Opacity="0.20"
        Color="#FFFFFF" />
    <SolidColorBrush
        x:Key="Brush.OverlayBlack13"
        Opacity="0.13"
        Color="#000000" />

    <!--  DataGrid Specific Brushes (Light)  -->
    <SolidColorBrush x:Key="Brush.DataGrid.HeaderBackground" Color="#EEF2F7" />
    <SolidColorBrush x:Key="Brush.DataGrid.HeaderForeground" Color="#1F2937" />
    <SolidColorBrush x:Key="Brush.DataGrid.HeaderBorder" Color="#CBD5E1" />
    <SolidColorBrush x:Key="Brush.DataGrid.RowHover" Color="#E5E7EB" />

</ResourceDictionary>
