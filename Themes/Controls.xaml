<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:QuanLyKhachSan_PhamTanLoi.Helpers"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  macOS (soft, spacious, glassy) + Fluent (clear layers, responsive states)  -->

    <!--  Typography  -->
    <FontFamily x:Key="Font.Primary">Segoe UI Variable Text, Roboto-Regular</FontFamily>


    <sys:Double x:Key="Font.Size.Caption">13</sys:Double>
    <sys:Double x:Key="Font.Size.Body">16</sys:Double>
    <sys:Double x:Key="Font.Size.BodyLarge">17</sys:Double>
    <sys:Double x:Key="Font.Size.Subtitle">19</sys:Double>
    <sys:Double x:Key="Font.Size.Title">24</sys:Double>
    <sys:Double x:Key="Font.Size.Hero">30</sys:Double>

    <!--  Radii  -->
    <CornerRadius x:Key="Radius.S">8</CornerRadius>
    <CornerRadius x:Key="Radius.M">14</CornerRadius>
    <CornerRadius x:Key="Radius.L">16</CornerRadius>
    <CornerRadius x:Key="Radius.XL">20</CornerRadius>

    <!--  Spacing  -->
    <Thickness x:Key="Pad.S">10,6</Thickness>
    <Thickness x:Key="Pad.M">14,8</Thickness>
    <Thickness x:Key="Pad.L">16,10</Thickness>

    <!--  Shared room grid sizing (system-wide alignment)  -->
    <sys:Double x:Key="RoomCard.Width">160</sys:Double>
    <sys:Double x:Key="RoomCard.Height">140</sys:Double>
    <Thickness x:Key="RoomCard.Margin">10</Thickness>
    <Thickness x:Key="RoomGrid.Padding">24,0,24,0</Thickness>

    <!--  Layer / material brushes  -->
    <LinearGradientBrush x:Key="Brush.MicaLike" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#FAFFFFFF" />
        <GradientStop Offset="0.35" Color="#F2FFFFFF" />
        <GradientStop Offset="1" Color="#E8FFFFFF" />
    </LinearGradientBrush>



    <SolidColorBrush
        x:Key="Brush.SurfaceTranslucent"
        Opacity="0.92"
        Color="{StaticResource Color.Surface}" />

    <!--  Reduce subpixel layout fuzz across the app  -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    </Style>

    <Style TargetType="{x:Type Page}">
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    </Style>


    <Style TargetType="{x:Type UserControl}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    </Style>

    <!--  Text defaults  -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
    </Style>

    <!--  Card-like border  -->
    <Style x:Key="MacFluent.Card" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.L}" />
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceTranslucent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="22"
                    Opacity="0.10"
                    ShadowDepth="2"
                    Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="MacFluent.Toolbar"
        BasedOn="{StaticResource MacFluent.Card}"
        TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.XL}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="18"
                    Opacity="0.08"
                    ShadowDepth="1"
                    Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Shadow host for crisp text (shadow is rendered behind content)  -->
    <Style x:Key="MacFluent.ShadowCard" TargetType="{x:Type ContentControl}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="helpers:ThemeProperties.CornerRadius" Value="{StaticResource Radius.L}" />
        <Setter Property="helpers:ThemeProperties.ShadowColor" Value="#000000" />
        <Setter Property="helpers:ThemeProperties.ShadowBlurRadius" Value="15" />
        <Setter Property="helpers:ThemeProperties.ShadowDepth" Value="5" />
        <Setter Property="helpers:ThemeProperties.ShadowOpacity" Value="0.2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.CornerRadius)}">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.ShadowBlurRadius)}"
                                    Opacity="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.ShadowOpacity)}"
                                    ShadowDepth="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.ShadowDepth)}"
                                    Color="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.ShadowColor)}" />
                            </Border.Effect>
                        </Border>
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.CornerRadius)}">
                            <ContentPresenter />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Room card: consistent sizing + hover animation  -->
    <Style
        x:Key="MacFluent.RoomCard"
        BasedOn="{StaticResource MacFluent.ShadowCard}"
        TargetType="{x:Type ContentControl}">
        <Setter Property="Width" Value="{StaticResource RoomCard.Width}" />
        <Setter Property="Height" Value="{StaticResource RoomCard.Height}" />
        <Setter Property="Margin" Value="{StaticResource RoomCard.Margin}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="helpers:ThemeProperties.CornerRadius" Value="14" />
        <Setter Property="helpers:ThemeProperties.ShadowBlurRadius" Value="20" />
        <Setter Property="helpers:ThemeProperties.ShadowDepth" Value="0" />
        <Setter Property="helpers:ThemeProperties.ShadowOpacity" Value="0.50" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                            To="1.04"
                            Duration="0:0:0.12" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                            To="1.04"
                            Duration="0:0:0.12" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                            To="1"
                            Duration="0:0:0.14" />
                        <DoubleAnimation
                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                            To="1"
                            Duration="0:0:0.14" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!--  Input frame: keep the view's internal TextBox/PasswordBox, but unify the border  -->
    <Style x:Key="MacFluent.InputFrame" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.M}" />
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}" />
        <Setter Property="BorderThickness" Value="1.2" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BrandPrimary}" />
                <Setter Property="BorderThickness" Value="1.6" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.BrandPrimary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.BrandSoft}" />
        <Setter Property="SelectionTextBrush" Value="{DynamicResource Brush.TextHeading}" />
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.BrandPrimary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.BrandSoft}" />
        <Setter Property="SelectionTextBrush" Value="{DynamicResource Brush.TextHeading}" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BrandPrimary}" />
                <Setter Property="BorderThickness" Value="1.6" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DatePicker}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BrandPrimary}" />
                <Setter Property="BorderThickness" Value="1.6" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="RowBackground" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.SurfaceSecondary}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSoft}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.BrandSoft}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.TextHeading}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Brush.TextHeading}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Buttons  -->
    <Style x:Key="MacFluent.ButtonBase" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="{StaticResource Pad.M}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="helpers:ThemeProperties.CornerRadius" Value="{StaticResource Radius.M}" />
        <Setter Property="helpers:ThemeProperties.HoverBackground" Value="{DynamicResource Brush.SurfaceSecondary}" />
        <Setter Property="helpers:ThemeProperties.PressedBackground" Value="{DynamicResource Brush.SurfaceSoft}" />
        <Setter Property="helpers:ThemeProperties.HoverBorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="helpers:ThemeProperties.PressedBorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="helpers:ThemeProperties.DisabledOpacity" Value="0.55" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.CornerRadius)}">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.HoverBackground)}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.HoverBorderBrush)}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.PressedBackground)}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.PressedBorderBrush)}" />
                            <Setter TargetName="Bd" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.DisabledOpacity)}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacFluent.ButtonGhost" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="helpers:ThemeProperties.CornerRadius" Value="{StaticResource Radius.M}" />
        <Setter Property="helpers:ThemeProperties.HoverBackground" Value="{DynamicResource Brush.Hover}" />
        <Setter Property="helpers:ThemeProperties.PressedBackground" Value="{DynamicResource Brush.SurfaceSoft}" />
        <Setter Property="helpers:ThemeProperties.DisabledOpacity" Value="0.55" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.CornerRadius)}">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.HoverBackground)}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.PressedBackground)}" />
                            <Setter TargetName="Bd" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.DisabledOpacity)}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style
        x:Key="MacFluent.ButtonPrimary"
        BasedOn="{StaticResource MacFluent.ButtonBase}"
        TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Brush.BrandPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="helpers:ThemeProperties.HoverBackground" Value="{DynamicResource Brush.BrandHover}" />
        <Setter Property="helpers:ThemeProperties.PressedBackground" Value="{DynamicResource Brush.BrandPressed}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <!--  NOTE: Không đặt Effect lên border chứa text (ClearType sẽ bị tắt -> chữ mờ).  -->
                    <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5">
                        <Border
                            x:Name="Shadow"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.M}">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="12"
                                    Opacity="0.12"
                                    ShadowDepth="1"
                                    Color="{DynamicResource Color.BrandPrimary}" />
                            </Border.Effect>
                        </Border>
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.M}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.HoverBackground)}" />
                            <Setter TargetName="Shadow" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.HoverBackground)}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.PressedBackground)}" />
                            <Setter TargetName="Shadow" Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:ThemeProperties.PressedBackground)}" />
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                            <Setter TargetName="Shadow" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="MacFluent.ButtonSecondary"
        BasedOn="{StaticResource MacFluent.ButtonBase}"
        TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="helpers:ThemeProperties.HoverBackground" Value="{DynamicResource Brush.SurfaceSoft}" />
        <Setter Property="helpers:ThemeProperties.PressedBackground" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="helpers:ThemeProperties.HoverBorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
        <Setter Property="helpers:ThemeProperties.PressedBorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
    </Style>

    <!--  Action buttons (semantic tokens)  -->
    <Style
        x:Key="MacFluent.ButtonAction.Add"
        BasedOn="{StaticResource MacFluent.ButtonBase}"
        TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Brush.Action.Add}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Action.Add}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Action.AddText}" />
        <Setter Property="helpers:ThemeProperties.HoverBackground" Value="{DynamicResource Brush.Action.AddHover}" />
        <Setter Property="helpers:ThemeProperties.PressedBackground" Value="{DynamicResource Brush.Action.AddPressed}" />
        <Setter Property="helpers:ThemeProperties.HoverBorderBrush" Value="{DynamicResource Brush.Action.AddHover}" />
        <Setter Property="helpers:ThemeProperties.PressedBorderBrush" Value="{DynamicResource Brush.Action.AddPressed}" />
    </Style>

    <Style
        x:Key="MacFluent.ButtonAction.Edit"
        BasedOn="{StaticResource MacFluent.ButtonBase}"
        TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Brush.Action.Edit}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Action.Edit}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Action.EditText}" />
        <Setter Property="helpers:ThemeProperties.HoverBackground" Value="{DynamicResource Brush.Action.EditHover}" />
        <Setter Property="helpers:ThemeProperties.PressedBackground" Value="{DynamicResource Brush.Action.EditPressed}" />
        <Setter Property="helpers:ThemeProperties.HoverBorderBrush" Value="{DynamicResource Brush.Action.EditHover}" />
        <Setter Property="helpers:ThemeProperties.PressedBorderBrush" Value="{DynamicResource Brush.Action.EditPressed}" />
    </Style>

    <Style
        x:Key="MacFluent.ButtonAction.Delete"
        BasedOn="{StaticResource MacFluent.ButtonBase}"
        TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Brush.Action.Delete}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Action.Delete}" />
